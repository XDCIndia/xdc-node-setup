{
  "schemaVersion": 1,
  "lastChecked": null,
  "checkIntervalHours": 6,
  "clients": {
    "XDPoSChain": {
      "repo": "XinFinOrg/XDPoSChain",
      "current": "v2.6.8",
      "latest": null,
      "autoUpdate": false,
      "binary": "XDC",
      "image": "xinfinorg/xdposchain:v2.6.8",
      "nodes": [
        {
          "host": "localhost",
          "role": "production",
          "rpcPort": 8545
        }
      ]
    },
    "gp5-xdc": {
      "repo": "AnilChinchawale/go-ethereum",
      "current": "v34",
      "latest": "v34",
      "autoUpdate": false,
      "binary": "geth",
      "image": "anilchinchawale/gp5-xdc:v34",
      "description": "GP5 XDC client with XDPoS v2 support",
      "networks": ["mainnet", "apothem"],
      "defaultPorts": {
        "rpc": 9545,
        "ws": 9546,
        "p2p": 30303
      },
      "nodes": [
        {
          "host": "localhost",
          "role": "production",
          "rpcPort": 9545
        }
      ]
    },
    "erigon-xdc": {
      "repo": "AnilChinchawale/erigon-xdc",
      "current": "0.1.0-alpha",
      "latest": null,
      "autoUpdate": false,
      "binary": "erigon"
    }
  },
  "infrastructure": {
    "docker": {
      "minVersion": "24.0"
    },
    "ubuntu": {
      "supported": ["20.04", "22.04", "24.04"]
    }
  },
  "notifications": {
    "telegram": {
      "enabled": false,
      "botToken": "",
      "chatId": ""
    },
    "webhook": {
      "enabled": false,
      "url": ""
    }
  },
  "ethstats": {
    "enabled": true,
    "server": "stats.xdcindia.com:443",
    "secret": "xdc_openscan_stats_2026",
    "nodeNamePrefix": "xdc-node"
  },
  "ethstats": {
    "enabled": true,
    "server": "stats.xdcindia.com:443",
    "secret": "xdc_openscan_stats_2026",
    "nodeNamePrefix": "xdc-node"
  },
  "monitoring": {
    "healthCheckInterval": 15,
    "versionCheckInterval": 360,
    "alertThresholds": {
      "blocksBehind": 100,
      "minPeers": 3,
      "diskWarning": 85,
      "diskCritical": 95,
      "cpuWarning": 90,
      "memoryWarning": 90,
      "securityScoreWarning": 70
    }
  },
  "backup": {
    "enabled": true,
    "schedule": {
      "daily": "0 3 * * *",
      "weekly": "0 2 * * 0"
    },
    "retention": {
      "daily": 7,
      "weekly": 4,
      "monthly": 12
    }
  }
}
