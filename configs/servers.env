# ============================================================
# servers.env — Fleet Server Registry
# Issue: https://github.com/XDCIndia/xdc-node-setup/issues/96
# ============================================================
# Maps server IDs to locations and SSH targets.
# Used by: scripts/lib/naming.sh, scripts/fleet.sh
# Pattern: {location}-{client}-{network}-{server_id}
# ============================================================

# --- Server Definitions ---
# Format: SERVER_<id>_HOST, SERVER_<id>_USER, SERVER_<id>_LOCATION

# Server 168 — test/dev node
SERVER_168_HOST=168.119.x.x
SERVER_168_USER=root
SERVER_168_LOCATION=test
SERVER_168_LABEL="Test Node"

# Server 213 — production node
SERVER_213_HOST=5.189.213.x
SERVER_213_USER=root
SERVER_213_LOCATION=prod
SERVER_213_LABEL="Production Node"

# --- Active Server List (space-separated IDs) ---
SERVERS="168 213"

# --- Default runtime identity (override per-server) ---
# SERVER_ID is set at runtime (usually from hostname or env)
SERVER_ID="${SERVER_ID:-168}"
LOCATION="${LOCATION:-$(echo "${SERVER_ID}" | sed 's/168/test/;s/213/prod/')}"
