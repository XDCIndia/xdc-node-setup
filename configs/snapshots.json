{
  "mainnet": {
    "full": {
      "url": "https://snapshots.xdc.network/mainnet/latest",
      "size": "~250GB",
      "type": "full",
      "updated": "weekly",
      "description": "Full node snapshot for mainnet",
      "note": "Community-hosted snapshot. Verify checksum before use."
    },
    "archive": {
      "url": "https://snapshots.xdc.network/mainnet/archive/latest",
      "size": "~500GB",
      "type": "archive",
      "updated": "monthly",
      "description": "Archive node with full historical state",
      "note": "Community-hosted snapshot. Verify checksum before use."
    }
  },
  "testnet": {
    "full": {
      "url": "https://snapshots.xdc.network/apothem/latest",
      "size": "~50GB",
      "type": "full",
      "updated": "weekly",
      "description": "Full node snapshot for Apothem testnet",
      "note": "Community-hosted snapshot. Verify checksum before use."
    }
  },
  "sources": {
    "primary": "https://snapshots.xdc.network",
    "mirrors": [
      "https://xdc-snapshots.oss-cn-hongkong.aliyuncs.com",
      "https://xdc-snapshots.s3.ap-southeast-1.amazonaws.com"
    ],
    "note": "Community-hosted snapshots. Always verify checksums. For custom mirrors, use XDC_SNAPSHOT_URL env var."
  },
  "checksums": {
    "algorithm": "SHA256",
    "suffix": ".sha256"
  },
  "custom_instructions": {
    "description": "How to use custom snapshot URLs",
    "example": "export XDC_SNAPSHOT_URL='https://your-mirror.com/xdc-snapshot.tar.gz' && xdc snapshot download mainnet-full",
    "create_own": "xdc snapshot create /backup/xdc-snapshots",
    "community": "Check XDC community channels for shared snapshots"
  },
  "validation": {
    "thresholds": {
      "mainnet": {
        "full": {
          "minChaindataSizeBytes": 161061273600,
          "minSstLdbFiles": 50000,
          "minAncientSegments": 1000,
          "maxStateBlockGap": 10,
          "requiredSubdirs": ["chaindata", "chaindata/ancient"]
        },
        "archive": {
          "minChaindataSizeBytes": 536870912000,
          "minSstLdbFiles": 150000,
          "minAncientSegments": 1000,
          "maxStateBlockGap": 0,
          "requiredSubdirs": ["chaindata", "chaindata/ancient", "chaindata/ancient/bodies", "chaindata/ancient/headers", "chaindata/ancient/receipts"]
        }
      },
      "testnet": {
        "full": {
          "minChaindataSizeBytes": 21474836480,
          "minSstLdbFiles": 10000,
          "minAncientSegments": 200,
          "maxStateBlockGap": 10,
          "requiredSubdirs": ["chaindata", "chaindata/ancient"]
        }
      }
    },
    "tools": {
      "ldbPackage": "rocksdb-tools",
      "optional": true,
      "note": "Install rocksdb-tools for full-level key-prefix verification"
    }
  }
}
