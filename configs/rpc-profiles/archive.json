{
  "profile": "archive",
  "description": "Archive node RPC - full historical state access for explorers and indexers",
  "allowed_methods": [
    "eth_blockNumber",
    "eth_getBlockByNumber",
    "eth_getBlockByHash",
    "eth_getTransactionByHash",
    "eth_getTransactionReceipt",
    "eth_getBalance",
    "eth_getCode",
    "eth_getStorageAt",
    "eth_call",
    "eth_estimateGas",
    "eth_gasPrice",
    "eth_sendRawTransaction",
    "eth_getTransactionCount",
    "eth_getLogs",
    "eth_getBlockTransactionCountByNumber",
    "eth_getBlockTransactionCountByHash",
    "eth_getTransactionByBlockNumberAndIndex",
    "eth_getTransactionByBlockHashAndIndex",
    "eth_getUncleCountByBlockNumber",
    "eth_getUncleByBlockNumberAndIndex",
    "net_version",
    "net_peerCount",
    "net_listening",
    "web3_clientVersion",
    "web3_sha3",
    "eth_chainId",
    "eth_syncing",
    "eth_protocolVersion",
    "eth_getProof",
    "debug_traceTransaction",
    "debug_traceBlockByNumber",
    "debug_traceBlockByHash",
    "trace_replayTransaction",
    "trace_replayBlockTransactions",
    "trace_block",
    "trace_filter"
  ],
  "blocked_methods": [
    "admin_*",
    "personal_*",
    "miner_*",
    "eth_sign",
    "eth_sendTransaction",
    "eth_signTransaction"
  ],
  "rate_limits": {
    "eth_call": "200/min",
    "eth_sendRawTransaction": "50/min",
    "eth_getLogs": "60/min",
    "debug_traceTransaction": "10/min",
    "debug_traceBlockByNumber": "5/min",
    "trace_replayTransaction": "10/min",
    "trace_block": "5/min",
    "default": "120/min"
  },
  "max_batch_size": 200,
  "max_response_size": "50MB",
  "notes": [
    "Archive nodes require significant disk space (1TB+)",
    "Debug/trace methods are CPU intensive",
    "Consider dedicated hardware for production use"
  ]
}
