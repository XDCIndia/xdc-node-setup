{
  "profile": "public-rpc",
  "description": "Public RPC endpoint - standard methods only, dangerous methods blocked",
  "allowed_methods": [
    "eth_blockNumber",
    "eth_getBlockByNumber",
    "eth_getBlockByHash",
    "eth_getTransactionByHash",
    "eth_getTransactionReceipt",
    "eth_getBalance",
    "eth_getCode",
    "eth_getStorageAt",
    "eth_call",
    "eth_estimateGas",
    "eth_gasPrice",
    "eth_sendRawTransaction",
    "eth_getTransactionCount",
    "eth_getLogs",
    "eth_getBlockTransactionCountByNumber",
    "eth_getBlockTransactionCountByHash",
    "eth_getTransactionByBlockNumberAndIndex",
    "eth_getTransactionByBlockHashAndIndex",
    "eth_getUncleCountByBlockNumber",
    "eth_getUncleByBlockNumberAndIndex",
    "net_version",
    "net_peerCount",
    "net_listening",
    "web3_clientVersion",
    "web3_sha3",
    "eth_chainId",
    "eth_syncing",
    "eth_protocolVersion",
    "eth_accounts",
    "eth_getCompilers"
  ],
  "blocked_methods": [
    "admin_*",
    "debug_*",
    "personal_*",
    "miner_*",
    "txpool_*",
    "eth_sign",
    "eth_sendTransaction",
    "eth_signTransaction"
  ],
  "rate_limits": {
    "eth_call": "100/min",
    "eth_sendRawTransaction": "20/min",
    "eth_getLogs": "30/min",
    "eth_getBalance": "120/min",
    "eth_getTransactionReceipt": "60/min",
    "default": "60/min"
  },
  "max_batch_size": 100,
  "max_response_size": "10MB"
}
