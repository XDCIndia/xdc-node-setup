#============================================================================
# XDC Node Security Hardening Configuration
# Addresses: #493, #492, #498, #499 - RPC Security and Container Hardening
#============================================================================

#----------------------------------------------------------------------------
# RPC Security Settings (#493, #492)
#----------------------------------------------------------------------------

# RPC bind address - use 127.0.0.1 instead of 0.0.0.0
# This restricts RPC access to localhost only
RPC_BIND_ADDRESS=127.0.0.1

# RPC port
RPC_PORT=8545

# WebSocket port  
WS_PORT=8546

# CORS configuration - specify exact origins instead of wildcard
# Format: comma-separated list of allowed origins
# Example: CORS_ORIGINS="https://xdc.network,https://explorer.xdc.network"
# Default: empty (no CORS allowed from browsers)
CORS_ORIGINS=""

# Virtual hosts - restrict which Host headers are accepted
# Format: comma-separated list of allowed hostnames
RPC_VHOSTS="localhost,127.0.0.1"

# API modules exposed via RPC (restrict to necessary modules)
RPC_API="eth,net,web3,txpool"

# Enable authenticated RPC only
RPC_AUTH_REQUIRED=true

# JWT secret for authenticated RPC (auto-generated if not set)
# This file should be owned by root with 0600 permissions
JWT_SECRET_FILE=/etc/xdc-node/jwt.hex

#----------------------------------------------------------------------------
# Container Security Settings (#499)
#----------------------------------------------------------------------------

# Run containers as non-root user
CONTAINER_USER_UID=1000
CONTAINER_USER_GID=1000

# Disable Docker socket mounting (set to true only if absolutely required)
MOUNT_DOCKER_SOCKET=false

# Drop all capabilities and add only required ones
CONTAINER_CAP_DROP="ALL"
CONTAINER_CAP_ADD="CHOWN,SETGID,SETUID"

# Use read-only root filesystem
CONTAINER_READ_ONLY=true

# Enable seccomp profile
CONTAINER_SECCOMP_PROFILE=/etc/xdc-node/seccomp-default.json

#----------------------------------------------------------------------------
# Authentication Settings (#498)
#----------------------------------------------------------------------------

# Dashboard authentication
DASHBOARD_AUTH_ENABLED=true
DASHBOARD_USER=""
DASHBOARD_PASS=""

# Generate random credentials on first run if not set
GENERATE_RANDOM_CREDENTIALS=true

# API key for SkyNet integration (should be provided via environment)
SKYNET_API_KEY=""

#----------------------------------------------------------------------------
# Network Security
#----------------------------------------------------------------------------

# P2P bind address (0.0.0.0 is required for peer connections)
P2P_BIND_ADDRESS=0.0.0.0
P2P_PORT=30303

# Enable UPnP port mapping (disable in production)
ENABLE_UPNP=false

# NAT external IP (set to your public IP)
NAT_EXT_IP=""

#----------------------------------------------------------------------------
# Rate Limiting
#----------------------------------------------------------------------------

# Enable RPC rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=20

#----------------------------------------------------------------------------
# Logging and Audit
#----------------------------------------------------------------------------

# Log all RPC calls
RPC_LOG_ALL_CALLS=true

# Log file location
SECURITY_LOG_FILE=/var/log/xdc-node/security.log

# Audit log for sensitive operations
AUDIT_LOG_ENABLED=true
AUDIT_LOG_FILE=/var/log/xdc-node/audit.log
