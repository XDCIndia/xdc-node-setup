# Standard XDC Multi-Client Port Map
# =================================
# This file defines the standard port assignments for all XDC clients
# to avoid conflicts when running multiple clients simultaneously.

# GP5 (Geth XDC Stable) - Official Client
GP5_RPC_PORT=8545
GP5_WS_PORT=8546
GP5_P2P_PORT=30303
GP5_METRICS_PORT=6060

# Geth PR5 (Feature Branch)
GP5_PR5_RPC_PORT=7070
GP5_PR5_WS_PORT=7071
GP5_PR5_P2P_PORT=30304
GP5_PR5_METRICS_PORT=6070

# Erigon-XDC - High-Performance Client
ERIGON_RPC_PORT=8547
ERIGON_WS_PORT=8548
ERIGON_P2P_PORT=30305
ERIGON_P2P_SENTRY=30311
ERIGON_AUTH_PORT=8561
ERIGON_METRICS_PORT=6071
ERIGON_PRIVATE_API=9091

# Nethermind-XDC - .NET Client
NM_RPC_PORT=8558
NM_WS_PORT=8559
NM_P2P_PORT=30306
NM_METRICS_PORT=6072

# Reth-XDC - Rust Client (Alpha)
RETH_RPC_PORT=8588
RETH_WS_PORT=8589
RETH_P2P_PORT=40303
RETH_DISCOVERY_PORT=40304
RETH_AUTH_PORT=8551
RETH_METRICS_PORT=6073

# SkyOne Dashboard
SKYONE_PORT=7070

# Note: GP5 uses standard ports (8545, 8546, 30303) for backward compatibility
# All other clients use non-conflicting ports to enable multi-client deployments
