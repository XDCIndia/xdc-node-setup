#==============================================================================
# XDC Mainnet Node Configuration
# 
# Copy this file and customize for your deployment.
# DO NOT commit the actual .env file with real passwords to version control.
#==============================================================================

#------------------------------------------------------------------------------
# Network Configuration
#------------------------------------------------------------------------------
NETWORK=mainnet
INSTANCE_NAME=xdc-mainnet-node

#------------------------------------------------------------------------------
# Sync and Storage Configuration
#------------------------------------------------------------------------------
# SYNC_MODE: full or fast
# - full: Downloads and validates all blocks from genesis (most secure)
# - fast: Downloads blocks but only validates headers (faster sync)
SYNC_MODE=full

# GC_MODE: archive or full
# - archive: Keeps all historical state (required for masternodes)
# - full: Prunes old state (uses less disk space)
GC_MODE=full

# LOG_LEVEL: 0=silent, 1=error, 2=warn, 3=info, 4=debug, 5=detail
LOG_LEVEL=2

#------------------------------------------------------------------------------
# RPC Configuration (enabled by default for production nodes)
#------------------------------------------------------------------------------
ENABLE_RPC=true
RPC_ADDR=0.0.0.0
RPC_PORT=8545
RPC_API=admin,eth,net,web3,XDPoS
RPC_CORS_DOMAIN=*
RPC_VHOSTS=*

#------------------------------------------------------------------------------
# WebSocket Configuration
#------------------------------------------------------------------------------
WS_ADDR=0.0.0.0
WS_PORT=8546
WS_API=eth,net,web3,XDPoS
WS_ORIGINS=*

#------------------------------------------------------------------------------
# Network Configuration
#------------------------------------------------------------------------------
PORT=30303
NAT=any

#------------------------------------------------------------------------------
# Metrics and Profiling
#------------------------------------------------------------------------------
METRICS=true
METRICS_ADDR=0.0.0.0
METRICS_PORT=6060
PPROF=true
PPROF_ADDR=0.0.0.0
PPROF_PORT=6060

#------------------------------------------------------------------------------
# Log Rotation
#------------------------------------------------------------------------------
# Maximum log file size in bytes before rotation (default: 1GB)
MAX_LOG_SIZE=1073741824

#------------------------------------------------------------------------------
# Grafana Configuration
#------------------------------------------------------------------------------
# IMPORTANT: Change these default credentials in production!
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
GRAFANA_SECRET_KEY=xdc-grafana-secret
GRAFANA_ROOT_URL=http://localhost:3000

#------------------------------------------------------------------------------
# Dashboard Configuration (optional)
#------------------------------------------------------------------------------
DASHBOARD_API_KEY=
