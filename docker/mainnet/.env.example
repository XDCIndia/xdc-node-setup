# Network Configuration
NETWORK=mainnet
NODE_NAME=xdc-node

# RPC Configuration
RPC_PORT=8545
RPC_ADDR=127.0.0.1
RPC_CORS_DOMAIN=http://localhost:3000
RPC_VHOSTS=localhost
WS_PORT=8546
WS_ADDR=127.0.0.1
WS_ORIGINS=http://localhost:3000

# P2P Configuration
P2P_PORT=30303
P2P_NAT=any

# Performance Tuning
CACHE=4096
TRIE_CACHE=1024
TX_POOL_GLOBAL_SLOTS=8192
TX_POOL_ACCOUNT_SLOTS=32

# Security
PPROF_ADDR=127.0.0.1
PPROF_PORT=6060

# SkyNet Integration (optional)
SKYNET_API_URL=https://net.xdc.network/api/v1
SKYNET_API_KEY=your_api_key_here
SKYNET_EMAIL=your_email@example.com
