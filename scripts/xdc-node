}

log() {
    if [[ "$QUIET" != "true" ]]; then
        echo -e "$(c GREEN)✓$(c NC) $1"
    fi
}

info() {
    if [[ "$QUIET" != "true" ]]; then
        echo -e "$(c BLUE)ℹ$(c NC) $1"
    fi
}

warn() {
    echo -e "$(c YELLOW)⚠$(c NC) $1" >&2
}

error() {
    echo -e "$(c RED)✗$(c NC) $1" >&2
}

die() {
    error "$1"
    exit 1
}

verbose() {
    if [[ "$VERBOSE" == "true" ]]; then
        echo -e "$(c DIM)$1$(c NC)"
    fi
}

json_output() {
    if [[ "$OUTPUT_JSON" == "true" ]]; then
        echo "$1"
        return 0
    fi
    return 1
}

# Spinner for long operations
spinner_pid=""
start_spinner() {
    local msg="${1:-Processing}"
    if [[ "$QUIET" == "true" ]] || [[ "$OUTPUT_JSON" == "true" ]]; then
        return
    fi
    (
        local i=0
        while true; do
            printf "\r$(c CYAN)${SPINNER_CHARS:i++%${#SPINNER_CHARS}:1}$(c NC) %s..." "$msg"
            sleep 0.1
        done
    ) &
    spinner_pid=$!
    disown "$spinner_pid" 2>/dev/null || true
}

stop_spinner() {
    local success="${1:-true}"
    local msg="${2:-Done}"
    if [[ -n "$spinner_pid" ]]; then
        kill "$spinner_pid" 2>/dev/null || true
        wait "$spinner_pid" 2>/dev/null || true
        spinner_pid=""
    fi
    if [[ "$QUIET" != "true" ]] && [[ "$OUTPUT_JSON" != "true" ]]; then
        if [[ "$success" == "true" ]]; then
            printf "\r$(c GREEN)✓$(c NC) %s    \n" "$msg"
        else
            printf "\r$(c RED)✗$(c NC) %s    \n" "$msg"
        fi
    fi
}

# Progress bar
progress_bar() {
    local current=$1
    local total=$2
    local width=${3:-40}
    local label=${4:-"Progress"}
    
    if [[ "$QUIET" == "true" ]] || [[ "$OUTPUT_JSON" == "true" ]]; then
        return
    fi
    
    local percent=$((current * 100 / total))
    local filled=$((current * width / total))
    local empty=$((width - filled))
    
    printf "\r$(c CYAN)%s$(c NC) [" "$label"
    printf "%${filled}s" '' | tr ' ' '█'
    printf "%${empty}s" '' | tr ' ' '░'
    printf "] %3d%%" "$percent"
    
    if [[ $current -eq $total ]]; then
        echo ""
    fi
}

# Table drawing
print_table_header() {
    local cols=("$@")
    local line=""
    
    echo -e "$(c BOLD)┌$(printf '─%.0s' {1..78})┐$(c NC)"
    printf "$(c BOLD)│$(c NC)"
    for col in "${cols[@]}"; do
        printf " %-10s$(c BOLD)│$(c NC)" "$col"
    done
    echo ""
    echo -e "$(c BOLD)├$(printf '─%.0s' {1..78})┤$(c NC)"
}

print_table_row() {
    local cols=("$@")
    printf "$(c BOLD)│$(c NC)"
    for col in "${cols[@]}"; do
        printf " %-10s$(c BOLD)│$(c NC)" "$col"
    done
    echo ""
}

print_table_footer() {
    echo -e "$(c BOLD)└$(printf '─%.0s' {1..78})┘$(c NC)"
}

# Check if running as root
require_root() {
    if [[ $EUID -ne 0 ]]; then
        die "This command requires root privileges. Please run with sudo."
    fi
}

# Check if a command exists
command_exists() {
    command -v "$1" &>/dev/null
}

# RPC call helper
rpc_call() {
    local url="${1:-http://localhost:8545}"
    local method="$2"
    local params="${3:-[]}"
    
    curl -s -m 10 -X POST \
        -H "Content-Type: application/json" \
        -d "{\"jsonrpc\":\"2.0\",\"method\":\"$method\",\"params\":$params,\"id\":1}" \
        "$url" 2>/dev/null || echo '{}'
}

# Get config value from versions.json
get_config() {
    local key="$1"
    local default="${2:-}"
    
    if [[ -f "$VERSIONS_FILE" ]]; then
        local value
        value=$(jq -r "$key // empty" "$VERSIONS_FILE" 2>/dev/null)
        if [[ -n "$value" && "$value" != "null" ]]; then
            echo "$value"
            return 0
        fi
    fi
    echo "$default"
}

# Run a script from the scripts directory
run_script() {
    local script="$1"
    shift
    local script_path="${SCRIPTS_DIR}/${script}"
    
    if [[ ! -f "$script_path" ]]; then
        # Try to find script in project dir
        script_path="${PROJECT_DIR}/scripts/${script}"
    fi
    
    if [[ ! -f "$script_path" ]]; then
        error "Script not found: $script"
        return 1
    fi
    
    if [[ ! -x "$script_path" ]]; then
        chmod +x "$script_path" 2>/dev/null || true
    fi
    
    bash "$script_path" "$@"
}

# Detect node service name
detect_service() {
    for service in xdc-node xdcchain xdc geth erigon; do
        if systemctl list-units --type=service --all | grep -q "$service"; then
            echo "$service"
            return 0
        fi
    done
    echo ""
}

# Find Docker container by name pattern
find_container() {
    # Common XDC container names
    local common_names=("xdc-node" "xdc" "xdcchain" "mainnet-node" "xdcnetwork-mainnet-node")
    
    # Check if docker is available
    if ! command -v docker &>/dev/null; then
        return 1
    fi
    
    # First check exact common names
    for name in "${common_names[@]}"; do
        if docker ps -a --format '{{.Names}}' 2>/dev/null | grep -qx "$name"; then
            echo "$name"
            return 0
        fi
    done
    
    # Then check pattern xdc.*node
    local container
    container=$(docker ps -a --format '{{.Names}}' 2>/dev/null | grep -E '^xdc.*node$' | head -1)
    if [[ -n "$container" ]]; then
        echo "$container"
        return 0
    fi
    
    # Check for any container with xdc in the name
    container=$(docker ps -a --format '{{.Names}}' 2>/dev/null | grep -i "xdc" | head -1)
    if [[ -n "$container" ]]; then
        echo "$container"
        return 0
    fi
    
    return 1
}

# Detect running client
detect_client() {
    if pgrep -x "XDC" &>/dev/null || pgrep -f "geth.*xdc" &>/dev/null; then
        echo "XDPoSChain"
    elif pgrep -x "erigon" &>/dev/null; then
        echo "erigon-xdc"
    else
        echo "unknown"
    fi
}

# Get RPC URL from config or use default
get_rpc_url() {
    # Check if --rpc flag was used
    if [[ -n "${XDC_RPC_URL:-}" ]]; then
        echo "$XDC_RPC_URL"
        return
    fi
    
    local default_url="http://127.0.0.1:${RPC_PORT:-8545}"
    local config_url
    config_url=$(get_config ".rpc_url" "")
    if [[ -n "$config_url" && "$config_url" != "null" ]]; then
        echo "$config_url"
    else
        echo "$default_url"
    fi
}

# Start xdc-agent container for SkyNet monitoring + auto-heal
_start_xdc_agent() {
    local network="${1:-mainnet}"
    local client="${2:-stable}"
    local node_type="${3:-full}"
    
    info "Starting xdc-agent (SkyNet monitoring)..."
    
    # Check if agent is already running
    if docker ps --format '{{.Names}}' 2>/dev/null | grep -q "xdc-agent"; then
        info "xdc-agent already running, restarting with updated config..."
        docker stop xdc-agent 2>/dev/null || true
        docker rm xdc-agent 2>/dev/null || true
    fi
    
    # Determine RPC port for the client
    local agent_rpc_port="${RPC_PORT:-8545}"
    case "$client" in
        erigon)      agent_rpc_port="${ERIGON_RPC_PORT:-8547}" ;;
        nethermind)  agent_rpc_port="${NM_RPC_PORT:-8558}" ;;
        reth)        agent_rpc_port="${RETH_RPC_PORT:-7073}" ;;
        geth-pr5)    agent_rpc_port="${GP5_RPC_PORT:-8557}" ;;
    esac
    
    # Read SkyNet config if available
    local skynet_url="${SKYNET_URL:-https://net.xdc.network}"
    local skynet_node_id="${SKYNET_NODE_ID:-}"
    local skynet_api_key="${SKYNET_API_KEY:-}"
    
    # Try to read from skynet.conf
    local skynet_conf="../${network}/.xdc-node/skynet.conf"
    if [[ -f "$skynet_conf" ]]; then
        skynet_node_id=$(grep -E '^SKYNET_NODE_ID=' "$skynet_conf" 2>/dev/null | cut -d= -f2 || echo "")
        skynet_api_key=$(grep -E '^SKYNET_API_KEY=' "$skynet_conf" 2>/dev/null | cut -d= -f2 || echo "")
        skynet_url=$(grep -E '^SKYNET_URL=' "$skynet_conf" 2>/dev/null | cut -d= -f2 || echo "$skynet_url")
    fi
    
    # Auto-generate node ID if not set
    if [[ -z "$skynet_node_id" ]]; then
        local hostname_short=$(hostname -s 2>/dev/null || echo "node")
        skynet_node_id="xdc-${client}-${hostname_short}-${network}"
        warn "No SKYNET_NODE_ID configured, using: $skynet_node_id"
    fi
    
    # Ensure xdc-network exists
    docker network create xdc-network 2>/dev/null || true
    
    # Run agent container
    docker run -d \
        --name xdc-agent \
        --restart unless-stopped \
        --network xdc-network \
        -e RPC_URL="http://host.docker.internal:${agent_rpc_port}" \
        -e SKYNET_URL="$skynet_url" \
        -e SKYNET_NODE_ID="$skynet_node_id" \
        -e SKYNET_API_KEY="$skynet_api_key" \
        -e CLIENT_NAME="$client" \
        -e NODE_TYPE="$node_type" \
        -e NETWORK="$network" \
        -e HEARTBEAT_INTERVAL=60 \
        -v /var/run/docker.sock:/var/run/docker.sock:ro \
        --add-host=host.docker.internal:host-gateway \
        anilchinchawale/xdc-agent:v2 2>/dev/null && \
        log "xdc-agent started (node: $skynet_node_id, rpc: :$agent_rpc_port)" || \
        warn "Failed to start xdc-agent. Install with: docker pull anilchinchawale/xdc-agent:v2"
}

# Inject peers from bootnodes.list or SkyNet API
inject_peers() {
    local rpc_url
    rpc_url=$(get_rpc_url)
    local peers_added=0
    local max_peers=25
    
    info "Checking peer count..."
    
    # Get current peer count via RPC
    local response
    response=$(rpc_call "$rpc_url" "net_peerCount" "[]" 2>/dev/null || echo '{}')
    local hex_peers
    hex_peers=$(echo "$response" | jq -r '.result // "0x0"')
    local current_peers=0
    if [[ "$hex_peers" != "0x0" && -n "$hex_peers" && "$hex_peers" != "null" ]]; then
        current_peers=$((16#${hex_peers#0x}))
    fi
    
    info "Current peer count: $current_peers"
    
    # If we have enough peers, skip injection
    if [[ $current_peers -ge 3 ]]; then
        info "Sufficient peers connected ($current_peers >= 3), skipping peer injection"
        return 0
    fi
    
    info "Low peer count detected, injecting peers..."
    
    # Array to hold bootnode enodes
    local bootnodes=()
    
    # Try local bootnodes.list first
    local bootnodes_file="$INSTALL_DIR/docker/mainnet/bootnodes.list"
    if [[ -f "$bootnodes_file" ]]; then
        info "Reading bootnodes from $bootnodes_file"
        while IFS= read -r line; do
            # Skip empty lines and comments
            [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
            # Extract enode if line contains one
            if [[ "$line" =~ ^enode:// ]]; then
                bootnodes+=("$line")
            fi
        done < "$bootnodes_file"
    fi
    
    # If no local bootnodes, try SkyNet API
    if [[ ${#bootnodes[@]} -eq 0 ]]; then
        info "No local bootnodes found, trying SkyNet API..."
        local skynet_response
        skynet_response=$(curl -s -m 10 "https://net.xdc.network/api/v1/peers/healthy" 2>/dev/null || echo '[]')
        
        # Parse enodes from SkyNet API response
        local skynet_peers
        skynet_peers=$(echo "$skynet_response" | jq -r '.[].enode // empty' 2>/dev/null)
        
        if [[ -n "$skynet_peers" ]]; then
            while IFS= read -r enode; do
                [[ -n "$enode" ]] && bootnodes+=("$enode")
            done <<< "$skynet_peers"
        fi
    fi
    
    # Limit the number of peers to inject
    local total_bootnodes=${#bootnodes[@]}
    if [[ $total_bootnodes -gt $max_peers ]]; then
        info "Limiting to $max_peers peers out of $total_bootnodes available"
        total_bootnodes=$max_peers
    fi
    
    if [[ $total_bootnodes -eq 0 ]]; then
        warn "No bootnodes found to inject"
        return 1
    fi
    
    info "Injecting $total_bootnodes peers..."
    
    # Add each peer via admin_addPeer RPC
    local i=0
    for enode in "${bootnodes[@]}"; do
        [[ $i -ge $max_peers ]] && break
        
        # Validate enode format
        if [[ ! "$enode" =~ ^enode://[a-f0-9]{128}@[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+:[0-9]+$ ]]; then
            verbose "Skipping invalid enode: ${enode:0:40}..."
            continue
        fi
        
        local add_response
        add_response=$(rpc_call "$rpc_url" "admin_addPeer" "[\"$enode\"]" 2>/dev/null || echo '{}')
        local success
        success=$(echo "$add_response" | jq -r '.result // false')
        
        if [[ "$success" == "true" ]]; then
            peers_added=$((peers_added + 1))
            verbose "Added peer: ${enode:0:40}..."
        else
            verbose "Failed to add peer: ${enode:0:40}..."
        fi
        
        i=$((i + 1))
        
        # Small delay to avoid overwhelming the node
        sleep 0.1
    done
    
    log "Injected $peers_added peers successfully"
    
    # Wait a moment for connections to establish
    sleep 2
    
    # Check new peer count
    response=$(rpc_call "$rpc_url" "net_peerCount" "[]" 2>/dev/null || echo '{}')
    hex_peers=$(echo "$response" | jq -r '.result // "0x0"')
    local new_peers=0
    if [[ "$hex_peers" != "0x0" && -n "$hex_peers" && "$hex_peers" != "null" ]]; then
        new_peers=$((16#${hex_peers#0x}))
    fi
    
    info "Peer count after injection: $new_peers"
    
    return 0
}

#==============================================================================
# Command: init
#==============================================================================
cmd_init() {
    local quick=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --quick) quick=true; shift ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node init$(c NC) — Interactive setup wizard

$(c BOLD)USAGE:$(c NC)
    xdc-node init [options]

$(c BOLD)OPTIONS:$(c NC)
    --quick     Minimal setup with defaults
    --help      Show this help

$(c BOLD)DESCRIPTION:$(c NC)
    Runs the interactive XDC node setup wizard. This will:
    - Check system requirements
    - Install dependencies
    - Configure the node
    - Set up monitoring and alerts

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    require_root
    
    if [[ ! -f "${PROJECT_DIR}/setup.sh" ]]; then
        die "Setup script not found at ${PROJECT_DIR}/setup.sh"
    fi
    
    print_banner
    
    if [[ "$quick" == "true" ]]; then
        info "Running quick setup with defaults..."
        export NON_INTERACTIVE=true
        bash "${PROJECT_DIR}/setup.sh"
    else
        info "Starting interactive setup wizard..."
        bash "${PROJECT_DIR}/setup.sh"
    fi
}

#==============================================================================
# Command: status
#==============================================================================
cmd_status() {
    local watch=false
    local interval=5
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --watch|-w) watch=true; shift ;;
            --interval) interval="$2"; shift 2 ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node status$(c NC) — Quick node status overview

$(c BOLD)USAGE:$(c NC)
    xdc-node status [options]

$(c BOLD)OPTIONS:$(c NC)
    --watch, -w      Auto-refresh every 5 seconds
    --interval N     Refresh interval in seconds (default: 5)
    --json           Output in JSON format
    --help           Show this help

$(c BOLD)OUTPUT:$(c NC)
    Shows a table with: Node | Block | Peers | Sync% | CPU | RAM | Disk | Status

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    show_status() {
        local rpc_url="${XDC_RPC_URL:-http://localhost:8545}"
        local mainnet_rpc="${MAINNET_RPC_URL:-https://erpc.xinfin.network}"
        
        # Check if multi-client mode is active (both geth and erigon running)
        local geth_running=false
        local erigon_running=false
        if docker ps --format '{{.Names}}' 2>/dev/null | grep -q "^xdc-node$"; then
            geth_running=true
        fi
        if docker ps --format '{{.Names}}' 2>/dev/null | grep -q "^xdc-node-erigon$"; then
            erigon_running=true
        fi
        
        # Helper function to get client status
        get_client_status() {
            local client_rpc="$1"
            local _response _hex_height _block_height=0 _sync_pct=100 _sync_status="synced" _peers=0
            local _client_version="unknown" _node_name="unknown" _network_id="unknown" _network="unknown"
            local _container_status="not running"
            
            # Get block height
            _response=$(rpc_call "$client_rpc" "eth_blockNumber")
            _hex_height=$(echo "$_response" | jq -r '.result // "0x0"')
            if [[ "$_hex_height" != "0x0" && -n "$_hex_height" && "$_hex_height" != "null" ]]; then
                _block_height=$((16#${_hex_height#0x}))
            fi
            
            # Get sync status
            _response=$(rpc_call "$client_rpc" "eth_syncing")
            local _syncing=$(echo "$_response" | jq -r '.result')
            if [[ "$_syncing" != "false" && "$_syncing" != "null" ]]; then
                local _current_block=$(echo "$_syncing" | jq -r '.currentBlock // "0x0"')
                local _highest_block=$(echo "$_syncing" | jq -r '.highestBlock // "0x0"')
                if [[ "$_current_block" != "0x0" && "$_highest_block" != "0x0" ]]; then
                    local _current=$((16#${_current_block#0x}))
                    local _highest=$((16#${_highest_block#0x}))
                    if [[ $_highest -gt 0 ]]; then
                        _sync_pct=$((_current * 100 / _highest))
                        _sync_status="syncing"
                    fi
                fi
            else
                # Check against mainnet
                _response=$(rpc_call "$mainnet_rpc" "eth_blockNumber")
                _hex_height=$(echo "$_response" | jq -r '.result // "0x0"')
                local _mainnet_height=0
                if [[ "$_hex_height" != "0x0" && -n "$_hex_height" && "$_hex_height" != "null" ]]; then
                    _mainnet_height=$((16#${_hex_height#0x}))
                fi
                if [[ $_mainnet_height -gt 0 && $_block_height -gt 0 ]]; then
                    _sync_pct=$((_block_height * 100 / _mainnet_height))
                    [[ $_sync_pct -gt 100 ]] && _sync_pct=100
                    [[ $_sync_pct -lt 99 ]] && _sync_status="syncing"
                fi
            fi
            
            # Get peer count
            _response=$(rpc_call "$client_rpc" "net_peerCount")
            local _hex_peers=$(echo "$_response" | jq -r '.result // "0x0"')
            if [[ "$_hex_peers" != "0x0" && -n "$_hex_peers" && "$_hex_peers" != "null" ]]; then
                _peers=$((16#${_hex_peers#0x}))
            fi
            
            # Get node info
            _response=$(rpc_call "$client_rpc" "admin_nodeInfo")
            _client_version=$(echo "$_response" | jq -r '.result.name // "unknown"')
            _node_name=$(echo "$_response" | jq -r '.result.id // "unknown"' | cut -d'@' -f1)
            _network_id=$(echo "$_response" | jq -r '.result.protocols.eth.network // .result.protocols.XDPoS.network // "unknown"')
            
            # Map network ID
            case "$_network_id" in
                50|"50") _network="mainnet" ;;
                51|"51") _network="testnet/apothem" ;;
                89|"89") _network="devnet" ;;
                *) _network="network-$_network_id" ;;
            esac
            
            # Return values
            echo "${_block_height}|${_sync_pct}|${_sync_status}|${_peers}|${_client_version}|${_node_name}|${_network}|${_network_id}"
        }
        
        # Get system stats
        local cpu_usage
        cpu_usage=$(awk '/^cpu /{u=$2+$4; t=$2+$3+$4+$5+$6+$7+$8; printf "%.0f", u/t*100}' /proc/stat 2>/dev/null || echo "0")
        local ram_usage
        ram_usage=$(awk '/MemTotal/{t=$2} /MemAvailable/{a=$2} END{printf "%.0f", (t-a)/t*100}' /proc/meminfo 2>/dev/null || echo "0")
        local disk_usage
        mkdir -p "${XDC_DATA}" 2>/dev/null || true
        disk_usage=$(df -h "${XDC_DATA}" 2>/dev/null | awk 'NR==2 {gsub(/%/,"",$5); print $5}' || echo "0")
        
        # Multi-client status display
        if [[ "$geth_running" == "true" && "$erigon_running" == "true" ]]; then
            # Both clients running - show multi-client status
            local geth_env_file="../${XDC_NETWORK:-mainnet}/.xdc-node/.env"
            local erigon_rpc_port=$(grep -E '^ERIGON_RPC_PORT=' "$geth_env_file" 2>/dev/null | cut -d= -f2 || echo 8547)
            : "${erigon_rpc_port:=8547}"
            
            # Get geth status (default RPC port)
            local geth_status geth_block geth_sync geth_peers geth_ver geth_node geth_net geth_netid
            IFS='|' read -r geth_block geth_sync_pct geth_sync geth_peers geth_ver geth_node geth_net geth_netid <<< "$(get_client_status "http://localhost:8545")"
            
            # Get erigon status
            local erigon_status erigon_block erigon_sync erigon_peers erigon_ver erigon_node erigon_net erigon_netid
            IFS='|' read -r erigon_block erigon_sync_pct erigon_sync erigon_peers erigon_ver erigon_node erigon_net erigon_netid <<< "$(get_client_status "http://localhost:${erigon_rpc_port}")"
            
            # Determine status indicators
            local geth_status_ind="$(c GREEN)●$(c NC) Online"
            [[ $geth_block -eq 0 ]] && geth_status_ind="$(c RED)●$(c NC) Offline"
            [[ "$geth_sync" == "syncing" ]] && geth_status_ind="$(c YELLOW)●$(c NC) Syncing"
            
            local erigon_status_ind="$(c GREEN)●$(c NC) Online"
            [[ $erigon_block -eq 0 ]] && erigon_status_ind="$(c RED)●$(c NC) Offline"
            [[ "$erigon_sync" == "syncing" ]] && erigon_status_ind="$(c YELLOW)●$(c NC) Syncing"
            
            if json_output ""; then
                cat << EOF
{
  "multiClient": true,
  "geth": {
    "clientVersion": "$geth_ver",
    "blockHeight": $geth_block,
    "syncPercent": $geth_sync_pct,
    "syncStatus": "$geth_sync",
    "peers": $geth_peers
  },
  "erigon": {
    "clientVersion": "$erigon_ver",
    "blockHeight": $erigon_block,
    "syncPercent": $erigon_sync_pct,
    "syncStatus": "$erigon_sync",
    "peers": $erigon_peers
  },
  "cpu": $cpu_usage,
  "ram": $ram_usage,
  "disk": $disk_usage,
  "timestamp": "$(date -Iseconds)"
}
EOF
                return 0
            fi
            
            # Print multi-client table
            echo ""
            echo -e "$(c BOLD)┌─────────────────────────────────────────────────────────────────────────────────┐$(c NC)"
            echo -e "$(c BOLD)│$(c NC)                 $(c CYAN)XDC Multi-Client Status$(c NC) (Geth + Erigon)                 $(c BOLD)│$(c NC)"
            echo -e "$(c BOLD)├──────────────┬───────────┬───────┬───────┬─────────┬────────────────────────────┤$(c NC)"
            echo -e "$(c BOLD)│$(c NC) $(c WHITE)Client$(c NC)       $(c BOLD)│$(c NC) $(c WHITE)Block$(c NC)     $(c BOLD)│$(c NC) $(c WHITE)Peers$(c NC) $(c BOLD)│$(c NC) $(c WHITE)Sync%$(c NC) $(c BOLD)│$(c NC) $(c WHITE)Status$(c NC)  $(c BOLD)│$(c NC) $(c WHITE)Version$(c NC)                  $(c BOLD)│$(c NC)"
            echo -e "$(c BOLD)├──────────────┼───────────┼───────┼───────┼─────────┼────────────────────────────┤$(c NC)"
            printf "$(c BOLD)│$(c NC) $(c CYAN)%-12s$(c NC) $(c BOLD)│$(c NC) %-9s $(c BOLD)│$(c NC) %-5s $(c BOLD)│$(c NC) %-5s $(c BOLD)│$(c NC) %-7s $(c BOLD)│$(c NC) %-26s $(c BOLD)│$(c NC)\n" \
                "Geth" "$geth_block" "$geth_peers" "${geth_sync_pct}%" "$geth_status_ind" "${geth_ver:0:26}"
            printf "$(c BOLD)│$(c NC) $(c MAGENTA)%-12s$(c NC) $(c BOLD)│$(c NC) %-9s $(c BOLD)│$(c NC) %-5s $(c BOLD)│$(c NC) %-5s $(c BOLD)│$(c NC) %-7s $(c BOLD)│$(c NC) %-26s $(c BOLD)│$(c NC)\n" \
                "Erigon" "$erigon_block" "$erigon_peers" "${erigon_sync_pct}%" "$erigon_status_ind" "${erigon_ver:0:26}"
            echo -e "$(c BOLD)└──────────────┴───────────┴───────┴───────┴─────────┴────────────────────────────┘$(c NC)"
            echo ""
            echo -e "$(c BOLD)System Resources:$(c NC)"
            echo -e "  CPU: ${cpu_usage}% | RAM: ${ram_usage}% | Disk: ${disk_usage}%"
            echo ""
            echo -e "$(c BOLD)RPC Endpoints:$(c NC)"
            echo -e "  Geth:    $(c CYAN)http://localhost:8545$(c NC)"
            echo -e "  Erigon:  $(c CYAN)http://localhost:${erigon_rpc_port}$(c NC)"
            echo ""
            echo -e "$(c DIM)Both clients are running simultaneously and can peer with each other$(c NC)"
            echo ""
            return 0
        fi
        
        # Single client mode - existing behavior
        # Get block height
        local response
        response=$(rpc_call "$rpc_url" "eth_blockNumber")
        local hex_height
        hex_height=$(echo "$response" | jq -r '.result // "0x0"')
        local block_height=0
        if [[ "$hex_height" != "0x0" && -n "$hex_height" && "$hex_height" != "null" ]]; then
            block_height=$((16#${hex_height#0x}))
        fi
        
        # Get sync status
        response=$(rpc_call "$rpc_url" "eth_syncing")
        local syncing=$(echo "$response" | jq -r '.result')
        local sync_status="synced"
        local sync_pct=100
        
        if [[ "$syncing" != "false" && "$syncing" != "null" ]]; then
            local current_block=$(echo "$syncing" | jq -r '.currentBlock // "0x0"')
            local highest_block=$(echo "$syncing" | jq -r '.highestBlock // "0x0"')
            if [[ "$current_block" != "0x0" && "$highest_block" != "0x0" ]]; then
                local current=$((16#${current_block#0x}))
                local highest=$((16#${highest_block#0x}))
                if [[ $highest -gt 0 ]]; then
                    sync_pct=$((current * 100 / highest))
                    sync_status="syncing"
                fi
            fi
        else
            response=$(rpc_call "$mainnet_rpc" "eth_blockNumber")
            hex_height=$(echo "$response" | jq -r '.result // "0x0"')
            local mainnet_height=0
            if [[ "$hex_height" != "0x0" && -n "$hex_height" && "$hex_height" != "null" ]]; then
                mainnet_height=$((16#${hex_height#0x}))
            fi
            if [[ $mainnet_height -gt 0 ]]; then
                sync_pct=$((block_height * 100 / mainnet_height))
                [[ $sync_pct -gt 100 ]] && sync_pct=100
                [[ $sync_pct -lt 99 ]] && sync_status="syncing"
            fi
        fi
        
        # Get peer count
        response=$(rpc_call "$rpc_url" "net_peerCount")
        local hex_peers
        hex_peers=$(echo "$response" | jq -r '.result // "0x0"')
        local peers=0
        if [[ "$hex_peers" != "0x0" && -n "$hex_peers" && "$hex_peers" != "null" ]]; then
            peers=$((16#${hex_peers#0x}))
        fi
        
        # Get node info
        response=$(rpc_call "$rpc_url" "admin_nodeInfo")
        local client_version=$(echo "$response" | jq -r '.result.name // "unknown"')
        local node_name=$(echo "$response" | jq -r '.result.id // "unknown"' | cut -d'@' -f1)
        local network_id=$(echo "$response" | jq -r '.result.protocols.eth.network // .result.protocols.XDPoS.network // "unknown"')
        
        local network="unknown"
        case "$network_id" in
            50|"50") network="mainnet" ;;
            51|"51") network="testnet/apothem" ;;
            89|"89") network="devnet" ;;
            *) network="network-$network_id" ;;
        esac
        
        # Get Docker container status
        local container_status="not running"
        local container=$(find_container 2>/dev/null || echo "")
        if [[ -n "$container" ]]; then
            local container_state=$(docker inspect -f '{{.State.Status}}' "$container" 2>/dev/null || echo "unknown")
            case "$container_state" in
                running) container_status="running" ;;
                exited) container_status="exited" ;;
                paused) container_status="paused" ;;
                restarting) container_status="restarting" ;;
                *) container_status="$container_state" ;;
            esac
        fi
        
        # Determine status
        local status="$(c GREEN)●$(c NC) Online"
        local status_json="online"
        
        if [[ $block_height -eq 0 ]]; then
            status="$(c RED)●$(c NC) Offline"
            status_json="offline"
        elif [[ "$sync_status" == "syncing" ]]; then
            status="$(c YELLOW)●$(c NC) Syncing"
            status_json="syncing"
        elif [[ $peers -lt 3 ]]; then
            status="$(c YELLOW)●$(c NC) Low Peers"
            status_json="low_peers"
        fi
        
        # Extract and detect client name
        local client="Unknown"
        local client_display="Unknown"
        
        if [[ "$client_version" == *"erigon"* ]]; then
            client="erigon"
            client_display="Erigon-XDC"
        elif [[ "$client_version" == *"XDC"* ]]; then
            if [[ "$client_version" == *"feature/xdpos"* ]] || [[ "$client_version" == *"pr5"* ]]; then
                client="geth-pr5"
                client_display="XDC Geth PR5"
            else
                client="stable"
                client_display="XDC Stable"
            fi
        else
            client=$(echo "$client_version" | cut -d'/' -f1)
            client_display="$client"
        fi
        
        if json_output ""; then
            cat << EOF
{
  "client": "$client",
  "clientVersion": "$client_version",
  "nodeName": "$node_name",
  "network": "$network",
  "networkId": "$network_id",
  "blockHeight": $block_height,
  "syncPercent": $sync_pct,
  "syncStatus": "$sync_status",
  "peers": $peers,
  "cpu": $cpu_usage,
  "ram": $ram_usage,
  "disk": $disk_usage,
  "containerStatus": "$container_status",
  "rpcUrl": "$rpc_url",
  "status": "$status_json",
  "timestamp": "$(date -Iseconds)"
}
EOF
            return 0
        fi
        
        # Print single client table
        echo ""
        echo -e "$(c BOLD)┌─────────────────────────────────────────────────────────────────────────────┐$(c NC)"
        echo -e "$(c BOLD)│$(c NC)                       $(c CYAN)XDC Node Status$(c NC)                                      $(c BOLD)│$(c NC)"
        echo -e "$(c BOLD)├──────────────┬───────────┬───────┬───────┬───────┬───────┬───────┬─────────┤$(c NC)"
        echo -e "$(c BOLD)│$(c NC) $(c WHITE)Client$(c NC)       $(c BOLD)│$(c NC) $(c WHITE)Block$(c NC)     $(c BOLD)│$(c NC) $(c WHITE)Peers$(c NC) $(c BOLD)│$(c NC) $(c WHITE)Sync%$(c NC) $(c BOLD)│$(c NC) $(c WHITE)CPU$(c NC)   $(c BOLD)│$(c NC) $(c WHITE)RAM$(c NC)   $(c BOLD)│$(c NC) $(c WHITE)Disk$(c NC)  $(c BOLD)│$(c NC) $(c WHITE)Status$(c NC)  $(c BOLD)│$(c NC)"
        echo -e "$(c BOLD)├──────────────┼───────────┼───────┼───────┼───────┼───────┼───────┼─────────┤$(c NC)"
        printf "$(c BOLD)│$(c NC) %-12s $(c BOLD)│$(c NC) %-9s $(c BOLD)│$(c NC) %-5s $(c BOLD)│$(c NC) %-5s $(c BOLD)│$(c NC) %-5s $(c BOLD)│$(c NC) %-5s $(c BOLD)│$(c NC) %-5s $(c BOLD)│$(c NC) %b $(c BOLD)│$(c NC)\n" \
            "${client_display:0:12}" \
            "$block_height" \
            "$peers" \
            "${sync_pct}%" \
            "${cpu_usage}%" \
            "${ram_usage}%" \
            "${disk_usage}%" \
            "$status"
        echo -e "$(c BOLD)└──────────────┴───────────┴───────┴───────┴───────┴───────┴───────┴─────────┘$(c NC)"
        echo ""
        echo -e "$(c BOLD)Node Information:$(c NC)"
        echo -e "  Client:    $(c CYAN)${client_display}$(c NC)"
        echo -e "  Version:   $(c CYAN)${client_version}$(c NC)"
        echo -e "  Node Name: $(c CYAN)${node_name:0:40}$(c NC)"
        echo -e "  Network:   $(c CYAN)${network} (ID: ${network_id})$(c NC)"
        echo -e "  Container: $(c CYAN)${container_status}$(c NC)"
        echo ""
        echo -e "$(c BOLD)RPC Endpoints:$(c NC)"
        echo -e "  HTTP:      $(c CYAN)${rpc_url}$(c NC)"
        echo -e "  WS:        $(c CYAN)ws://127.0.0.1:${WS_PORT:-8546}$(c NC)"
        echo -e "  IPC:       $(c CYAN)${XDC_DATA}/XDC.ipc$(c NC)"
        echo -e "  Dashboard: $(c CYAN)http://localhost:${DASHBOARD_PORT:-7070}$(c NC)"
        echo ""
        
        # Setup Completion Progress
        echo -e "$(c BOLD)Setup Completion:$(c NC)"
        
        local setup_checks=()
        local setup_total=0
        local setup_done=0
        
        # Check 1: Node installed (if we got here, it's installed)
        setup_total=$((setup_total + 1))
        if [[ "$container_status" != "not running" || -d "$XDC_DATA" ]]; then
            setup_done=$((setup_done + 1))
            setup_checks+=("$(c GREEN)[✓]$(c NC) Node installed")
        else
            setup_checks+=("$(c DIM)[✗] Node installed$(c NC)")
        fi
        
        # Check 2: Node running
        setup_total=$((setup_total + 1))
        if [[ "$container_status" == "running" || $block_height -gt 0 ]]; then
            setup_done=$((setup_done + 1))
            setup_checks+=("$(c GREEN)[✓]$(c NC) Node running")
        else
            setup_checks+=("$(c DIM)[✗] Node running$(c NC)")
        fi
        
        # Check 3: Node synced (>99%)
        setup_total=$((setup_total + 1))
        if [[ $sync_pct -ge 99 ]]; then
            setup_done=$((setup_done + 1))
            setup_checks+=("$(c GREEN)[✓]$(c NC) Node synced (${sync_pct}%)")
        else
            setup_checks+=("$(c YELLOW)[⋯]$(c NC) Node synced (${sync_pct}%)")
        fi
        
        # Check 4: Peers connected (>3)
        setup_total=$((setup_total + 1))
        if [[ $peers -gt 3 ]]; then
            setup_done=$((setup_done + 1))
            setup_checks+=("$(c GREEN)[✓]$(c NC) Peers connected ($peers)")
        else
            setup_checks+=("$(c YELLOW)[⋯]$(c NC) Peers connected ($peers/4+)")
        fi
        
        # Check 5: Firewall configured
        setup_total=$((setup_total + 1))
        if ufw status 2>/dev/null | grep -q "Status: active"; then
            setup_done=$((setup_done + 1))
            setup_checks+=("$(c GREEN)[✓]$(c NC) Firewall configured")
        else
            setup_checks+=("$(c DIM)[✗] Firewall configured$(c NC)")
        fi
        
        # Check 6: SkyNet registered
        setup_total=$((setup_total + 1))
        local skynet_conf="${PROJECT_DIR}/${NETWORK:-mainnet}/.xdc-node/skynet.conf"
        if [[ -f "$skynet_conf" ]] && grep -q "skynet_id" "$skynet_conf" 2>/dev/null; then
            setup_done=$((setup_done + 1))
            setup_checks+=("$(c GREEN)[✓]$(c NC) SkyNet registered")
        else
            setup_checks+=("$(c DIM)[✗] SkyNet registered$(c NC)")
        fi
        
        # Check 7: Monitoring enabled
        setup_total=$((setup_total + 1))
        if docker ps 2>/dev/null | grep -qE "prometheus|grafana" || systemctl is-active prometheus &>/dev/null; then
            setup_done=$((setup_done + 1))
            setup_checks+=("$(c GREEN)[✓]$(c NC) Monitoring enabled")
        else
            setup_checks+=("$(c DIM)[✗] Monitoring enabled$(c NC)")
        fi
        
        # Calculate completion percentage
        local completion_pct=$((setup_done * 100 / setup_total))
        
        # Draw progress bar
        local bar_width=20
        local filled=$((setup_done * bar_width / setup_total))
        local empty=$((bar_width - filled))
        
        echo -n "  "
        printf "%${filled}s" '' | tr ' ' '█'
        printf "%${empty}s" '' | tr ' ' '░'
        echo -e " $setup_done/$setup_total ($(c CYAN)${completion_pct}%%$(c NC))"
        echo ""
        
        # Show checks in two columns
        local i=0
        for check in "${setup_checks[@]}"; do
            if [[ $((i % 2)) -eq 0 ]]; then
                echo -n "  $check"
                # Pad to align second column
                printf "%*s" $((40 - ${#check})) ""
            else
                echo "  $check"
            fi
            i=$((i + 1))
        done
        [[ $((i % 2)) -ne 0 ]] && echo ""  # New line if odd number
        
        echo ""
        echo -e "$(c DIM)Updated: $(date '+%Y-%m-%d %H:%M:%S')$(c NC)"
    }
    
    if [[ "$watch" == "true" ]]; then
        while true; do
            clear
            print_banner
            show_status
            echo ""
            echo -e "$(c DIM)Press Ctrl+C to exit. Refreshing every ${interval}s...$(c NC)"
            sleep "$interval"
        done
    else
        show_status
    fi
}

#==============================================================================
# Command: health
#==============================================================================
cmd_health() {
    local full=false
    local notify=false
    local security_only=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --full) full=true; shift ;;
            --notify) notify=true; shift ;;
            --security-only) security_only=true; shift ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node health$(c NC) — Run health check

$(c BOLD)USAGE:$(c NC)
    xdc-node health [options]

$(c BOLD)OPTIONS:$(c NC)
    --full           Run comprehensive health check
    --notify         Send notification with results
    --security-only  Only run security-related checks
    --json           Output in JSON format
    --help           Show this help

$(c BOLD)CHECKS:$(c NC)
    - Block height and sync status
    - Peer connectivity
    - RPC responsiveness
    - Disk/CPU/RAM usage
    - Process health
    - Network connectivity

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    local script="${SCRIPTS_DIR}/node-health-check.sh"
    
    if [[ ! -f "$script" ]]; then
        die "Health check script not found at $script"
    fi
    
    local args=()
    [[ "$full" == "true" ]] && args+=(--full)
    [[ "$notify" == "true" ]] && args+=(--notify)
    [[ "$security_only" == "true" ]] && args+=(--security-only)
    
    if [[ "$QUIET" != "true" ]]; then
        print_banner
        echo -e "$(c BOLD)Running Health Check$(c NC)"
        echo ""
    fi
    
    local pass_count=0
    local fail_count=0
    local warn_count=0
    
    # Run the health check script
    start_spinner "Running health checks"
    
    local output
    if output=$(bash "$script" ${args[@]+"${args[@]}"} 2>&1); then
        stop_spinner true "Health check completed"
    else
        stop_spinner false "Health check completed with issues"
    fi
    
    if [[ "$OUTPUT_JSON" == "true" ]]; then
        # Extract JSON from script output or generate summary
        echo "$output" | grep -E '^\{' || cat << EOF
{
  "status": "completed",
  "timestamp": "$(date -Iseconds)",
  "checks": {
    "passed": $pass_count,
    "failed": $fail_count,
    "warnings": $warn_count
  }
}
EOF
        return 0
    fi
    
    echo "$output"
    
    # Summary
    echo ""
    echo -e "$(c BOLD)━━━ Summary ━━━$(c NC)"
    echo "$output" | grep -c "✓" | xargs -I {} echo -e "$(c GREEN)✓$(c NC) Passed: {}"
    echo "$output" | grep -c "✗" | xargs -I {} echo -e "$(c RED)✗$(c NC) Failed: {}"
    echo "$output" | grep -c "⚠" | xargs -I {} echo -e "$(c YELLOW)⚠$(c NC) Warnings: {}"
}

#==============================================================================
# Command: security
#==============================================================================
cmd_security() {
    local audit_only=false
    local fix=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --audit-only) audit_only=true; shift ;;
            --fix) fix=true; shift ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc security$(c NC) — Run security audit

$(c BOLD)USAGE:$(c NC)
    xdc security [options]

$(c BOLD)OPTIONS:$(c NC)
    --audit-only  Check only, don't apply changes (default)
    --fix         Apply recommended security fixes (requires confirmation)
    --json        Output in JSON format
    --help        Show this help

$(c BOLD)DESCRIPTION:$(c NC)
    By default, this command only audits your security configuration
    and provides recommendations. No files are modified unless you
    explicitly use --fix.

$(c BOLD)CHECKS:$(c NC)
    - SSH configuration
    - Firewall rules
    - File permissions
    - User accounts
    - Network exposure (RPC/WS)
    - Fail2ban status
    - Automatic updates

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    require_root
    
    if [[ "$QUIET" != "true" ]]; then
        print_banner
        echo -e "$(c BOLD)Security Audit$(c NC) $(c DIM)(read-only, no changes will be made)$(c NC)"
        echo ""
    fi
    
    # Security checks (read-only)
    declare -A checks=(
        ["SSH Key-Only Auth"]="grep -q 'PasswordAuthentication no' /etc/ssh/sshd_config 2>/dev/null"
        ["SSH Non-Standard Port"]="! grep -qE '^Port 22$' /etc/ssh/sshd_config 2>/dev/null"
        ["Firewall Enabled"]="ufw status | grep -q 'Status: active' 2>/dev/null"
        ["Fail2ban Active"]="systemctl is-active fail2ban &>/dev/null"
        ["Root Login Restricted"]="grep -qE 'PermitRootLogin (no|prohibit-password)' /etc/ssh/sshd_config 2>/dev/null"
        ["RPC Not Exposed"]="! netstat -tlnp 2>/dev/null | grep ':8545.*0.0.0.0' | grep -v '127.0.0.1'"
        ["WebSocket Not Exposed"]="! netstat -tlnp 2>/dev/null | grep ':8546.*0.0.0.0' | grep -v '127.0.0.1'"
        ["Automatic Updates"]="systemctl is-enabled unattended-upgrades &>/dev/null"
    )
    
    declare -A advice=(
        ["SSH Key-Only Auth"]="Edit /etc/ssh/sshd_config: Set 'PasswordAuthentication no', then run 'systemctl restart sshd'"
        ["SSH Non-Standard Port"]="Edit /etc/ssh/sshd_config: Set 'Port <non-22-port>', then run 'systemctl restart sshd'"
        ["Firewall Enabled"]="Enable firewall: 'ufw allow 30303/tcp && ufw allow 30303/udp && ufw enable'"
        ["Fail2ban Active"]="Install fail2ban: 'apt install fail2ban -y && systemctl enable fail2ban && systemctl start fail2ban'"
        ["Root Login Restricted"]="Edit /etc/ssh/sshd_config: Set 'PermitRootLogin no', then run 'systemctl restart sshd'"
        ["RPC Not Exposed"]="Check docker-compose.yml: RPC should bind to 127.0.0.1:8545 not 0.0.0.0:8545"
        ["WebSocket Not Exposed"]="Check docker-compose.yml: WS should bind to 127.0.0.1:8546 not 0.0.0.0:8546"
        ["Automatic Updates"]="Enable unattended-upgrades: 'apt install unattended-upgrades -y && dpkg-reconfigure -plow unattended-upgrades'"
    )
    
    local total=0
    local passed=0
    local failed_checks=()
    
    for check in "${!checks[@]}"; do
        total=$((total + 1))
        local status="fail"
        local icon="$(c RED)✗$(c NC)"
        
        if eval "${checks[$check]}" &>/dev/null; then
            passed=$((passed + 1))
            status="pass"
            icon="$(c GREEN)✓$(c NC)"
        else
            failed_checks+=("$check")
        fi
        
        if [[ "$OUTPUT_JSON" != "true" ]]; then
            echo -e "$icon $check"
        fi
    done
    
    local score=$((passed * 100 / total))
    local score_color
    if [[ $score -ge 80 ]]; then
        score_color="$(c GREEN)"
    elif [[ $score -ge 60 ]]; then
        score_color="$(c YELLOW)"
    else
        score_color="$(c RED)"
    fi
    
    if [[ "$OUTPUT_JSON" == "true" ]]; then
        cat << EOF
{
  "score": $score,
  "passed": $passed,
  "total": $total,
  "timestamp": "$(date -Iseconds)"
}
EOF
        return 0
    fi
    
    echo ""
    echo -e "$(c BOLD)━━━ Security Score ━━━$(c NC)"
    echo -e "${score_color}${score}/100$(c NC) ($passed/$total checks passed)"
    
    # Show recommendations for failed checks
    if [[ ${#failed_checks[@]} -gt 0 ]]; then
        echo ""
        echo -e "$(c BOLD)━━━ Recommendations ━━━$(c NC)"
        for check in "${failed_checks[@]}"; do
            echo ""
            echo -e "$(c YELLOW)⚠$(c NC) $(c BOLD)$check$(c NC)"
            echo -e "  $(c DIM)${advice[$check]}$(c NC)"
        done
        echo ""
        echo -e "$(c CYAN)ℹ$(c NC) For more help: $(c BOLD)xdc -h$(c NC) or visit https://github.com/XinFinOrg/XDC-Node-Setup"
    fi
    
    # Only offer --fix if score is low and user didn't already use it
    if [[ "$fix" == "true" ]]; then
        local script="${SCRIPTS_DIR}/security-harden.sh"
        if [[ -f "$script" ]]; then
            echo ""
            warn "You are about to apply automated security fixes."
            echo ""
            read -p "$(echo -e "$(c BOLD)Continue? [y/N]$(c NC) ")" -n 1 -r
            echo ""
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                info "Applying security fixes..."
                bash "$script"
            else
                info "Security fixes cancelled. No changes were made."
            fi
        else
            warn "Security hardening script not found at $script"
        fi
    elif [[ $score -lt 80 ]]; then
        echo ""
        info "To apply automated fixes: $(c BOLD)xdc security --fix$(c NC)"
        info "Or apply recommendations manually using the commands above."
    fi
}

#==============================================================================
# Command: update
#==============================================================================
cmd_update() {
    local check_only=false
    local auto_enable=false
    local auto_disable=false
    local force=false
    local target_version=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --check)
                check_only=true
                shift
                ;;
            --auto)
                auto_enable=true
                shift
                ;;
            --no-auto)
                auto_disable=true
                shift
                ;;
            --force)
                force=true
                shift
                ;;
            --version)
                target_version="$2"
                shift 2
                ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc update$(c NC) — Update xdc-node-setup and node components

$(c BOLD)USAGE:$(c NC)
    xdc update [options]

$(c BOLD)DESCRIPTION:$(c NC)
    Checks for and applies updates to xdc-node-setup from GitHub releases.
    Can update the CLI scripts, Docker images, and node configuration.

$(c BOLD)OPTIONS:$(c NC)
    --check          Check for available updates without applying
    --auto           Enable automatic updates via cron
    --no-auto        Disable automatic updates
    --force          Apply update without confirmation
    --version V      Update to specific version (default: latest)
    --help           Show this help

$(c BOLD)AUTO-UPDATE:$(c NC)
    When enabled, automatic updates run daily at 3:00 AM.
    Logs are saved to /var/log/xdc-auto-update.log
    Backups are created before each update.

$(c BOLD)EXAMPLES:$(c NC)
    xdc update                    # Check and apply available updates
    xdc update --check            # Only check for updates
    xdc update --auto             # Enable auto-updates
    xdc update --force            # Force update without prompt
    xdc update --version v1.1.0   # Update to specific version

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done

    # Handle auto-update enable/disable
    if [[ "$auto_enable" == true ]]; then
        local auto_update_script="${SCRIPTS_DIR}/auto-update.sh"
        if [[ -f "$auto_update_script" ]]; then
            bash "$auto_update_script" setup-cron
        else
            error "Auto-update script not found at $auto_update_script"
            return 1
        fi
        return 0
    fi
    
    if [[ "$auto_disable" == true ]]; then
        local auto_update_script="${SCRIPTS_DIR}/auto-update.sh"
        if [[ -f "$auto_update_script" ]]; then
            bash "$auto_update_script" remove-cron
        else
            error "Auto-update script not found at $auto_update_script"
            return 1
        fi
        return 0
    fi

    # Run auto-update check/apply
    local auto_update_script="${SCRIPTS_DIR}/auto-update.sh"
    if [[ ! -f "$auto_update_script" ]]; then
        # Fallback to legacy Docker-based update
        cmd_update_legacy
        return $?
    fi
    
    local args=()
    [[ "$check_only" == true ]] && args+=("--check")
    [[ "$force" == true ]] && args+=("--force")
    [[ -n "$target_version" ]] && args+=("--version" "$target_version")
    
    bash "$auto_update_script" update ${args[@]+"${args[@]}"}
}

# Legacy Docker-based update (fallback)
cmd_update_legacy() {
    # Determine directories and compose file
    local STATE_DIR="${XDC_STATE_DIR:-${PROJECT_DIR}/${XDC_NETWORK}/.xdc-node}"
    local COMPOSE_FILE="${INSTALL_DIR}/docker/docker-compose.yml"
    
    # Fallback to find compose file
    if [[ ! -f "$COMPOSE_FILE" ]]; then
        for cf in "${PROJECT_DIR}/docker/docker-compose.yml" "${PROJECT_DIR}/docker-compose.yml" "./docker-compose.yml"; do
            [[ -f "$cf" ]] && COMPOSE_FILE="$cf" && break
        done
    fi
    
    if [[ ! -f "$COMPOSE_FILE" ]]; then
        die "Docker compose file not found"
    fi

    # 1. Check current image version
    local current=$(docker inspect --format '{{.Config.Image}}' xdc-node 2>/dev/null || echo "unknown")
    log "Current image: $current"

    # 2. Backup current config
    local backup_dir="$STATE_DIR/backups/$(date +%Y%m%d_%H%M%S)"
    mkdir -p "$backup_dir"
    cp -r "$STATE_DIR"/*.conf "$STATE_DIR"/*.env "$backup_dir/" 2>/dev/null || true
    log "Config backed up to $backup_dir"

    # 3. Pull latest image
    log "Pulling latest image..."
    if ! docker compose -f "$COMPOSE_FILE" pull xdc-node 2>/dev/null; then
        warn "Failed to pull image with 'docker compose', trying 'docker-compose'..."
        docker-compose -f "$COMPOSE_FILE" pull xdc-node || die "Failed to pull latest image"
    fi

    # 4. Restart with new image
    log "Restarting with new image..."
    if ! docker compose -f "$COMPOSE_FILE" up -d xdc-node 2>/dev/null; then
        docker-compose -f "$COMPOSE_FILE" up -d xdc-node || die "Failed to restart node"
    fi

    # 5. Wait and verify
    log "Waiting for node to start..."
    sleep 10
    local new=$(docker inspect --format '{{.Config.Image}}' xdc-node 2>/dev/null || echo "unknown")
    log "New image: $new"

    # 6. Check node starts syncing
    local RPC_PORT=${RPC_PORT:-8545}
    local block=$(curl -s -X POST http://127.0.0.1:${RPC_PORT} -H "Content-Type: application/json" -d '{"jsonrpc":"2.0","method":"eth_blockNumber","params":[],"id":1}' 2>/dev/null | grep -o '"result":"[^"]*"' | cut -d'"' -f4)
    if [ -n "$block" ]; then
        local block_dec=$((16#${block#0x}))
        log "Node running, block: $block_dec"
    else
        warn "Node may not be responding yet, check with: xdc status"
    fi
}

#==============================================================================
# Command: backup
#==============================================================================
cmd_backup() {
    local output=""
    local compress="gzip"
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --output)
                output="$2"
                shift 2
                ;;
            --compress)
                compress="$2"
                shift 2
                ;;
            --list)
                local backup_dir="${XDC_BACKUP:-/backup/xdc-node}"
                info "Available backups:"
                ls -lh "$backup_dir" 2>/dev/null || echo "  No backups found"
                return 0
                ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc backup$(c NC) — Backup chaindata and config to archive

$(c BOLD)USAGE:$(c NC)
    xdc backup [options]

$(c BOLD)OPTIONS:$(c NC)
    --output PATH      Output file path (default: auto-generated in DATA_DIR/backups/)
    --compress TYPE    Compression type: gzip (default) or zstd
    --list             Show available backups
    --help             Show this help

$(c BOLD)DESCRIPTION:$(c NC)
    Creates a backup archive of the node chaindata and configuration.
    Optionally stops the node for a consistent backup (recommended).

$(c BOLD)EXAMPLES:$(c NC)
    xdc backup                              # Create backup with defaults
    xdc backup --output /tmp/my-backup.tar.gz
    xdc backup --compress zstd

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done

    # Determine directories
    local DATA_DIR="${XDC_DATA:-${PROJECT_DIR}/${XDC_NETWORK}/xdcchain}"
    local STATE_DIR="${XDC_STATE_DIR:-${PROJECT_DIR}/${XDC_NETWORK}/.xdc-node}"
    local COMPOSE_FILE="${INSTALL_DIR}/docker/docker-compose.yml"
    
    # Fallback to find compose file
    if [[ ! -f "$COMPOSE_FILE" ]]; then
        for cf in "${PROJECT_DIR}/docker/docker-compose.yml" "${PROJECT_DIR}/docker-compose.yml" "./docker-compose.yml"; do
            [[ -f "$cf" ]] && COMPOSE_FILE="$cf" && break
        done
    fi

    # Default output path
    if [[ -z "$output" ]]; then
        output="$DATA_DIR/backups/xdc-backup-$(date +%Y%m%d_%H%M%S).tar.gz"
    fi
    
    mkdir -p "$(dirname "$output")"

    # Estimate size
    local datasize=$(du -sh "$DATA_DIR" 2>/dev/null | cut -f1 || echo "unknown")
    log "Chain data size: ${datasize:-unknown}"
    log "Output: $output"

    # Stop node for consistent backup
    local stop_node=""
    if [[ "$QUIET" != "true" ]]; then
        read -rp "Stop node for consistent backup? (recommended) [y/N]: " stop_node
    fi
    
    if [[ "$stop_node" =~ ^[Yy]$ ]]; then
        log "Stopping node..."
        if ! docker compose -f "$COMPOSE_FILE" stop xdc-node 2>/dev/null; then
            docker-compose -f "$COMPOSE_FILE" stop xdc-node 2>/dev/null || true
        fi
    fi

    # Backup chaindata + config
    log "Backing up chaindata and config..."
    local tar_opts="czf"
    if [[ "$compress" == "zstd" ]]; then
        tar_opts="--zstd -cf"
    fi
    
    tar $tar_opts "$output" \
        -C "$DATA_DIR" . \
        -C "$STATE_DIR" . \
        2>/dev/null || warn "Some files may not have been included"

    local size=$(du -sh "$output" 2>/dev/null | cut -f1 || echo "unknown")
    log "Backup complete: $output ($size)"

    # Restart if stopped
    if [[ "$stop_node" =~ ^[Yy]$ ]]; then
        log "Restarting node..."
        if ! docker compose -f "$COMPOSE_FILE" up -d xdc-node 2>/dev/null; then
            docker-compose -f "$COMPOSE_FILE" up -d xdc-node 2>/dev/null || true
        fi
        log "Node restarted"
    fi
}

#==============================================================================
# Command: restore
#==============================================================================
cmd_restore() {
    local backup_file=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node restore$(c NC) — Restore from backup

$(c BOLD)USAGE:$(c NC)
    xdc-node restore <backup-file>

$(c BOLD)OPTIONS:$(c NC)
    --help    Show this help

$(c BOLD)DESCRIPTION:$(c NC)
    Restores node data from a backup archive.
    Verifies integrity before restoration.

$(c BOLD)EXAMPLE:$(c NC)
    xdc-node restore /backup/xdc-node/daily/xdc-backup-2024-01-15.tar.gz

EOF
                return 0
                ;;
            -*) shift ;;
            *) backup_file="$1"; shift ;;
        esac
    done
    
    require_root
    
    if [[ -z "$backup_file" ]]; then
        die "Please specify a backup file. Run 'xdc-node backup --list' to see available backups."
    fi
    
    if [[ ! -f "$backup_file" ]]; then
        die "Backup file not found: $backup_file"
    fi
    
    if [[ "$QUIET" != "true" ]]; then
        print_banner
        echo -e "$(c BOLD)Restore from Backup$(c NC)"
        echo ""
    fi
    
    info "Backup file: $backup_file"
    
    # Verify integrity
    start_spinner "Verifying backup integrity"
    if tar -tzf "$backup_file" &>/dev/null; then
        stop_spinner true "Backup integrity verified"
    else
        stop_spinner false "Backup integrity check failed"
        die "Backup file is corrupted or invalid"
    fi
    
    # Confirmation
    echo ""
    warn "This will overwrite current node data!"
    read -p "Are you sure you want to continue? [y/N] " -n 1 -r
    echo ""
    
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        info "Restore cancelled"
        return 0
    fi
    
    # Stop node
    info "Stopping node..."
    cmd_stop
    
    # Restore
    start_spinner "Restoring data"
    
    local restore_dir="${XDC_DATA}"
    mkdir -p "$restore_dir"
    tar -xzf "$backup_file" -C "$restore_dir"
    
    stop_spinner true "Data restored"
    
    # Start node
    info "Starting node..."
    cmd_start
    
    log "Restore completed successfully"
}

#==============================================================================
# Command: reset
#==============================================================================
cmd_reset() {
    local client=""
    local confirm=false
    local keep_config=true
    local datadir=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --client)
                client="$2"
                shift 2
                ;;
            --confirm)
                confirm=true
                shift
                ;;
            --full)
                keep_config=false
                shift
                ;;
            --data-dir)
                datadir="$2"
                shift 2
                ;;
            --help|-h)
                cat << 'EOF'
$(c BOLD)xdc reset$(c NC) — Reset node data and resync

$(c BOLD)USAGE:$(c NC)
    xdc reset [options]

$(c BOLD)OPTIONS:$(c NC)
    --client NAME    Target client (geth, erigon, or auto-detect)
    --confirm        Skip confirmation prompt (use with caution!)
    --full           Remove config as well (complete reset)
    --data-dir PATH  Custom data directory to reset
    --help           Show this help

$(c BOLD)DESCRIPTION:$(c NC)
    Resets the node by removing chaindata and restarting sync from genesis.
    This is useful for recovering from:
    - Bad blocks / state root mismatches
    - Corrupted chaindata
    - Stalled sync that won't progress

    Configuration is preserved by default. Use --full to remove everything.

$(c BOLD)SAFETY:$(c NC)
    Always backup important data before resetting:
    - Keystore files (if running validator)
    - Custom configuration
    - Any data you want to preserve

$(c BOLD)EXAMPLES:$(c NC)
    xdc reset --confirm                    # Reset with confirmation
    xdc reset --client erigon --confirm    # Reset Erigon node
    xdc reset --full --confirm             # Complete reset including config

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done

    if [[ "$QUIET" != "true" ]]; then
        print_banner
        echo -e "$(c BOLD)Reset Node$(c NC)"
        echo ""
    fi

    # Detect client if not specified
    if [[ -z "$client" ]]; then
        if docker ps --format '{{.Names}}' 2>/dev/null | grep -q "erigon"; then
            client="erigon"
        elif docker ps --format '{{.Names}}' 2>/dev/null | grep -q "xdc-node"; then
            client="geth"
        else
            # Check data directories
            if [[ -d "${PROJECT_DIR}/mainnet/erigon-datadir" ]]; then
                client="erigon"
            else
                client="geth"
            fi
        fi
        info "Auto-detected client: $client"
    fi

    # Determine data directory
    if [[ -z "$datadir" ]]; then
        case "$client" in
            erigon)
                datadir="${PROJECT_DIR}/${XDC_NETWORK}/erigon-datadir"
                ;;
            geth|*)
                datadir="${PROJECT_DIR}/${XDC_NETWORK}/xdcchain"
                ;;
        esac
    fi

    # Check if data directory exists
    if [[ ! -d "$datadir" ]]; then
        warn "Data directory not found: $datadir"
        info "Node may already be reset or using different path"
        return 1
    fi

    # Calculate size for user information
    local data_size
    data_size=$(du -sh "$datadir" 2>/dev/null | cut -f1 || echo "unknown")

    # Show warning
    echo ""
    warn "This will DELETE all blockchain data!"
    echo ""
    echo -e "  Client:      $(c CYAN)$client$(c NC)"
    echo -e "  Data dir:    $(c CYAN)$datadir$(c NC)"
    echo -e "  Size:        $(c CYAN)$data_size$(c NC)"
    echo -e "  Keep config: $(c CYAN)$keep_config$(c NC)"
    echo ""
    echo -e "  $(c YELLOW)This action cannot be undone!$(c NC)"
    echo ""

    # Confirmation
    if [[ "$confirm" != "true" ]]; then
        read -p "$(echo -e "$(c BOLD)Type 'reset' to confirm: $(c NC)")" -r
        echo ""
        if [[ $REPLY != "reset" ]]; then
            info "Reset cancelled"
            return 0
        fi
    fi

    # Stop node
    info "Stopping $client node..."
    if [[ "$client" == "erigon" ]]; then
        docker stop xdc-node-erigon 2>/dev/null || true
        docker rm xdc-node-erigon 2>/dev/null || true
    else
        cmd_stop
    fi

    # Remove data
    start_spinner "Removing chaindata ($data_size)"

    if [[ "$keep_config" == "true" ]]; then
        # Remove only chaindata, keep config
        case "$client" in
            erigon)
                rm -rf "${datadir:?}"/* 2>/dev/null || true
                ;;
            geth|*)
                rm -rf "${datadir:?}/XDC" 2>/dev/null || true
                rm -rf "${datadir:?}/nodes" 2>/dev/null || true
                rm -rf "${datadir:?}/ethash" 2>/dev/null || true
                ;;
        esac
    else
        # Full reset - remove everything
        rm -rf "${datadir:?}" 2>/dev/null || true
    fi

    stop_spinner true "Chaindata removed"

    # Start node
    info "Starting $client node..."
    if [[ "$client" == "erigon" ]]; then
        xdc start --client erigon
    else
        cmd_start
    fi

    log "Reset completed. Node will now resync from genesis or snapshot."
    info "Monitor progress with: $(c CYAN)xdc status --watch$(c NC)"
}

#==============================================================================
# Command: logs
#==============================================================================
cmd_logs() {
    local lines=50
    local follow=false
    local client=""
    local rotate=false
    local clean=false
    local component=""
    local since=""
    local search=""
    local format="text"
    local level=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --lines|-n) lines="$2"; shift 2 ;;
            --follow|-f) follow=true; shift ;;
            --client) client="$2"; shift 2 ;;
            --rotate) rotate=true; shift ;;
            --clean) clean=true; shift ;;
            --component) component="$2"; shift 2 ;;
            --since) since="$2"; shift 2 ;;
            --search|-s) search="$2"; shift 2 ;;
            --format) format="$2"; shift 2 ;;
            --level) level="$2"; shift 2 ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc logs$(c NC) — Tail node logs

$(c BOLD)USAGE:$(c NC)
    xdc logs [options]

$(c BOLD)OPTIONS:$(c NC)
    --lines, -n N       Number of lines to show (default: 50)
    --follow, -f        Follow log output (like tail -f)
    --client NAME       Specific client logs (geth, erigon)
    --component NAME    Show logs for specific component:
                        heartbeat|lfg|dashboard|node
    --since TIME        Show logs since time (e.g., '1h', '30m', '2024-01-01')
    --search, -s QUERY  Search logs via Loki (LogQL query)
    --level LEVEL       Filter by log level (ERROR, WARN, INFO, DEBUG)
    --format FORMAT     Output format: text (default), json
    --rotate            Manually trigger log rotation (move, compress, cleanup)
    --clean             Remove all old logs from oldlogs/ directory
    --help              Show this help

$(c BOLD)LOKI SEARCH EXAMPLES:$(c NC)
    xdc logs --search "error"           # Search for 'error' in all logs
    xdc logs --search "sync" --since 1h # Search 'sync' in last hour
    xdc logs --level ERROR              # Show only errors
    xdc logs --search "block" --format json  # Output as JSON

$(c BOLD)EXAMPLES:$(c NC)
    xdc logs -f -n 100              # Follow node logs with 100 lines
    xdc logs --component heartbeat  # Show heartbeat logs
    xdc logs --component lfg -f     # Follow LFG logs
    xdc logs --since 1h             # Show logs from last hour
    xdc logs --rotate               # Manually rotate logs
    xdc logs --clean                # Remove all old logs

$(c BOLD)LOG ROTATION:$(c NC)
    Logs are automatically rotated daily via cron (2:00 AM).
    - Logs older than 24 hours are moved to oldlogs/ and compressed
    - Logs older than 7 days are automatically deleted (configurable via LOG_RETENTION_DAYS)
    - Docker container logs use json-file driver (max-size: 50m, max-file: 5)

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    # Handle log rotation command
    if [[ "$rotate" == "true" ]]; then
        info "Manually triggering log rotation..."
        local rotate_script="${SCRIPTS_DIR}/log-rotate.sh"
        
        if [[ ! -f "$rotate_script" ]]; then
            die "Log rotation script not found at $rotate_script"
        fi
        
        if [[ ! -x "$rotate_script" ]]; then
            chmod +x "$rotate_script" 2>/dev/null || true
        fi
        
        if bash "$rotate_script"; then
            log "Log rotation completed successfully"
        else
            die "Log rotation failed. Check ${XDC_NETWORK:-mainnet}/.xdc-node/log-rotation.log for details"
        fi
        return 0
    fi
    
    # Handle clean old logs command
    if [[ "$clean" == "true" ]]; then
        local oldlogs_dir="${PROJECT_DIR}/${XDC_NETWORK}/xdcchain/oldlogs"
        local component_oldlogs_dir="${PROJECT_DIR}/${XDC_NETWORK}/.xdc-node/logs/oldlogs"
        
        local count=0
        if [[ -d "$oldlogs_dir" ]]; then
            count=$(find "$oldlogs_dir" -type f 2>/dev/null | wc -l)
        fi
        if [[ -d "$component_oldlogs_dir" ]]; then
            count=$((count + $(find "$component_oldlogs_dir" -type f 2>/dev/null | wc -l)))
        fi
        
        if [[ $count -eq 0 ]]; then
            info "No old logs found to clean"
            return 0
        fi
        
        echo ""
        warn "This will permanently delete $count old log file(s)"
        read -p "$(echo -e "$(c BOLD)Are you sure? [y/N]$(c NC) ")" -n 1 -r
        echo ""
        
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            info "Removing old logs..."
            local removed=0
            if [[ -d "$oldlogs_dir" ]]; then
                rm -rf "${oldlogs_dir:?}"/* 2>/dev/null && removed=1
            fi
            if [[ -d "$component_oldlogs_dir" ]]; then
                rm -rf "${component_oldlogs_dir:?}"/* 2>/dev/null && removed=1
            fi
            if [[ $removed -eq 1 ]]; then
                log "Successfully removed $count old log file(s)"
            else
                die "Failed to remove old logs"
            fi
        else
            info "Clean cancelled"
        fi
        return 0
    fi
    
    # Handle Loki search (--search option)
    if [[ -n "$search" ]] || [[ -n "$level" ]]; then
        local loki_url="${LOKI_URL:-http://localhost:3100}"
        
        # Check if Loki is running
        if ! curl -s "${loki_url}/ready" >/dev/null 2>&1; then
            warn "Loki is not running at $loki_url"
            info "Start the logging stack with: xdc start --logging"
            info "Or falling back to grep search..."
            
            # Fallback to grep search on local logs
            local log_file="${PROJECT_DIR}/${XDC_NETWORK}/xdcchain/XDC.log"
            if [[ -f "$log_file" ]]; then
                if [[ -n "$level" ]]; then
                    grep -i "\[$level\]" "$log_file" | tail -n "$lines"
                elif [[ -n "$search" ]]; then
                    grep -i "$search" "$log_file" | tail -n "$lines"
                fi
            else
                die "No log file found and Loki not available"
            fi
            return 0
        fi
        
        info "Searching logs via Loki..."
        
        # Build LogQL query
        local query='{job="xdc-node"}'
        if [[ -n "$level" ]]; then
            query="{job=\"xdc-node\", level=\"$level\"}"
        fi
        if [[ -n "$search" ]]; then
            query="${query} |= \"$search\""
        fi
        
        # Calculate time range
        local end_time=$(date +%s)000000000
        local start_time=""
        if [[ -n "$since" ]]; then
            if [[ "$since" =~ ^([0-9]+)([hmd])$ ]]; then
                local amount="${BASH_REMATCH[1]}"
                local unit="${BASH_REMATCH[2]}"
                case "$unit" in
                    h) start_time=$(( ($(date +%s) - amount * 3600) ))000000000 ;;
                    m) start_time=$(( ($(date +%s) - amount * 60) ))000000000 ;;
                    d) start_time=$(( ($(date +%s) - amount * 86400) ))000000000 ;;
                esac
            else
                # Default to last hour
                start_time=$(( ($(date +%s) - 3600) ))000000000
            fi
        else
            # Default to last hour
            start_time=$(( ($(date +%s) - 3600) ))000000000
        fi
        
        # Query Loki
        local response
        response=$(curl -s -G "${loki_url}/loki/api/v1/query_range" \
            --data-urlencode "query=${query}" \
            --data-urlencode "start=${start_time}" \
            --data-urlencode "end=${end_time}" \
            --data-urlencode "limit=${lines}" \
            --data-urlencode "direction=backward" 2>/dev/null)
        
        if [[ -z "$response" ]]; then
            die "Failed to query Loki"
        fi
        
        # Output results
        if [[ "$format" == "json" ]]; then
            echo "$response" | jq '.' 2>/dev/null || echo "$response"
        else
            # Parse and display log lines
            echo "$response" | jq -r '.data.result[].values[][1]' 2>/dev/null | \
                while read -r line; do
                    # Color-code by level
                    if [[ "$line" =~ \[ERROR\] ]] || [[ "$line" =~ \"level\":\"error\" ]]; then
                        echo -e "$(c RED)${line}$(c NC)"
                    elif [[ "$line" =~ \[WARN\] ]] || [[ "$line" =~ \"level\":\"warn\" ]]; then
                        echo -e "$(c YELLOW)${line}$(c NC)"
                    elif [[ "$line" =~ \[INFO\] ]] || [[ "$line" =~ \"level\":\"info\" ]]; then
                        echo -e "$(c GREEN)${line}$(c NC)"
                    else
                        echo "$line"
                    fi
                done
        fi
        
        return 0
    fi
    
    # Handle component logs
    if [[ -n "$component" ]]; then
        local component_log="${PROJECT_DIR}/${XDC_NETWORK}/.xdc-node/logs/${component}.log"
        
        # Validate component name
        case "$component" in
            heartbeat|lfg|dashboard|node)
                ;;
            *)
                die "Invalid component: $component. Valid components: heartbeat, lfg, dashboard, node"
                ;;
        esac
        
        # For node component, show regular node logs
        if [[ "$component" == "node" ]]; then
            # Fall through to regular node log handling
            :
        else
            # Show component-specific logs
            if [[ ! -f "$component_log" ]]; then
                die "Component log not found: $component_log"
            fi
            
            # Handle --since filtering
            if [[ -n "$since" ]]; then
                # Convert since to date filter
                local since_date=""
                if [[ "$since" =~ ^[0-9]+[hHmMdD]$ ]]; then
                    # Relative time like 1h, 30m
                    local amount=${since%[hHmMdD]}
                    local unit=${since: -1}
                    case "$unit" in
                        h|H) since_date=$(date -d "${amount} hours ago" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date -v-${amount}H '+%Y-%m-%d %H:%M:%S') ;;
                        m|M) since_date=$(date -d "${amount} minutes ago" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date -v-${amount}M '+%Y-%m-%d %H:%M:%S') ;;
                        d|D) since_date=$(date -d "${amount} days ago" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date -v-${amount}d '+%Y-%m-%d %H:%M:%S') ;;
                    esac
                elif [[ "$since" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2} ]]; then
                    # Absolute date
                    since_date="$since"
                fi
                
                if [[ -n "$since_date" ]]; then
                    # Filter by date (assuming ISO format timestamps in logs)
                    if [[ "$follow" == "true" ]]; then
                        tail -n "$lines" -f "$component_log" | while read line; do
                            if [[ "$line" > "$since_date" ]] || [[ "$line" =~ ^\[?$since_date ]]; then
                                echo "$line"
                            fi
                        done
                    else
                        cat "$component_log" | while read line; do
                            if [[ "$line" > "$since_date" ]] || [[ "$line" =~ ^\[?$since_date ]]; then
                                echo "$line"
                            fi
                        done | tail -n "$lines"
                    fi
                    return 0
                fi
            fi
            
            if [[ "$follow" == "true" ]]; then
                tail -n "$lines" -f "$component_log"
            else
                tail -n "$lines" "$component_log"
            fi
            return 0
        fi
    fi
    
    # Handle regular node logs (Docker or systemd)
    local log_file=""
    local possible_logs=(
        "/var/log/xdc-node.log"
        "/var/log/xdcchain.log"
        "${XDC_DATA}/xdc.log"
        "${XDC_DATA}/geth.log"
        "${XDC_DATA}/erigon.log"
        "${XDC_DATA}/XDC.log"
    )
    
    for log in "${possible_logs[@]}"; do
        if [[ -f "$log" ]]; then
            log_file="$log"
            break
        fi
    done
    
    # Also check journalctl
    local service
    service=$(detect_service)
    
    if [[ -n "$since" ]]; then
        # Convert since to journalctl format
        local journal_since=""
        if [[ "$since" =~ ^[0-9]+[hHmMdD]$ ]]; then
            journal_since="--since=${since} ago"
        elif [[ "$since" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2} ]]; then
            journal_since="--since=${since}"
        fi
        
        if [[ -n "$service" ]]; then
            if [[ "$follow" == "true" ]]; then
                journalctl -u "$service" $journal_since -n "$lines" -f
            else
                journalctl -u "$service" $journal_since -n "$lines" --no-pager
            fi
        elif [[ -n "$log_file" ]]; then
            # For file-based logs with since, we'd need more complex parsing
            # For now, just tail the file
            if [[ "$follow" == "true" ]]; then
                tail -n "$lines" -f "$log_file"
            else
                tail -n "$lines" "$log_file"
            fi
        else
            die "No log files found. Is the node running?"
        fi
    elif [[ -n "$service" ]]; then
        if [[ "$follow" == "true" ]]; then
            journalctl -u "$service" -n "$lines" -f
        else
            journalctl -u "$service" -n "$lines" --no-pager
        fi
    elif [[ -n "$log_file" ]]; then
        if [[ "$follow" == "true" ]]; then
            tail -n "$lines" -f "$log_file"
        else
            tail -n "$lines" "$log_file"
        fi
    else
        die "No log files found. Is the node running?"
    fi
}

#==============================================================================
# Command: restart
#==============================================================================
cmd_restart() {
    local graceful=true
    local force=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --graceful) graceful=true; shift ;;
            --force) graceful=false; force=true; shift ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node restart$(c NC) — Graceful node restart

$(c BOLD)USAGE:$(c NC)
    xdc-node restart [options]

$(c BOLD)OPTIONS:$(c NC)
    --graceful   Wait for current block before restart (default)
    --force      Immediate restart
    --help       Show this help

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    # Try Docker first
    local container
    if container=$(find_container) && [[ -n "$container" ]]; then
        info "Found Docker container: $container"
        
        if [[ "$graceful" == "true" && "$force" != "true" ]]; then
            info "Performing graceful restart..."
            start_spinner "Waiting for block finalization"
            sleep 2
            stop_spinner true "Block finalized"
        fi
        
        start_spinner "Restarting container"
        
        if docker restart "$container" >/dev/null 2>&1; then
            stop_spinner true "Container restarted"
            log "Docker container $container restarted successfully"
            
            # Wait a moment for RPC to be available
            sleep 3
            
            # Inject peers if needed
            inject_peers || true
            return 0
        else
            stop_spinner false "Restart failed"
            die "Failed to restart Docker container $container"
        fi
    fi
    
    # Fall back to systemctl
    require_root
    
    local service
    service=$(detect_service)
    
    if [[ -z "$service" ]]; then
        die "No XDC node service or Docker container found"
    fi
    
    if [[ "$graceful" == "true" && "$force" != "true" ]]; then
        info "Performing graceful restart..."
        start_spinner "Waiting for block finalization"
        sleep 2
        stop_spinner true "Block finalized"
    fi
    
    start_spinner "Restarting node"
    
    if systemctl restart "$service"; then
        stop_spinner true "Node restarted"
        log "Node $service restarted successfully"
        
        # Wait a moment for RPC to be available
        sleep 3
        
        # Inject peers if needed
        inject_peers || true
    else
        stop_spinner false "Restart failed"
        die "Failed to restart $service"
    fi
}

#==============================================================================
# Command: stop
#==============================================================================
cmd_stop() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node stop$(c NC) — Stop all XDC node containers

$(c BOLD)USAGE:$(c NC)
    xdc-node stop

$(c BOLD)DESCRIPTION:$(c NC)
    Stops all XDC-related Docker containers including:
    - xdc-node (main blockchain node)
    - xdc-agent (Next.js dashboard + SkyNet monitoring)
    - xdc-metrics-collector (metrics collection)

$(c BOLD)OPTIONS:$(c NC)
    --help    Show this help

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    # Find and stop all XDC-related containers
    local containers
    containers=$(docker ps -q --filter "name=xdc" --filter "name=skynet" 2>/dev/null || true)
    
    if [[ -n "$containers" ]]; then
        local count
        count=$(echo "$containers" | wc -l)
        info "Found $count XDC container(s)"
        start_spinner "Stopping all XDC containers"
        
        # Stop each container individually to handle spaces in names safely
        local stop_failed=false
        while IFS= read -r container; do
            [[ -n "$container" ]] || continue
            docker stop "$container" >/dev/null 2>&1 || stop_failed=true
        done <<< "$containers"
        
        if [[ "$stop_failed" == "false" ]]; then
            stop_spinner true "All containers stopped"
            log "Stopped $count XDC container(s)"
        else
            stop_spinner false "Some containers failed to stop"
            warn "Some containers may not have stopped cleanly"
        fi
        return 0
    fi
    
    # Try specific container names as fallback
    local specific_containers="xdc-node xdc-agent xdc-metrics-collector"
    local found_any=false
    
    for container in $specific_containers; do
        if docker ps -q --filter "name=$container" | grep -q .; then
            found_any=true
            start_spinner "Stopping $container"
            if docker stop "$container" >/dev/null 2>&1; then
                stop_spinner true "$container stopped"
            else
                stop_spinner false "Failed to stop $container"
            fi
        fi
    done
    
    if [[ "$found_any" == "false" ]]; then
        # Fall back to systemctl
        require_root
        local service
        service=$(detect_service)
        
        if [[ -z "$service" ]]; then
            warn "No XDC node service or Docker container found"
            return 0
        fi
        
        start_spinner "Stopping node"
        
        if systemctl stop "$service"; then
            stop_spinner true "Node stopped"
            log "Node $service stopped"
        else
            stop_spinner false "Stop failed"
            die "Failed to stop $service"
        fi
    fi
}

#==============================================================================
# Command: start
#==============================================================================
cmd_start() {
    local network=""
    local client_override=""
    local install_args=""
    local multi_client=false
    local node_type=""
    local with_agent=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node start$(c NC) — Start node

$(c BOLD)USAGE:$(c NC)
    xdc-node start [OPTIONS]

$(c BOLD)DESCRIPTION:$(c NC)
    Starts the XDC node. If no configuration is found, runs install.sh first.
    Supports running multiple clients simultaneously with monitoring agent.

$(c BOLD)OPTIONS:$(c NC)
    --network NETWORK    Network: mainnet, testnet, devnet, apothem (default: mainnet)
    --client CLIENT      Client: stable, geth-pr5, erigon, nethermind, reth (default: auto-detect)
    --type TYPE          Node type: archive, full, snap (default: full)
                           archive — Keep all historical state (largest storage)
                           full    — Full validation, pruned state (default)
                           snap    — Snap sync for fast initial sync (geth/nethermind only)
    --agent              Start xdc-agent alongside the node (SkyNet monitoring + auto-heal)
    --multi-client, --all Start all configured clients simultaneously
    --monitoring         Start with full monitoring stack (Prometheus, Grafana, etc.)
    --logging            Start with log aggregation stack (Loki, Promtail, Grafana)
    --help               Show this help

$(c BOLD)EXAMPLES:$(c NC)
    xdc-node start                                  # Start mainnet full node
    xdc-node start --type archive                   # Start archive node (all state)
    xdc-node start --type archive --agent           # Archive node + SkyNet agent
    xdc-node start --client erigon --type archive   # Erigon archive node
    xdc-node start --client nethermind --agent      # Nethermind + agent
    xdc-node start --client geth-pr5 --type full    # GP5 full node
    xdc-node start --network apothem                # Start Apothem testnet
    xdc-node start --multi-client --agent           # All clients + agent
    xdc-node start --monitoring                     # Start with monitoring stack

EOF
                return 0
                ;;
            --network)
                network="$2"
                install_args="$install_args --network $network"
                shift 2
                ;;
            --client)
                client_override="$2"
                shift 2
                ;;
            --type)
                node_type="$2"
                case "$node_type" in
                    archive|full|snap) ;;
                    *) die "Invalid node type '$node_type'. Use: archive, full, snap" ;;
                esac
                shift 2
                ;;
            --agent)
                with_agent=true
                shift
                ;;
            --multi-client|--all)
                multi_client=true
                shift
                ;;
            --monitoring)
                local monitoring=true
                shift
                ;;
            --logging)
                local logging=true
                shift
                ;;
            *) shift ;;
        esac
    done
    
    # Default node type
    : "${node_type:=full}"
    
    # Export node type for compose files
    export XDC_NODE_TYPE="$node_type"
    
    # Check if configuration exists
    local config_dir="${INSTALL_DIR:-/opt/xdc-node}"
    local docker_compose="$config_dir/docker/docker-compose.yml"
    
    if [[ ! -f "$docker_compose" ]]; then
        warn "No XDC node configuration found at $config_dir"
        info "Running install.sh to set up your node..."
        
        # Find install.sh
        local install_script=""
        for path in "$config_dir/install.sh" "$PROJECT_DIR/install.sh" "$HOME/xdc-node-setup/install.sh" "./install.sh"; do
            if [[ -f "$path" ]]; then
                install_script="$path"
                break
            fi
        done
        
        if [[ -z "$install_script" ]]; then
            # Download install.sh
            info "Downloading install.sh..."
            install_script="/tmp/xdc-install.sh"
            if curl -fsSL "https://raw.githubusercontent.com/AnilChinchawale/xdc-node-setup/main/install.sh" -o "$install_script" 2>/dev/null; then
                chmod +x "$install_script"
            else
                die "Failed to download install.sh. Please run setup manually."
            fi
        fi
        
        # Run install.sh with network arg
        log "Running $install_script $install_args..."
        if bash "$install_script" $install_args; then
            log "Installation complete. Starting node..."
        else
            die "Installation failed. Please check the output above."
        fi
    fi
    
    # Try Docker first (single container start - existing behavior)
    local container
    if container=$(find_container) && [[ -n "$container" ]] && [[ "$multi_client" != "true" ]] && [[ "$client_override" != "erigon" ]]; then
        info "Found Docker container: $container"
        start_spinner "Starting Docker container"
        
        if docker start "$container" >/dev/null 2>&1; then
            stop_spinner true "Container started"
            log "Docker container $container started"
            
            # Wait a moment for RPC to be available
            sleep 3
            
            # Inject peers if needed
            inject_peers || true
            return 0
        else
            stop_spinner false "Start failed"
            die "Failed to start Docker container $container"
        fi
    fi
    
    # Try to start via docker compose
    if [[ -f "$docker_compose" ]]; then
        cd "$(dirname "$docker_compose")" || die "Failed to change to docker directory"
        
        # --- Port conflict auto-resolution ---
        _find_free_port() {
            local p="$1" tries=10 i=0
            while [ $i -lt $tries ]; do
                if ! ss -tlnH "sport = :$p" 2>/dev/null | grep -q ":$p" && \
                   ! docker ps --format '{{.Ports}}' 2>/dev/null | grep -q "0.0.0.0:$p->"; then
                    echo "$p"; return 0
                fi
                p=$((p + 1)); i=$((i + 1))
            done
            echo "$1"
        }

        # Load env file if exists
        local env_file=""
        for ef in "../${network:-mainnet}/.xdc-node/.env" "../mainnet/.xdc-node/.env" "../testnet/.xdc-node/.env" "../devnet/.xdc-node/.env"; do
            [[ -f "$ef" ]] && env_file="$ef" && break
        done
        
        # Read current ports from env or defaults
        local rpc_port=8545 ws_port=8546 p2p_port=30303 dash_port=7070
        local erigon_rpc_port=8547 erigon_p2p_port=30304 erigon_p2p_68=30311 erigon_dash_port=7071
        if [[ -n "$env_file" ]]; then
            rpc_port=$(grep -E '^RPC_PORT=' "$env_file" 2>/dev/null | cut -d= -f2 || echo 8545)
            ws_port=$(grep -E '^WS_PORT=' "$env_file" 2>/dev/null | cut -d= -f2 || echo 8546)
            p2p_port=$(grep -E '^P2P_PORT=' "$env_file" 2>/dev/null | cut -d= -f2 || echo 30303)
            dash_port=$(grep -E '^DASHBOARD_PORT=' "$env_file" 2>/dev/null | cut -d= -f2 || echo 7070)
            # Erigon ports
            erigon_rpc_port=$(grep -E '^ERIGON_RPC_PORT=' "$env_file" 2>/dev/null | cut -d= -f2 || echo 8547)
            erigon_p2p_port=$(grep -E '^ERIGON_P2P_PORT=' "$env_file" 2>/dev/null | cut -d= -f2 || echo 30304)
            erigon_p2p_68=$(grep -E '^ERIGON_P2P_PORT_68=' "$env_file" 2>/dev/null | cut -d= -f2 || echo 30311)
            erigon_dash_port=$(grep -E '^ERIGON_DASHBOARD_PORT=' "$env_file" 2>/dev/null | cut -d= -f2 || echo 7071)
        fi
        : "${rpc_port:=8545}" "${ws_port:=8546}" "${p2p_port:=30303}" "${dash_port:=7070}"
        : "${erigon_rpc_port:=8547}" "${erigon_p2p_port:=30304}" "${erigon_p2p_68:=30311}" "${erigon_dash_port:=7071}"
        
        # Check if geth (xdc-node) is already running
        local geth_running=false
        if docker ps --format '{{.Names}}' | grep -q "^xdc-node$"; then
            geth_running=true
        fi
        
        # Check if erigon is already running
        local erigon_running=false
        if docker ps --format '{{.Names}}' | grep -q "^xdc-node-erigon$"; then
            erigon_running=true
        fi
        
        # Multi-client mode: start both geth and erigon
        if [[ "$multi_client" == "true" ]]; then
            info "Starting multi-client mode (both geth and erigon)..."
            start_spinner "Starting XDC nodes"
            
            # Resolve port conflicts for multi-client mode
            local orig_rpc=$rpc_port orig_ws=$ws_port orig_p2p=$p2p_port orig_dash=$dash_port
            local orig_erigon_rpc=$erigon_rpc_port orig_erigon_p2p=$erigon_p2p_port
            local orig_erigon_p2p_68=$erigon_p2p_68 orig_erigon_dash=$erigon_dash_port
            
            rpc_port=$(_find_free_port "$rpc_port")
            ws_port=$(_find_free_port "$ws_port")
            p2p_port=$(_find_free_port "$p2p_port")
            dash_port=$(_find_free_port "$dash_port")
            erigon_rpc_port=$(_find_free_port "$erigon_rpc_port")
            erigon_p2p_port=$(_find_free_port "$erigon_p2p_port")
            erigon_p2p_68=$(_find_free_port "$erigon_p2p_68")
            erigon_dash_port=$(_find_free_port "$erigon_dash_port")
            
            # Log any port changes
            [[ "$rpc_port" != "$orig_rpc" ]] && warn "Geth RPC port $orig_rpc in use → using $rpc_port"
            [[ "$ws_port" != "$orig_ws" ]] && warn "Geth WS port $orig_ws in use → using $ws_port"
            [[ "$p2p_port" != "$orig_p2p" ]] && warn "Geth P2P port $orig_p2p in use → using $p2p_port"
            [[ "$dash_port" != "$orig_dash" ]] && warn "Geth Dashboard port $orig_dash in use → using $dash_port"
            [[ "$erigon_rpc_port" != "$orig_erigon_rpc" ]] && warn "Erigon RPC port $orig_erigon_rpc in use → using $erigon_rpc_port"
            [[ "$erigon_p2p_port" != "$orig_erigon_p2p" ]] && warn "Erigon P2P port $orig_erigon_p2p in use → using $erigon_p2p_port"
            [[ "$erigon_p2p_68" != "$orig_erigon_p2p_68" ]] && warn "Erigon P2P68 port $orig_erigon_p2p_68 in use → using $erigon_p2p_68"
            [[ "$erigon_dash_port" != "$orig_erigon_dash" ]] && warn "Erigon Dashboard port $orig_erigon_dash in use → using $erigon_dash_port"
            
            # Export all ports
            export RPC_PORT="$rpc_port" WS_PORT="$ws_port" P2P_PORT="$p2p_port" DASHBOARD_PORT="$dash_port"
            export ERIGON_RPC_PORT="$erigon_rpc_port" ERIGON_P2P_PORT="$erigon_p2p_port" 
            export ERIGON_P2P_PORT_68="$erigon_p2p_68" ERIGON_DASHBOARD_PORT="$erigon_dash_port"
            [[ -n "$network" ]] && export NETWORK="$network"
            
            # Start geth if not running
            if [[ "$geth_running" != "true" ]]; then
                info "Starting geth (xdc-node)..."
                if ! docker compose -f docker-compose.yml up -d xdc-node xdc-agent 2>/dev/null; then
                    stop_spinner false "Failed to start geth"
                    die "Failed to start geth client. Check 'docker compose logs' for details."
                fi
                log "Geth client started"
            else
                info "Geth already running, skipping..."
            fi
            
            # Start erigon using standalone compose
            if [[ "$erigon_running" != "true" ]]; then
                info "Starting erigon (xdc-erigon)..."
                if [[ -f "docker-compose.erigon-standalone.yml" ]]; then
                    # Create xdc-network if it doesn't exist
                    docker network create xdc-network 2>/dev/null || true
                    
                    if ! docker compose -f docker-compose.erigon-standalone.yml up -d 2>/dev/null; then
                        stop_spinner false "Failed to start erigon"
                        die "Failed to start erigon client. Check 'docker compose logs' for details."
                    fi
                    log "Erigon client started"
                else
                    stop_spinner false "Erigon standalone compose not found"
                    die "docker-compose.erigon-standalone.yml not found. Please check your installation."
                fi
            else
                info "Erigon already running, skipping..."
            fi
            
            stop_spinner true "Both clients started"
            
            # Print status
            echo ""
            echo -e "$(c GREEN)$(c BOLD)═══════════════════════════════════════════$(c NC)"
            echo -e "$(c GREEN)$(c BOLD)  Multi-Client Mode Active!$(c NC)"
            echo -e "$(c GREEN)$(c BOLD)═══════════════════════════════════════════$(c NC)"
            echo ""
            echo -e "  $(c BOLD)Geth (xdc-node):$(c NC)"
            echo -e "    Dashboard:  http://localhost:${dash_port}"
            echo -e "    RPC:        http://127.0.0.1:${rpc_port}"
            echo -e "    WebSocket:  ws://127.0.0.1:${ws_port}"
            echo -e "    P2P:        :${p2p_port}"
            echo ""
            echo -e "  $(c BOLD)Erigon (xdc-erigon):$(c NC)"
            echo -e "    Dashboard:  http://localhost:${erigon_dash_port}"
            echo -e "    RPC:        http://127.0.0.1:${erigon_rpc_port}"
            echo -e "    P2P:        :${erigon_p2p_port} (eth/63), :${erigon_p2p_68} (eth/68)"
            echo ""
            echo -e "  $(c BOLD)Node Type:$(c NC) $node_type"
            [[ "$with_agent" == "true" ]] && echo -e "  $(c BOLD)Agent:$(c NC)      ✅ SkyNet monitoring active"
            echo ""
            echo -e "  $(c DIM)Check status:  xdc status$(c NC)"
            echo -e "  $(c DIM)View logs:     xdc logs --client erigon$(c NC)"
            echo ""
            
            # Start agent if requested
            if [[ "$with_agent" == "true" ]]; then
                _start_xdc_agent "$network" "multi" "$node_type"
            fi
            
            return 0
        fi
        
        # Single client mode with --client erigon
        # If geth is running and user wants erigon, use standalone compose
        if [[ "$client_override" == "erigon" ]] && [[ "$geth_running" == "true" ]]; then
            info "Starting erigon alongside existing geth node..."
            start_spinner "Starting Erigon"
            
            # Resolve erigon port conflicts
            local orig_erigon_rpc=$erigon_rpc_port orig_erigon_p2p=$erigon_p2p_port
            local orig_erigon_p2p_68=$erigon_p2p_68 orig_erigon_dash=$erigon_dash_port
            erigon_rpc_port=$(_find_free_port "$erigon_rpc_port")
            erigon_p2p_port=$(_find_free_port "$erigon_p2p_port")
            erigon_p2p_68=$(_find_free_port "$erigon_p2p_68")
            erigon_dash_port=$(_find_free_port "$erigon_dash_port")
            
            # Log any changes
            [[ "$erigon_rpc_port" != "$orig_erigon_rpc" ]] && warn "Erigon RPC port $orig_erigon_rpc in use → using $erigon_rpc_port"
            [[ "$erigon_p2p_port" != "$orig_erigon_p2p" ]] && warn "Erigon P2P port $orig_erigon_p2p in use → using $erigon_p2p_port"
            [[ "$erigon_p2p_68" != "$orig_erigon_p2p_68" ]] && warn "Erigon P2P68 port $orig_erigon_p2p_68 in use → using $erigon_p2p_68"
            [[ "$erigon_dash_port" != "$orig_erigon_dash" ]] && warn "Erigon Dashboard port $orig_erigon_dash in use → using $erigon_dash_port"
            
            # Export erigon ports
            export ERIGON_RPC_PORT="$erigon_rpc_port" ERIGON_P2P_PORT="$erigon_p2p_port"
            export ERIGON_P2P_PORT_68="$erigon_p2p_68" ERIGON_DASHBOARD_PORT="$erigon_dash_port"
            [[ -n "$network" ]] && export NETWORK="$network"
            
            if [[ -f "docker-compose.erigon-standalone.yml" ]]; then
                # Create xdc-network if it doesn't exist (geth should have created it)
                docker network create xdc-network 2>/dev/null || true
                
                if docker compose -f docker-compose.erigon-standalone.yml up -d 2>/dev/null; then
                    stop_spinner true "Erigon started"
                    log "Erigon client started alongside geth"
                    
                    echo ""
                    echo -e "$(c GREEN)$(c BOLD)═══════════════════════════════════════════$(c NC)"
                    echo -e "$(c GREEN)$(c BOLD)  Erigon Node Running Alongside Geth!$(c NC)"
                    echo -e "$(c GREEN)$(c BOLD)═══════════════════════════════════════════$(c NC)"
                    echo ""
                    echo -e "  $(c BOLD)Geth (existing):$(c NC)"
                    echo -e "    RPC:        http://127.0.0.1:${rpc_port}"
                    echo ""
                    echo -e "  $(c BOLD)Erigon (new):$(c NC)"
                    echo -e "    Dashboard:  http://localhost:${erigon_dash_port}"
                    echo -e "    RPC:        http://127.0.0.1:${erigon_rpc_port}"
                    echo -e "    P2P:        :${erigon_p2p_port} (eth/63), :${erigon_p2p_68} (eth/68)"
                    echo ""
                    return 0
                else
                    stop_spinner false "Erigon start failed"
                    die "Failed to start Erigon. Check 'docker compose logs' for details."
                fi
            else
                stop_spinner false "Erigon compose not found"
                die "docker-compose.erigon-standalone.yml not found"
            fi
        fi
        
        # Standard single-client mode
        start_spinner "Starting XDC node"
        
        # Resolve conflicts
        local orig_rpc=$rpc_port orig_ws=$ws_port orig_p2p=$p2p_port orig_dash=$dash_port
        rpc_port=$(_find_free_port "$rpc_port")
        ws_port=$(_find_free_port "$ws_port")
        p2p_port=$(_find_free_port "$p2p_port")
        dash_port=$(_find_free_port "$dash_port")
        
        # Log any changes
        [[ "$rpc_port" != "$orig_rpc" ]] && warn "RPC port $orig_rpc in use → using $rpc_port"
        [[ "$ws_port" != "$orig_ws" ]] && warn "WS port $orig_ws in use → using $ws_port"
        [[ "$p2p_port" != "$orig_p2p" ]] && warn "P2P port $orig_p2p in use → using $p2p_port"
        [[ "$dash_port" != "$orig_dash" ]] && warn "Dashboard port $orig_dash in use → using $dash_port"
        
        # Detect client type from config or use override
        local client="${client_override:-stable}"
        if [[ -z "$client_override" ]]; then
            local client_conf=""
            for cf in "../${network:-mainnet}/.xdc-node/client.conf" "../mainnet/.xdc-node/client.conf" "../testnet/.xdc-node/client.conf" "../devnet/.xdc-node/client.conf"; do
                [[ -f "$cf" ]] && client_conf="$cf" && break
            done
            
            if [[ -n "$client_conf" ]]; then
                client=$(grep -E '^CLIENT=' "$client_conf" 2>/dev/null | cut -d= -f2 || echo "stable")
            fi
        fi
        
        # Build compose command with client and optional monitoring stack
        local compose_cmd="docker compose -f docker-compose.yml"
        
        # --- Node type: set GC mode flags per client ---
        # These env vars are picked up by compose files / entrypoints
        local gcmode_flag=""
        case "$node_type" in
            archive)
                export XDC_GCMODE="archive"
                gcmode_flag="--gcmode archive"
                info "Node type: ARCHIVE (all historical state preserved)"
                ;;
            snap)
                export XDC_SYNCMODE="snap"
                gcmode_flag="--syncmode snap"
                info "Node type: SNAP sync (fast initial sync)"
                ;;
            full|*)
                export XDC_GCMODE="full"
                gcmode_flag="--gcmode full"
                info "Node type: FULL (default)"
                ;;
        esac
        export XDC_EXTRA_FLAGS="${XDC_EXTRA_FLAGS:-} $gcmode_flag"
        
        # Add client-specific override
        case "$client" in
            erigon)
                # If geth is NOT running, use override compose (existing behavior)
                if [[ "$geth_running" != "true" ]]; then
                    if [[ -f "docker-compose.erigon.yml" ]]; then
                        compose_cmd="$compose_cmd -f docker-compose.erigon.yml"
                        info "Using Erigon-XDC client"
                    else
                        warn "Erigon compose file not found, using stable client"
                    fi
                fi
                # Erigon-specific: archive = --prune=nothing, full = default
                if [[ "$node_type" == "archive" ]]; then
                    export ERIGON_EXTRA_FLAGS="${ERIGON_EXTRA_FLAGS:-} --prune=nothing"
                fi
                ;;
            geth-pr5)
                if [[ -f "docker-compose.geth-pr5.yml" ]]; then
                    compose_cmd="$compose_cmd -f docker-compose.geth-pr5.yml"
                    info "Using Geth PR5 client"
                else
                    warn "Geth PR5 compose file not found, using stable client"
                fi
                ;;
            nethermind)
                if [[ -f "docker-compose.nethermind-standalone.yml" ]]; then
                    compose_cmd="docker compose -f docker-compose.nethermind-standalone.yml"
                    info "Using Nethermind-XDC client"
                elif [[ -f "docker-compose.nethermind.yml" ]]; then
                    compose_cmd="$compose_cmd -f docker-compose.nethermind.yml"
                    info "Using Nethermind-XDC client (overlay)"
                else
                    warn "Nethermind compose file not found, using stable client"
                fi
                # Nethermind-specific node type
                case "$node_type" in
                    archive) export NM_EXTRA_FLAGS="${NM_EXTRA_FLAGS:-} --Pruning.Mode=None" ;;
                    snap)    export NM_EXTRA_FLAGS="${NM_EXTRA_FLAGS:-} --Sync.FastSync=true" ;;
                esac
                ;;
            reth)
                if [[ -f "docker-compose.reth.yml" ]]; then
                    compose_cmd="docker compose -f docker-compose.reth.yml"
                    info "Using Reth-XDC client"
                else
                    warn "Reth compose file not found. Reth must be run manually."
                fi
                # Reth: archive = --full, otherwise default
                if [[ "$node_type" == "archive" ]]; then
                    export RETH_EXTRA_FLAGS="${RETH_EXTRA_FLAGS:-} --full"
                fi
                ;;
            stable|*)
                info "Using XDC Stable client (v2.6.8)"
                ;;
        esac
        
        # Add monitoring stack if requested
        if [[ "${monitoring:-false}" == "true" ]] && [[ -f "docker-compose.monitoring.yml" ]]; then
            compose_cmd="$compose_cmd -f docker-compose.monitoring.yml"
            info "Including monitoring stack (Prometheus, Grafana, etc.)"
        fi
        
        # Add logging stack if requested
        if [[ "${logging:-false}" == "true" ]] && [[ -f "docker-compose.logging.yml" ]]; then
            compose_cmd="$compose_cmd -f docker-compose.logging.yml"
            info "Including logging stack (Loki, Promtail, Grafana)"
            info "Log dashboard will be available at http://localhost:3200"
        fi
        
        # Export resolved ports and start
        export RPC_PORT="$rpc_port" WS_PORT="$ws_port" PORT="$p2p_port" P2P_PORT="$p2p_port" DASHBOARD_PORT="$dash_port"
        [[ -n "$network" ]] && export NETWORK="$network"
        
        # Ensure skynet.conf exists as a file (Docker creates a directory if missing)
        local _skynet_conf="../${network:-mainnet}/.xdc-node/skynet.conf"
        if [[ -d "$_skynet_conf" ]]; then
            rm -rf "$_skynet_conf"
        fi
        if [[ ! -f "$_skynet_conf" ]]; then
            mkdir -p "$(dirname "$_skynet_conf")"
            touch "$_skynet_conf"
        fi
        
        if $compose_cmd up -d 2>/dev/null; then
            stop_spinner true "Node started"
        else
            stop_spinner false "Start failed"
            die "Failed to start XDC node. Check 'docker compose logs' for details."
        fi
        
        log "XDC node started via docker compose ($client, $node_type)"
        
        # --- Start xdc-agent if requested ---
        if [[ "$with_agent" == "true" ]]; then
            _start_xdc_agent "$network" "$client" "$node_type"
        fi
        
        # Wait for RPC
        sleep 5
        
        # Inject peers
        inject_peers || true
        
        # --- Print access links ---
        echo ""
        echo -e "$(c GREEN)$(c BOLD)═══════════════════════════════════════════$(c NC)"
        echo -e "$(c GREEN)$(c BOLD)  XDC Node is running!$(c NC)"
        echo -e "$(c GREEN)$(c BOLD)═══════════════════════════════════════════$(c NC)"
        echo ""
        echo -e "  $(c BOLD)Client:$(c NC)     $client"
        echo -e "  $(c BOLD)Type:$(c NC)       $node_type"
        echo -e "  $(c BOLD)Dashboard:$(c NC)  http://localhost:${dash_port}"
        echo -e "  $(c BOLD)RPC:$(c NC)        http://127.0.0.1:${rpc_port}"
        echo -e "  $(c BOLD)WebSocket:$(c NC)  ws://127.0.0.1:${ws_port}"
        echo -e "  $(c BOLD)P2P:$(c NC)        :${p2p_port}"
        [[ "$with_agent" == "true" ]] && echo -e "  $(c BOLD)Agent:$(c NC)      ✅ SkyNet monitoring active"
        echo ""
        echo -e "  $(c DIM)Check status:  xdc status$(c NC)"
        echo -e "  $(c DIM)View logs:     xdc logs$(c NC)"
        echo ""
        return 0
    fi
    
    # Fall back to systemctl
    require_root
    
    local service
    service=$(detect_service)
    
    if [[ -z "$service" ]]; then
        die "No XDC node service or Docker container found"
    fi
    
    start_spinner "Starting node"
    
    if systemctl start "$service"; then
        stop_spinner true "Node started"
        log "Node $service started"
        
        # Wait a moment for RPC to be available
        sleep 3
        
        # Inject peers if needed
        inject_peers || true
    else
        stop_spinner false "Start failed"
        die "Failed to start $service"
    fi
}

#==============================================================================
# Command: config
#==============================================================================
cmd_config() {
    local action=""
    local key=""
    local value=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            list|get|set)
                action="$1"
                shift
                if [[ "$action" == "get" || "$action" == "set" ]]; then
                    key="${1:-}"
                    shift || true
                fi
                if [[ "$action" == "set" ]]; then
                    value="${1:-}"
                    shift || true
                fi
                ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node config$(c NC) — View/edit configuration

$(c BOLD)USAGE:$(c NC)
    xdc-node config list
    xdc-node config get <key>
    xdc-node config set <key> <value>

$(c BOLD)OPTIONS:$(c NC)
    --json    Output in JSON format
    --help    Show this help

$(c BOLD)KEYS:$(c NC)
    rpc_url              RPC endpoint URL
    network              Network (mainnet/testnet)
    client               Client name
    auto_update          Enable auto-updates (true/false)
    telegram_enabled     Enable Telegram notifications
    telegram_bot_token   Telegram bot token
    telegram_chat_id     Telegram chat ID

$(c BOLD)EXAMPLES:$(c NC)
    xdc-node config list
    xdc-node config get network
    xdc-node config set telegram_enabled true

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    case "$action" in
        list)
            if [[ "$OUTPUT_JSON" == "true" ]]; then
                cat "$VERSIONS_FILE" 2>/dev/null || echo '{}'
            else
                if [[ -f "$VERSIONS_FILE" ]]; then
                    echo -e "$(c BOLD)Configuration (versions.json):$(c NC)"
                    echo ""
                    jq '.' "$VERSIONS_FILE" 2>/dev/null || cat "$VERSIONS_FILE"
                else
                    warn "Config file not found: $VERSIONS_FILE"
                fi
            fi
            ;;
        get)
            if [[ -z "$key" ]]; then
                die "Please specify a key. Run 'xdc-node config --help' for available keys."
            fi
            local result
            result=$(get_config ".$key" "")
            if [[ -n "$result" ]]; then
                echo "$result"
            else
                die "Key not found: $key"
            fi
            ;;
        set)
            if [[ -z "$key" || -z "$value" ]]; then
                die "Please specify key and value. Usage: xdc-node config set <key> <value>"
            fi
            require_root
            
            if [[ -f "$VERSIONS_FILE" ]]; then
                local tmp_file
                tmp_file=$(mktemp)
                jq ".$key = \"$value\"" "$VERSIONS_FILE" > "$tmp_file" && mv "$tmp_file" "$VERSIONS_FILE"
                log "Set $key = $value"
            else
                die "Config file not found: $VERSIONS_FILE"
            fi
            ;;
        *)
            die "Unknown action. Use: list, get, or set"
            ;;
    esac
}

#==============================================================================
# Command: notify
#==============================================================================
cmd_notify() {
    local test=false
    local message=""
    local level="info"
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --test) test=true; shift ;;
            --send) message="$2"; shift 2 ;;
            --level) level="$2"; shift 2 ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node notify$(c NC) — Test notifications or send custom alert

$(c BOLD)USAGE:$(c NC)
    xdc-node notify [options]

$(c BOLD)OPTIONS:$(c NC)
    --test             Test all configured notification channels
    --send "message"   Send a custom notification
    --level LEVEL      Notification level (critical, warning, info)
    --help             Show this help

$(c BOLD)EXAMPLES:$(c NC)
    xdc-node notify --test
    xdc-node notify --send "Node maintenance complete" --level info

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    local notify_script="${SCRIPTS_DIR}/lib/notify.sh"
    local test_script="${SCRIPTS_DIR}/notify-test.sh"
    
    if [[ "$test" == "true" ]]; then
        if [[ -f "$test_script" ]]; then
            info "Testing notification channels..."
            bash "$test_script"
        else
            die "Notification test script not found"
        fi
    elif [[ -n "$message" ]]; then
        if [[ -f "$notify_script" ]]; then
            # shellcheck source=/dev/null
            source "$notify_script"
            
            case "$level" in
                critical) notify_alert "critical" "🚨 Alert" "$message" "cli_alert" ;;
                warning)  notify_alert "warning" "⚠️ Warning" "$message" "cli_alert" ;;
                *)        notify_alert "info" "ℹ️ Info" "$message" "cli_alert" ;;
            esac
            
            log "Notification sent: $message"
        else
            die "Notification library not found"
        fi
    else
        die "Please specify --test or --send \"message\""
    fi
}

#==============================================================================
# Command: dashboard
#==============================================================================
cmd_dashboard() {
    local port=3000
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port) port="$2"; shift 2 ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node dashboard$(c NC) — Start web dashboard

$(c BOLD)USAGE:$(c NC)
    xdc-node dashboard [options]

$(c BOLD)OPTIONS:$(c NC)
    --port N    Port number (default: 3000)
    --help      Show this help

$(c BOLD)DESCRIPTION:$(c NC)
    Starts the web-based monitoring dashboard.

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    local dashboard_dir="${PROJECT_DIR}/dashboard"
    
    if [[ ! -d "$dashboard_dir" ]]; then
        die "Dashboard not found. It may not be installed yet."
    fi
    
    info "Starting dashboard on port $port..."
    info "Open http://localhost:$port in your browser"
    
    cd "$dashboard_dir"
    
    if [[ -f "package.json" ]]; then
        npm start -- --port "$port"
    elif [[ -f "index.html" ]]; then
        python3 -m http.server "$port"
    else
        die "Dashboard entry point not found"
    fi
}

#==============================================================================
# Command: version
#==============================================================================
cmd_version() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node version$(c NC) — Show version information

$(c BOLD)USAGE:$(c NC)
    xdc-node version

$(c BOLD)OPTIONS:$(c NC)
    --json    Output in JSON format
    --help    Show this help

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    local client
    client=$(detect_client)
    
    local current_version
    current_version=$(get_config ".clients.${client:-XDPoSChain}.current" "unknown")
    
    local latest_version
    local repo
    repo=$(get_config ".clients.${client:-XDPoSChain}.repo" "XinFinOrg/XDPoSChain")
    latest_version=$(curl -s "https://api.github.com/repos/$repo/releases/latest" 2>/dev/null | jq -r '.tag_name // "unknown"')
    
    if [[ "$OUTPUT_JSON" == "true" ]]; then
        cat << EOF
{
  "cli": "$CLI_VERSION",
  "client": "${client:-unknown}",
  "clientVersion": "$current_version",
  "latestVersion": "$latest_version"
}
EOF
        return 0
    fi
    
    echo -e "$(c BOLD)xdc-node CLI$(c NC)        v$CLI_VERSION"
    echo -e "$(c BOLD)Client$(c NC)              ${client:-not detected}"
    echo -e "$(c BOLD)Client Version$(c NC)      $current_version"
    echo -e "$(c BOLD)Latest Available$(c NC)    $latest_version"
}

#==============================================================================
# First Run Experience
#==============================================================================
first_run_check() {
    if [[ ! -f "$FIRST_RUN_FILE" && "$QUIET" != "true" && "$OUTPUT_JSON" != "true" ]]; then
        print_banner
        echo -e "$(c GREEN)Welcome to the XDC Node CLI!$(c NC)"
        echo ""
        echo "Quick start:"
        echo "  1. Run 'xdc-node init' to set up your node"
        echo "  2. Run 'xdc-node status' to check node health"
        echo "  3. Run 'xdc-node help' for all available commands"
        echo ""
        
        # Create marker file
        mkdir -p "$(dirname "$FIRST_RUN_FILE")"
        touch "$FIRST_RUN_FILE" 2>/dev/null || true
    fi
}

#------------------------------------------------------------------------------
# XDC-Specific Commands
#------------------------------------------------------------------------------

cmd_masternode() {

cmd_client() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                cat << 'HELP'
$(c BOLD)xdc client$(c NC) — Show current client information

$(c BOLD)USAGE:$(c NC)
    xdc client

$(c BOLD)DESCRIPTION:$(c NC)
    Display information about the currently running XDC client,
    including client type (stable, geth-pr5, erigon), version,
    and configuration.

$(c BOLD)EXAMPLES:$(c NC)
    xdc client      # Show client info

HELP
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    if [[ "$QUIET" != "true" ]]; then
        print_banner
        echo -e "$(c BOLD)XDC Client Information$(c NC)"
        echo ""
    fi
    
    # Try to detect client from config
    local client="unknown"
    local client_conf=""
    for cf in "${PROJECT_DIR}"/*/".xdc-node/client.conf"; do
        [[ -f "$cf" ]] && client_conf="$cf" && break
    done
    
    if [[ -n "$client_conf" ]]; then
        client=$(grep -E '^CLIENT=' "$client_conf" 2>/dev/null | cut -d= -f2 || echo "unknown")
        echo -e "$(c BOLD)Configured Client:$(c NC) $(c CYAN)${client}$(c NC)"
        echo -e "$(c DIM)  Config: ${client_conf}$(c NC)"
        echo ""
    fi
    
    # Try to get running client version from RPC
    local rpc_url="${XDC_RPC_URL:-http://localhost:8545}"
    local response
    response=$(rpc_call "$rpc_url" "web3_clientVersion" 2>/dev/null || echo '{}')
    local client_version=$(echo "$response" | jq -r '.result // "unknown"')
    
    if [[ "$client_version" != "unknown" ]]; then
        echo -e "$(c BOLD)Running Client:$(c NC)"
        echo -e "  Version: $(c CYAN)${client_version}$(c NC)"
        
        # Detect client type from version string
        local detected_client="unknown"
        if [[ "$client_version" == *"erigon"* ]]; then
            detected_client="Erigon-XDC"
        elif [[ "$client_version" == *"feature/xdpos"* ]] || [[ "$client_version" == *"pr5"* ]]; then
            detected_client="XDC Geth PR5"
        elif [[ "$client_version" == *"XDC"* ]]; then
            detected_client="XDC Stable"
        fi
        echo -e "  Type:    $(c CYAN)${detected_client}$(c NC)"
        echo ""
    else
        echo -e "$(c YELLOW)⚠$(c NC) Node RPC not available at $rpc_url"
        echo ""
    fi
    
    # Show available clients
    echo -e "$(c BOLD)Available Clients:$(c NC)"
    echo "  1. $(c GREEN)stable$(c NC)    - XDC Stable (v2.6.8) - Official Docker image"
    echo "  2. $(c GREEN)geth-pr5$(c NC)  - XDC Geth PR5 - Latest geth with XDPoS"
    echo "  3. $(c GREEN)erigon$(c NC)    - Erigon-XDC - Multi-client diversity"
    echo ""
    echo -e "$(c DIM)To switch clients, run: xdc start --client <name>$(c NC)"
}

    local action=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            setup|status|register)
                action="$1"
                shift
                ;;
            --help|-h)
                echo "xdc-node masternode — XDC Masternode Setup"
                echo ""
                echo "Usage:"
                echo "  xdc-node masternode setup    Run interactive masternode setup"
                echo "  xdc-node masternode status   Check masternode status"
                echo "  xdc-node masternode register Register as masternode candidate"
                echo ""
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    case "$action" in
        setup|status|register)
            run_script "masternode-setup.sh" "--$action"
            ;;
        *)
            run_script "masternode-setup.sh"
            ;;
    esac
}

cmd_peers() {
    local action="optimize"
    local args=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            optimize|list|test|add)
                action="$1"
                shift
                ;;
            --testnet)
                args="$args --testnet"
                shift
                ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node peers$(c NC) — Peer Connection Optimization

$(c BOLD)USAGE:$(c NC)
    xdc-node peers <command> [options]

$(c BOLD)COMMANDS:$(c NC)
    optimize  Optimize peer list by latency ranking
    list      List current peers
    test      Test bootnode connectivity
    add       Add peers from bootnodes.list (manual peer injection)

$(c BOLD)OPTIONS:$(c NC)
    --testnet    Use testnet instead of mainnet
    --help       Show this help

$(c BOLD)EXAMPLES:$(c NC)
    xdc-node peers optimize
    xdc-node peers add
    xdc-node peers list --testnet

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    case "$action" in
        add)
            inject_peers
            ;;
        *)
            # bootnode-optimize.sh doesn't use action flags, just run with args
            run_script "bootnode-optimize.sh" "$args"
            ;;
    esac
}

cmd_snapshot() {
    local SNAPSHOT_URL="${1:-${SNAPSHOT_URL:-}}"
    local DATA_DIR="${XDC_DATA:-${PROJECT_DIR}/${XDC_NETWORK}/xdcchain}"
    local COMPOSE_FILE="${INSTALL_DIR}/docker/docker-compose.yml"
    
    # Fallback to find compose file
    if [[ ! -f "$COMPOSE_FILE" ]]; then
        for cf in "${PROJECT_DIR}/docker/docker-compose.yml" "${PROJECT_DIR}/docker-compose.yml" "./docker-compose.yml"; do
            [[ -f "$cf" ]] && COMPOSE_FILE="$cf" && break
        done
    fi

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --url)
                SNAPSHOT_URL="$2"
                shift 2
                ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc snapshot$(c NC) — Download and apply chain snapshot

$(c BOLD)USAGE:$(c NC)
    xdc snapshot [URL]
    xdc snapshot --url <snapshot_url>

$(c BOLD)DESCRIPTION:$(c NC)
    Downloads and applies a chain snapshot to quickly sync the node.
    Supports XDC mainnet snapshots (pruned ~100GB, archive ~500GB).
    Automatically stops the node, backs up existing data, downloads
    and extracts the snapshot, then restarts.

$(c BOLD)SNAPSHOTS:$(c NC)
    Without a URL, prompts to select:
      1) XDC Mainnet (pruned) — ~100GB
      2) XDC Mainnet (archive) — ~500GB
      3) Custom URL

$(c BOLD)EXAMPLES:$(c NC)
    xdc snapshot                    # Interactive snapshot selection
    xdc snapshot https://example.com/snapshot.tar.gz
    xdc snapshot --url https://example.com/snapshot.tar.gz

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done

    if [ -z "$SNAPSHOT_URL" ]; then
        # Default XDC mainnet snapshot URLs
        echo "Available snapshots:"
        echo "  1) XDC Mainnet (pruned) — ~100GB"
        echo "  2) XDC Mainnet (archive) — ~500GB"
        echo "  3) Custom URL"
        read -rp "Select [1-3]: " choice
        case $choice in
            1) SNAPSHOT_URL="https://download.xinfin.network/xdcchain-mainnet-pruned.tar.gz" ;;
            2) SNAPSHOT_URL="https://download.xinfin.network/xdcchain-mainnet-archive.tar.gz" ;;
            3) read -rp "Enter URL: " SNAPSHOT_URL ;;
            *) error "Invalid choice"; return 1 ;;
        esac
    fi

    if [ -z "$SNAPSHOT_URL" ]; then
        error "No snapshot URL provided"
        return 1
    fi

    # Check for required tools
    if ! command -v wget &>/dev/null && ! command -v curl &>/dev/null; then
        die "Either wget or curl is required"
    fi

    # 1. Stop node
    log "Stopping node..."
    if ! docker compose -f "$COMPOSE_FILE" stop xdc-node 2>/dev/null; then
        docker-compose -f "$COMPOSE_FILE" stop xdc-node 2>/dev/null || warn "Failed to stop node, continuing anyway"
    fi

    # 2. Backup existing chaindata
    if [ -d "$DATA_DIR/xdcchain" ]; then
        log "Backing up existing chaindata..."
        mv "$DATA_DIR/xdcchain" "$DATA_DIR/xdcchain.backup.$(date +%Y%m%d_%H%M%S)"
    fi
    mkdir -p "$DATA_DIR/xdcchain"

    # 3. Download with resume support
    log "Downloading snapshot from $SNAPSHOT_URL..."
    log "This may take a while depending on snapshot size and network speed..."
    if command -v wget &>/dev/null; then
        wget -c "$SNAPSHOT_URL" -O "$DATA_DIR/snapshot.tar.gz" || die "Download failed"
    else
        curl -C - -L "$SNAPSHOT_URL" -o "$DATA_DIR/snapshot.tar.gz" || die "Download failed"
    fi

    # 4. Extract
    log "Extracting snapshot..."
    tar xzf "$DATA_DIR/snapshot.tar.gz" -C "$DATA_DIR/xdcchain/" || die "Extraction failed"
    rm "$DATA_DIR/snapshot.tar.gz"

    # 5. Restart
    log "Starting node with snapshot data..."
    if ! docker compose -f "$COMPOSE_FILE" up -d xdc-node 2>/dev/null; then
        docker-compose -f "$COMPOSE_FILE" up -d xdc-node || die "Failed to start node"
    fi
    log "Snapshot applied. Check sync with: xdc status"
}

