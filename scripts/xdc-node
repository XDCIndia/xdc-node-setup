    xdc heartbeat --install     # Install SkyNet heartbeat agent
    xdc ssl -d dashboard.example.com -e admin@example.com  # Setup SSL
    xdc security                # Run security audit (advisory only)
    xdc security --fix          # Apply security fixes (with confirmation)
