cmd_governance() {
    local action=""
    local proposal_id=""
    local vote_choice=""
    local voter_address=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            proposals|vote|impact|history)
                action="$1"
                shift
                ;;
            --id)
                proposal_id="$2"
                shift 2
                ;;
            --vote)
                vote_choice="$2"
                shift 2
                ;;
            --address)
                voter_address="$2"
                shift 2
                ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node governance$(c NC) — XDC Governance Participation

$(c BOLD)USAGE:$(c NC)
    xdc-node governance proposals                    List active proposals
    xdc-node governance vote --id ID --vote yes|no [--address ADDR]
    xdc-node governance impact --id ID               Analyze proposal impact
    xdc-node governance history                      Show voting history

$(c BOLD)OPTIONS:$(c NC)
    --id ID         Proposal ID
    --vote CHOICE   Vote choice (yes/no)
    --address ADDR  Voter address (optional, uses coinbase if not set)
    --help          Show this help

$(c BOLD)EXAMPLES:$(c NC)
    xdc-node governance proposals                    # List proposals
    xdc-node governance vote --id 123 --vote yes     # Cast vote
    xdc-node governance impact --id 123              # Analyze proposal
    xdc-node governance history                      # View history

$(c BOLD)DESCRIPTION:$(c NC)
    Participate in XDC Network governance:
    - View active governance proposals
    - Cast votes on proposals (requires masternode)
    - Analyze proposal impact
    - Track your voting history

Note: Only masternode owners can participate in governance.

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    case "$action" in
        proposals)
            run_script "governance.sh" "proposals"
            ;;
        vote)
            if [[ -z "$proposal_id" || -z "$vote_choice" ]]; then
                error "Usage: xdc-node governance vote --id ID --vote yes|no [--address ADDR]"
                return 1
            fi
            if [[ -n "$voter_address" ]]; then
                run_script "governance.sh" "vote $proposal_id $vote_choice $voter_address"
            else
                run_script "governance.sh" "vote $proposal_id $vote_choice"
            fi
            ;;
        impact)
            if [[ -z "$proposal_id" ]]; then
                error "Usage: xdc-node governance impact --id ID"
                return 1
            fi
            run_script "governance.sh" "impact $proposal_id"
            ;;
        history)
            run_script "governance.sh" "history"
            ;;
        "")
            run_script "governance.sh" "proposals"
            ;;
        *)
            error "Unknown action: $action"
            cmd_governance --help
            return 1
            ;;
    esac
}

