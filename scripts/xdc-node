#!/usr/bin/env bash
set -euo pipefail

#==============================================================================
# xdc — XDC Network Node Management CLI
# Version: 1.0.0
# Enterprise-grade CLI for managing XDC Network nodes
#==============================================================================

readonly CLI_VERSION="1.0.0"
readonly CLI_NAME="xdc"

# Determine script and project directories
if [[ -L "${BASH_SOURCE[0]}" ]]; then
    SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
else
    SCRIPT_PATH="${BASH_SOURCE[0]}"
fi
readonly CLI_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
readonly PROJECT_DIR="$(dirname "$CLI_DIR")"
readonly SCRIPTS_DIR="${PROJECT_DIR}/scripts"
readonly CONFIGS_DIR="${PROJECT_DIR}/configs"

# Auto-detect INSTALL_DIR
find_install_dir() {
    for d in /opt/xdc-node /opt/xdc "$HOME/.xdc-node" "$HOME/workspace/xdc-node-setup" "$PROJECT_DIR"; do
        [[ -d "$d/docker" ]] && echo "$d" && return
    done
    echo "$PROJECT_DIR"
}
readonly INSTALL_DIR="$(find_install_dir)"

# Detect network from config.toml or environment
detect_network() {
    local network="${NETWORK:-}"
    
    # Try to read from config.toml if it exists
    if [[ -z "$network" && -f "${PROJECT_DIR}/config.toml" ]]; then
        network=$(grep -E '^\s*name\s*=' "${PROJECT_DIR}/config.toml" 2>/dev/null | sed -E 's/.*=\s*"([^"]+)".*/\1/' | head -1)
    fi
    
    # Try XDC_HOME/config.toml as fallback
    if [[ -z "$network" && -f "${XDC_HOME:-/opt/xdc-node}/config.toml" ]]; then
        network=$(grep -E '^\s*name\s*=' "${XDC_HOME:-/opt/xdc-node}/config.toml" 2>/dev/null | sed -E 's/.*=\s*"([^"]+)".*/\1/' | head -1)
    fi
    
    # Default to mainnet
    echo "${network:-mainnet}"
}

# Runtime directories with network-aware defaults
readonly XDC_HOME="${XDC_HOME:-/opt/xdc-node}"
readonly XDC_NETWORK="$(detect_network)"
readonly XDC_DATA="${XDC_DATA:-${PROJECT_DIR}/${XDC_NETWORK}/xdcchain}"
readonly XDC_STATE_DIR="${XDC_STATE_DIR:-${PROJECT_DIR}/${XDC_NETWORK}/.xdc-node}"
readonly XDC_LOGS="${XDC_LOGS:-/var/log}"
readonly XDC_BACKUP="${XDC_BACKUP:-/backup/xdc-node}"

# Default config files
readonly VERSIONS_FILE="${XDC_HOME}/configs/versions.json"
readonly NOTIFY_CONF="${XDC_HOME}/configs/notify.conf"

# Global flags
OUTPUT_JSON=false
QUIET=false
VERBOSE=false
NO_COLOR=false

# Colors (will be disabled if --no-color or not a TTY)
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
GRAY='\033[0;90m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# Spinner characters
readonly SPINNER_CHARS='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'

# First run flag file
readonly FIRST_RUN_FILE="${XDC_HOME}/.xdc-cli-initialized"

#==============================================================================
# Utility Functions
#==============================================================================

setup_colors() {
    if [[ "$NO_COLOR" == "true" ]] || [[ ! -t 1 ]]; then
        RED='' GREEN='' YELLOW='' BLUE='' MAGENTA='' CYAN=''
        WHITE='' GRAY='' BOLD='' DIM='' NC=''
    fi
}

c() {
    local var="${1:-NC}"
    echo -e "${!var:-}"
}

print_banner() {
    if [[ "$QUIET" == "true" ]]; then return; fi
    cat << 'EOF'

    ██╗  ██╗██████╗  ██████╗    ███╗   ██╗ ██████╗ ██████╗ ███████╗
    ╚██╗██╔╝██╔══██╗██╔════╝    ████╗  ██║██╔═══██╗██╔══██╗██╔════╝
     ╚███╔╝ ██║  ██║██║         ██╔██╗ ██║██║   ██║██║  ██║█████╗  
     ██╔██╗ ██║  ██║██║         ██║╚██╗██║██║   ██║██║  ██║██╔══╝  
    ██╔╝ ██╗██████╔╝╚██████╗    ██║ ╚████║╚██████╔╝██████╔╝███████╗
    ╚═╝  ╚═╝╚═════╝  ╚═════╝    ╚═╝  ╚═══╝ ╚═════╝ ╚═════╝ ╚══════╝

EOF
    echo -e "    $(c CYAN)XDC Network Node Management CLI$(c NC) $(c DIM)v${CLI_VERSION}$(c NC)"
    echo ""
}

print_help() {
    cat << EOF
$(c BOLD)xdc$(c NC) — XDC Network Node Management CLI

$(c BOLD)USAGE:$(c NC)
    xdc <command> [options]

$(c BOLD)XDC-SPECIFIC COMMANDS:$(c NC)

    $(c GREEN)masternode$(c NC)     Setup and manage masternode (stake check, keystore, registration)
    $(c GREEN)rewards$(c NC)        Masternode rewards analytics (history, APY, exports)
    $(c GREEN)cluster$(c NC)        Multi-node cluster management (failover, health)
    $(c GREEN)stake$(c NC)          Stake management (delegations, auto-compound, tax)
    $(c GREEN)peers$(c NC)          Optimize peer connections (latency ranking, NAT detection)
    $(c GREEN)snapshot$(c NC)       Manage chain snapshots (download/create/verify)
    $(c GREEN)monitor$(c NC)        XDC-specific monitoring (epoch, rewards, fork detection)
    $(c GREEN)sync$(c NC)           Sync optimization (status, ETA, pruning)
    $(c GREEN)rpc-secure$(c NC)     RPC security hardening (method filtering, rate limits)
    $(c GREEN)network$(c NC)        Network intelligence (peer map, fork readiness, diversity)
    $(c GREEN)consensus$(c NC)      XDPoS v2 consensus monitoring (epoch, rounds, votes, penalties)
    $(c GREEN)network-stats$(c NC)  Network-wide statistics and validator rankings
    $(c GREEN)governance$(c NC)     Governance participation (proposals, voting, history)
    $(c GREEN)marketplace$(c NC)    Verified hosting provider directory

$(c BOLD)CLIENT MANAGEMENT:$(c NC)
    $(c GREEN)client$(c NC)         Show current client information
    $(c GREEN)start --client$(c NC) Start with specific client (stable|geth-pr5|erigon)

$(c BOLD)GENERAL COMMANDS:$(c NC)
    $(c GREEN)init$(c NC)           Interactive setup wizard (wraps setup.sh)
    $(c GREEN)status$(c NC)         Quick node status overview with setup progress
    $(c GREEN)info$(c NC)           Alias for status (node information)
    $(c GREEN)health$(c NC)         Run health check (wraps node-health-check.sh)
    $(c GREEN)security$(c NC)       Run security audit (advisory only, --fix to apply)
    $(c GREEN)heartbeat$(c NC)      Manage SkyNet heartbeat agent (--install, --uninstall)
    $(c GREEN)ssl$(c NC)            Setup SSL/HTTPS for dashboard (--domain, --email)
    $(c GREEN)update$(c NC)         Update node Docker image and restart
    $(c GREEN)snapshot$(c NC)       Download and apply chain snapshot (mainnet/pruned/archive)
    $(c GREEN)backup$(c NC)         Backup chaindata and config to archive
    $(c GREEN)restore$(c NC)        Restore from backup
    $(c GREEN)reset$(c NC)          Reset node and resync (fixes bad blocks)
    $(c GREEN)logs$(c NC)           Tail node logs
    $(c GREEN)restart$(c NC)        Graceful node restart
    $(c GREEN)stop$(c NC)           Stop all XDC containers
    $(c GREEN)start$(c NC)          Start node (auto-detects ports if in use)
    $(c GREEN)addpeers$(c NC)       Add peers from bootnodes.list (manual injection)
    $(c GREEN)attach$(c NC)         Attach to XDC console (IPC first, then RPC fallback)
    $(c GREEN)config$(c NC)         View/edit configuration
    $(c GREEN)notify$(c NC)         Test notifications or send custom alert
    $(c GREEN)dashboard$(c NC)      Start web dashboard
    $(c GREEN)version$(c NC)        Show CLI and client versions
    $(c GREEN)help$(c NC)           Show this help message

$(c BOLD)GLOBAL OPTIONS:$(c NC)
    --json        Output in JSON format
    --quiet       Suppress non-essential output
    --verbose     Show detailed output
    --no-color    Disable colored output
    --rpc URL     Override RPC endpoint URL

$(c BOLD)EXAMPLES:$(c NC)
    xdc init                    # Start interactive setup wizard
    xdc status                  # Show node status with setup progress
    xdc status --watch          # Monitor status in real-time
    xdc start --multi-client    # Run geth AND erigon simultaneously
    xdc start --client erigon   # Start erigon (standalone if geth running)
