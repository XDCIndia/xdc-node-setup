cmd_marketplace() {
    local action="open"
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            open|list)
                action="$1"
                shift
                ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc marketplace$(c NC) — Verified Hosting Provider Directory

$(c BOLD)USAGE:$(c NC)
    xdc marketplace [action]

$(c BOLD)ACTIONS:$(c NC)
    open     Open the hosting provider directory in browser (default)
    list     List verified providers in terminal

$(c BOLD)DESCRIPTION:$(c NC)
    Opens the curated list of verified hosting providers for XDC nodes.
    Includes pricing, recommended specs, and quick-start guides for:
    - Hetzner
    - OVHcloud
    - DigitalOcean
    - AWS
    - Contabo
    - Vultr

$(c BOLD)EXAMPLES:$(c NC)
    xdc marketplace              # Open directory in browser
    xdc marketplace list         # Show providers in terminal

$(c BOLD)SEE ALSO:$(c NC)
    docs/HOSTING-PROVIDERS.md in the repository for full details

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    local doc_url="https://github.com/AnilChinchawale/XDC-Node-Setup/blob/main/docs/HOSTING-PROVIDERS.md"
    
    case "$action" in
        open)
            info "Opening hosting provider directory..."
            info "$doc_url"
            
            # Try to open in browser
            if command -v xdg-open &>/dev/null; then
                xdg-open "$doc_url"
            elif command -v open &>/dev/null; then
                open "$doc_url"
            elif command -v start &>/dev/null; then
                start "$doc_url"
            else
                echo -e "$(c CYAN)$doc_url$(c NC)"
                echo "Please open the URL manually in your browser."
            fi
            ;;
        list)
            echo ""
            echo -e "$(c BOLD)Verified Hosting Providers for XDC Nodes$(c NC)"
            echo -e "$(c DIM)For full details, run: xdc marketplace$(c NC)"
            echo ""
            
            echo -e "$(c CYAN)┌─────────────────────┬──────────────────┬──────────────────────────────────────────────┐$(c NC)"
            echo -e "$(c CYAN)│$(c NC) $(c BOLD)Provider$(c NC)            $(c CYAN)│$(c NC) $(c BOLD)Cheapest Plan$(c NC)    $(c CYAN)│$(c NC) $(c BOLD)Best For$(c NC)                                     $(c CYAN)│$(c NC)"
            echo -e "$(c CYAN)├─────────────────────┼──────────────────┼──────────────────────────────────────────────┤$(c NC)"
            echo -e "$(c CYAN)│$(c NC) Hetzner             $(c CYAN)│$(c NC) €4.51/mo         $(c CYAN)│$(c NC) Budget, EU users, excellent price-performance$(c NC)"
            echo -e "$(c CYAN)│$(c NC) Contabo             $(c CYAN)│$(c NC) €4.99/mo         $(c CYAN)│$(c NC) Best value, large storage allocations        $(c NC)"
            echo -e "$(c CYAN)│$(c NC) DigitalOcean        $(c CYAN)│$(c NC) \$24/mo           $(c CYAN)│$(c NC) Beginners, simple pricing, great docs        $(c NC)"
            echo -e "$(c CYAN)│$(c NC) Vultr               $(c CYAN)│$(c NC) \$20/mo           $(c CYAN)│$(c NC) Flexibility, huge global network             $(c NC)"
            echo -e "$(c CYAN)│$(c NC) OVHcloud            $(c CYAN)│$(c NC) €7/mo            $(c CYAN)│$(c NC) EU compliance, GDPR, anti-DDoS included      $(c NC)"
            echo -e "$(c CYAN)│$(c NC) AWS                 $(c CYAN)│$(c NC) ~\$85/mo          $(c CYAN)│$(c NC) Enterprise, massive infrastructure           $(c NC)"
            echo -e "$(c CYAN)└─────────────────────┴──────────────────┴──────────────────────────────────────────────┘$(c NC)"
            echo ""
            echo -e "$(c BOLD)Recommended Mainnet Specs:$(c NC) 4+ vCPUs, 8GB+ RAM, 500GB+ SSD"
            echo -e "$(c BOLD)Quick Start:$(c NC) Run $(c CYAN)xdc marketplace$(c NC) to view full comparison"
            ;;
    esac
}

#==============================================================================
# Advanced Masternode Commands
#==============================================================================

cmd_rewards() {
    local action="summary"
    local days=30
    local export_format=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            summary|history|apy|missed|slashing|compare)
                action="$1"
                shift
                ;;
            --days|-d)
                days="$2"
                shift 2
                ;;
            --export)
                export_format="$2"
                shift 2
                ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node rewards$(c NC) — Masternode Rewards Analytics

$(c BOLD)USAGE:$(c NC)
    xdc-node rewards [action] [options]

$(c BOLD)ACTIONS:$(c NC)
    summary      Show current period reward summary (default)
    history      Show reward history
    apy          Calculate current APY
    missed       Show missed blocks report
    slashing     Show slashing events
    compare      Compare actual vs expected rewards

$(c BOLD)OPTIONS:$(c NC)
    --days N     Number of days to analyze (default: 30)
    --export FMT Export data (json, csv, pdf)
    --help       Show this help

$(c BOLD)EXAMPLES:$(c NC)
    xdc-node rewards                    # Show summary
    xdc-node rewards history --days 7   # Last 7 days history
    xdc-node rewards apy                # Calculate APY
    xdc-node rewards export csv         # Export to CSV

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    local args="--$action"
    if [[ "$action" == "history" ]]; then
        args="$args --days $days"
    fi
    if [[ -n "$export_format" ]]; then
        args="$args --export $export_format"
    fi
    
    run_script "masternode-rewards.sh" "$args"
}

cmd_cluster() {
    local action="status"
    local node=""
    local cluster_id=""
    local force=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            init|status|health|failover|sync-keys|leader|config|add-node|remove-node|promote|demote)
                action="$1"
                shift
                ;;
            --cluster-id)
                cluster_id="$2"
                shift 2
                ;;
            --node)
                node="$2"
                shift 2
                ;;
            --force)
                force=true
                shift
                ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node cluster$(c NC) — Masternode Cluster Management

$(c BOLD)USAGE:$(c NC)
    xdc-node cluster [action] [options]

$(c BOLD)ACTIONS:$(c NC)
    init         Initialize cluster configuration
    status       Show cluster status (default)
    health       Check health of all nodes
    failover     Perform manual failover
    sync-keys    Sync keys to all nodes
    leader       Show current leader
    config       Show cluster configuration
    add-node     Add a backup node
    remove-node  Remove a node from cluster
    promote      Promote node to primary
    demote       Demote node to backup

$(c BOLD)OPTIONS:$(c NC)
    --cluster-id ID   Set cluster ID
    --node HOST       Target node for operation
    --force           Force operation without confirmation
    --help            Show this help

$(c BOLD)EXAMPLES:$(c NC)
    xdc-node cluster init --cluster-id xdc-mn-001
    xdc-node cluster status
    xdc-node cluster add-node 192.168.1.100
    xdc-node cluster failover --node 192.168.1.101

EOF
                return 0
                ;;
            *) 
                # Handle positional arguments
                if [[ -z "$node" && ! "$1" =~ ^-- ]]; then
                    node="$1"
                fi
                shift
                ;;
        esac
    done
    
    local args=""
    case "$action" in
        init)
            args="init"
            if [[ -n "$cluster_id" ]]; then
                args="$args --cluster-id $cluster_id"
            fi
            ;;
        add-node|remove-node|promote|demote)
            if [[ -z "$node" ]]; then
                error "Node address required. Usage: xdc-node cluster $action <host>"
                return 1
            fi
            args="$action $node"
            if [[ "$force" == "true" ]]; then
                args="$args --force"
            fi
            ;;
        failover)
            args="failover"
            if [[ -n "$node" ]]; then
                args="$args $node"
            fi
            if [[ "$force" == "true" ]]; then
                args="$args --force"
            fi
            ;;
        *)
            args="$action"
            ;;
    esac
    
    run_script "masternode-cluster.sh" "$args"
}

cmd_stake() {
    local action="info"
    local address=""
    local amount=""
    local enabled=""
    local threshold=""
    local year="$(date +%Y)"
    local days="30"
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            info|delegations|compound|compound-status|compound-now|withdraw-plan|tax-report|cost-basis|estimate-rewards|add-delegation|remove-delegation)
                action="$1"
                shift
                ;;
            --address|-a)
                address="$2"
                shift 2
                ;;
            --amount)
                amount="$2"
                shift 2
                ;;
            --enable)
                enabled="on"
                shift
                ;;
            --disable)
                enabled="off"
                shift
                ;;
            --threshold)
                threshold="$2"
                shift 2
                ;;
            --year)
                year="$2"
                shift 2
                ;;
            --days)
                days="$2"
                shift 2
                ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node stake$(c NC) — Stake Management Tools

$(c BOLD)USAGE:$(c NC)
    xdc-node stake [action] [options]

$(c BOLD)ACTIONS:$(c NC)
    info              Show stake information (default)
    delegations       List all delegations
    compound          Enable auto-compound
    compound-status   Show auto-compound status
    compound-now      Trigger compound immediately
    withdraw-plan     Show optimal withdrawal strategy
    tax-report        Generate tax report
    cost-basis        Calculate cost basis
    estimate-rewards  Estimate future rewards
    add-delegation    Add new delegation
    remove-delegation Remove delegation

$(c BOLD)OPTIONS:$(c NC)
    --address ADDR    Masternode/delegator address
    --amount AMT      Stake amount in XDC
    --enable          Enable auto-compound
    --disable         Disable auto-compound
    --threshold AMT   Auto-compound threshold
    --year YYYY       Tax year (default: current)
    --days N          Days for estimation
    --help            Show this help

$(c BOLD)EXAMPLES:$(c NC)
    xdc-node stake                              # Show stake info
    xdc-node stake compound --enable            # Enable auto-compound
    xdc-node stake compound --disable           # Disable auto-compound
    xdc-node stake tax-report --year 2025       # Generate 2025 tax report
    xdc-node stake estimate-rewards --days 90   # Estimate 90-day rewards

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    local args=""
    case "$action" in
        info)
            args="--stake-info"
            ;;
        delegations)
            args="--delegations"
            if [[ -n "$address" ]]; then
                args="$args --address $address"
            fi
            ;;
        compound)
            if [[ -z "$enabled" ]]; then
                enabled="on"
            fi
            args="--compound $enabled"
            if [[ -n "$threshold" ]]; then
                args="$args --threshold $threshold"
            fi
            ;;
        compound-status)
            args="--compound-status"
            ;;
        compound-now)
            args="--compound-now"
            ;;
        withdraw-plan)
            args="--withdraw-plan"
            ;;
        tax-report)
            args="--tax-report $year"
            ;;
        cost-basis)
            args="--cost-basis"
            ;;
        estimate-rewards)
            args="--estimate-rewards $days"
            ;;
        add-delegation)
            if [[ -z "$address" ]]; then
                error "Address required. Usage: xdc-node stake add-delegation --address ADDR [--amount AMT]"
                return 1
            fi
            args="--add-delegation $address"
            if [[ -n "$amount" ]]; then
                args="$args --amount $amount"
            fi
            ;;
        remove-delegation)
            if [[ -z "$address" ]]; then
                error "Address required. Usage: xdc-node stake remove-delegation --address ADDR"
                return 1
            fi
            args="--remove-delegation $address"
            ;;
    esac
    
    run_script "stake-manager.sh" "$args"
}

#==============================================================================
# Command: attach
#==============================================================================
cmd_attach() {
    local target="${1:-}"
    
    # Show help if requested
    if [[ "$target" == "--help" || "$target" == "-h" ]]; then
        cat << EOF
$(c BOLD)xdc attach$(c NC) — Attach to XDC console

$(c BOLD)USAGE:$(c NC)
    xdc attach [rpc-url]

$(c BOLD)DESCRIPTION:$(c NC)
    Attaches to the XDC JavaScript console. Tries IPC first (fastest),
    then falls back to RPC if IPC socket is not available.

$(c BOLD)EXAMPLES:$(c NC)
    xdc attach                      # Auto-detect (IPC preferred)
    xdc attach http://localhost:8545   # Specific RPC endpoint

EOF
        return 0
    fi
    
    local container
    container=$(find_container 2>/dev/null || echo "")
    
    if [[ -n "$container" ]]; then
        # Docker container found - try IPC first (inside container)
        local ipc_path="/work/xdcchain/XDC.ipc"
        
        verbose "Checking for IPC socket in container: $ipc_path"
        if docker exec "$container" test -S "$ipc_path" 2>/dev/null; then
            info "Attaching via IPC: $ipc_path (inside container $container)"
            if ! docker exec -it "$container" XDC attach "$ipc_path" 2>/dev/null; then
                # Try with 'xdc' command instead of 'XDC'
                docker exec -it "$container" xdc attach "$ipc_path" || {
                    error "Failed to attach via IPC"
                    return 1
                }
            fi
        else
            # IPC not available - fall back to RPC
            local rpc_url="${target:-http://xdc-node:8545}"
            warn "IPC socket not found in container, falling back to RPC"
            info "Attaching via RPC: $rpc_url"
            if ! docker exec -it "$container" XDC attach "$rpc_url" 2>/dev/null; then
                # Try with 'xdc' command
                docker exec -it "$container" xdc attach "$rpc_url" || {
                    error "Failed to attach via RPC. Is the node running?"
                    return 1
                }
            fi
        fi
    else
        # No container - try local IPC then RPC
        local ipc_path="${XDC_DATA}/XDC.ipc"
        
        verbose "Checking for local IPC socket: $ipc_path"
        if [[ -S "$ipc_path" ]]; then
            info "Attaching via IPC: $ipc_path"
            if ! XDC attach "$ipc_path" 2>/dev/null; then
                xdc attach "$ipc_path" || {
                    error "Failed to attach via IPC"
                    return 1
                }
            fi
        else
            # IPC not available - fall back to RPC
            local rpc_url="${target:-$(get_rpc_url)}"
            warn "IPC socket not found, falling back to RPC"
            info "Attaching via RPC: $rpc_url"
            if ! XDC attach "$rpc_url" 2>/dev/null; then
                xdc attach "$rpc_url" || {
                    error "Failed to attach via RPC. Is the node running and RPC enabled?"
                    return 1
                }
            fi
        fi
    fi
}

#==============================================================================
# Command: heartbeat
#==============================================================================
cmd_heartbeat() {
    local install=false
    local uninstall=false
    local status=false
    local start=false
    local stop=false
    local node_id=""
    local api_url="https://net.xdc.network/api/v1/nodes"
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --install) install=true; shift ;;
            --uninstall) uninstall=true; shift ;;
            --status) status=true; shift ;;
            --start) start=true; shift ;;
            --stop) stop=true; shift ;;
            --node-id) node_id="$2"; shift 2 ;;
            --api-url) api_url="$2"; shift 2 ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc heartbeat$(c NC) — Manage SkyNet Heartbeat Agent

$(c BOLD)USAGE:$(c NC)
    xdc heartbeat [options]

$(c BOLD)OPTIONS:$(c NC)
    --install        Install heartbeat as a service (auto-detects platform)
    --uninstall      Remove heartbeat service
    --status         Check heartbeat service status
    --start          Start heartbeat service manually
    --stop           Stop heartbeat service manually
    --node-id ID     Set custom node ID for heartbeat
    --api-url URL    Set custom API URL for heartbeat
    --help           Show this help

$(c BOLD)PLATFORM SUPPORT:$(c NC)
    Linux    - Installs systemd timer/service
    macOS    - Installs launchd plist (~/Library/LaunchAgents/)

$(c BOLD)EXAMPLES:$(c NC)
    xdc heartbeat --install                    # Install heartbeat service
    xdc heartbeat --uninstall                  # Remove heartbeat service
    xdc heartbeat --status                     # Check service status
    xdc heartbeat --install --node-id XXX      # Install with custom node ID

$(c BOLD)DESCRIPTION:$(c NC)
    The heartbeat agent sends node status updates to SkyNet every 60 seconds.
    It reports block height, peer count, sync status, and system metrics.

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    # Detect platform
    local platform
    platform=$(uname -s)
    
    # Determine paths based on platform
    local script_dir="${PROJECT_DIR}/scripts"
    local plist_template="${PROJECT_DIR}/configs/macos/com.xdc.heartbeat.plist"
    local user_home="$HOME"
    local launch_agents="${user_home}/Library/LaunchAgents"
    local plist_dest="${launch_agents}/com.xdc.heartbeat.plist"
    local xdc_home="${user_home}/.xdc-node"
    local heartbeat_script="${xdc_home}/heartbeat.sh"
    
    # Handle status check
    if [[ "$status" == "true" ]]; then
        info "Checking heartbeat service status..."
        
        case "$platform" in
            Darwin)
                if [[ -f "$plist_dest" ]]; then
                    echo -e "$(c GREEN)✓$(c NC) LaunchAgent installed: $plist_dest"
                    local svc_status
                    svc_status=$(launchctl list com.xdc.heartbeat 2>&1 || echo "Not loaded")
                    if [[ "$svc_status" != "Not loaded" ]]; then
                        echo -e "$(c GREEN)✓$(c NC) Service loaded in launchctl"
                    else
                        echo -e "$(c YELLOW)⚠$(c NC) Service not loaded in launchctl"
                    fi
                    if [[ -f "${xdc_home}/heartbeat.log" ]]; then
                        echo -e "$(c CYAN)ℹ$(c NC) Recent log entries:"
                        tail -5 "${xdc_home}/heartbeat.log" 2>/dev/null || echo "No log entries yet"
                    fi
                else
                    echo -e "$(c YELLOW)⚠$(c NC) LaunchAgent not installed"
                fi
                ;;
            Linux)
                if systemctl list-units --type=timer 2>/dev/null | grep -q xdc-heartbeat; then
                    systemctl status xdc-heartbeat.timer --no-pager 2>/dev/null || true
                else
                    warn "Systemd timer not found. Heartbeat may not be installed."
                fi
                ;;
        esac
        return 0
    fi
    
    # Handle start
    if [[ "$start" == "true" ]]; then
        case "$platform" in
            Darwin)
                if [[ -f "$plist_dest" ]]; then
                    launchctl load "$plist_dest" 2>/dev/null || true
                    log "Heartbeat service started"
                else
                    die "LaunchAgent not installed. Run: xdc heartbeat --install"
                fi
                ;;
            Linux)
                if systemctl start xdc-heartbeat.timer 2>/dev/null; then
                    log "Heartbeat timer started"
                else
                    die "Failed to start heartbeat timer"
                fi
                ;;
        esac
        return 0
    fi
    
    # Handle stop
    if [[ "$stop" == "true" ]]; then
        case "$platform" in
            Darwin)
                launchctl unload "$plist_dest" 2>/dev/null || true
                log "Heartbeat service stopped"
                ;;
            Linux)
                systemctl stop xdc-heartbeat.timer 2>/dev/null || true
                log "Heartbeat timer stopped"
                ;;
        esac
        return 0
    fi
    
    # Handle uninstall
    if [[ "$uninstall" == "true" ]]; then
        info "Uninstalling heartbeat service..."
        
        case "$platform" in
            Darwin)
                launchctl unload "$plist_dest" 2>/dev/null || true
                [[ -f "$plist_dest" ]] && rm -f "$plist_dest" && log "Removed: $plist_dest"
                [[ -f "$heartbeat_script" ]] && rm -f "$heartbeat_script" && log "Removed: $heartbeat_script"
                log "Heartbeat service uninstalled from macOS"
                ;;
            Linux)
                systemctl stop xdc-heartbeat.timer 2>/dev/null || true
                systemctl disable xdc-heartbeat.timer 2>/dev/null || true
                rm -f /etc/systemd/system/xdc-heartbeat.timer
                rm -f /etc/systemd/system/xdc-heartbeat.service
                systemctl daemon-reload
                log "Heartbeat service uninstalled from Linux"
                ;;
        esac
        return 0
    fi
    
    # Handle install
    if [[ "$install" == "true" ]]; then
        info "Installing heartbeat service on $platform..."
        
        case "$platform" in
            Darwin)
                mkdir -p "$xdc_home" "$launch_agents"
                
                # Generate node ID
                [[ -z "$node_id" ]] && node_id=$(uuidgen 2>/dev/null || python3 -c "import uuid; print(uuid.uuid4())" 2>/dev/null || echo "$(hostname)-$(date +%s)")
                
                # Create simple heartbeat script
                cat > "$heartbeat_script" << EOF
#!/bin/bash
NODE_ID="$node_id"
API_URL="$api_url"
RPC_URL="\${XDC_RPC_URL:-http://127.0.0.1:8545}"

BLOCK_HEX=\$(curl -s -m 5 -X POST "\$RPC_URL" -H "Content-Type: application/json" -d '{"jsonrpc":"2.0","method":"eth_blockNumber","params":[],"id":1}' | python3 -c "import sys,json; print(json.load(sys.stdin).get('result','0x0'))" 2>/dev/null)
BLOCK=\$((16#\${BLOCK_HEX:-0x0}))

echo "[\$(date '+%Y-%m-%d %H:%M:%S')] Heartbeat: block=\$BLOCK" >> "${xdc_home}/heartbeat.log"
EOF
                chmod +x "$heartbeat_script"
                
                # Create plist
                if [[ -f "$plist_template" ]]; then
                    sed -e "s|{{SCRIPT_PATH}}|${heartbeat_script}|g" \
                        -e "s|{{LOG_DIR}}|${xdc_home}|g" \
                        -e "s|{{WORKING_DIR}}|${xdc_home}|g" \
                        "$plist_template" > "$plist_dest"
                else
                    cat > "$plist_dest" << EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.xdc.heartbeat</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>${heartbeat_script}</string>
    </array>
    <key>StartInterval</key>
    <integer>60</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${xdc_home}/heartbeat.log</string>
    <key>StandardErrorPath</key>
    <string>${xdc_home}/heartbeat-error.log</string>
</dict>
</plist>
EOF
                fi
                
                launchctl unload "$plist_dest" 2>/dev/null || true
                launchctl load "$plist_dest"
                
                log "Heartbeat service installed for macOS"
                log "LaunchAgent: $plist_dest"
                ;;
            Linux)
                require_root
                cat > /etc/systemd/system/xdc-heartbeat.service << EOF
[Unit]
Description=XDC SkyNet Heartbeat Agent
After=network.target
[Service]
Type=oneshot
User=${SUDO_USER:-$USER}
ExecStart=${PROJECT_DIR}/scripts/skynet-agent.sh heartbeat
EOF
                cat > /etc/systemd/system/xdc-heartbeat.timer << EOF
[Unit]
Description=XDC SkyNet Heartbeat Timer
[Timer]
OnBootSec=60
OnUnitActiveSec=60
[Install]
WantedBy=timers.target
EOF
                systemctl daemon-reload
                systemctl enable xdc-heartbeat.timer
                systemctl start xdc-heartbeat.timer
                log "Heartbeat service installed for Linux"
                ;;
            *)
                die "Unsupported platform: $platform"
                ;;
        esac
        return 0
    fi
    
    cmd_heartbeat --help
}

#==============================================================================
# Command: ssl
#==============================================================================
cmd_ssl() {
    local domain=""
    local email=""
    local port="7070"
    local staging=false
    local renew=false
    local revoke=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --domain|-d) domain="$2"; shift 2 ;;
            --email|-e) email="$2"; shift 2 ;;
            --port|-p) port="$2"; shift 2 ;;
            --staging|-s) staging=true; shift ;;
            --renew) renew=true; shift ;;
            --revoke) revoke=true; shift ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc ssl$(c NC) — SSL Certificate Management for SkyOne Dashboard

$(c BOLD)USAGE:$(c NC)
    xdc ssl [options]

$(c BOLD)OPTIONS:$(c NC)
    --domain, -d DOMAIN      Domain name (required for new setup)
    --email, -e EMAIL        Email for Let's Encrypt (required)
    --port, -p PORT          Dashboard port (default: 7070)
    --staging, -s            Use Let's Encrypt staging environment
    --renew                  Renew existing certificates
    --revoke                 Revoke certificate (requires --domain)
    --help                   Show this help

$(c BOLD)EXAMPLES:$(c NC)
    xdc ssl --domain dashboard.example.com --email admin@example.com
    xdc ssl --renew
    xdc ssl --domain dashboard.example.com --revoke

$(c BOLD)DESCRIPTION:$(c NC)
    Automates SSL certificate setup using Let's Encrypt and nginx.

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    local ssl_script="${PROJECT_DIR}/scripts/setup-ssl.sh"
    [[ ! -f "$ssl_script" ]] && die "SSL setup script not found: $ssl_script"
    
    local args=()
    [[ -n "$domain" ]] && args+=("--domain" "$domain")
    [[ -n "$email" ]] && args+=("--email" "$email")
    [[ "$port" != "7070" ]] && args+=("--port" "$port")
    [[ "$staging" == "true" ]] && args+=("--staging")
    [[ "$renew" == "true" ]] && args+=("--renew")
    [[ "$revoke" == "true" ]] && args+=("--revoke")
    
    if [[ $EUID -ne 0 ]]; then
        sudo bash "$ssl_script" ${args[@]+"${args[@]}"}
    else
        bash "$ssl_script" ${args[@]+"${args[@]}"}
    fi
}

#==============================================================================
# Main Entry Point
#==============================================================================
main() {
    # Parse global options first
    local args=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) OUTPUT_JSON=true; shift ;;
            --quiet|-q) QUIET=true; shift ;;
            --verbose|-v) VERBOSE=true; shift ;;
            --no-color) NO_COLOR=true; shift ;;
            --rpc)
                export XDC_RPC_URL="$2"
                shift 2
                ;;
            *) args+=("$1"); shift ;;
        esac
    done
    set -- ${args[@]+"${args[@]}"}
    
    setup_colors
    
    # No command given
    if [[ $# -eq 0 ]]; then
        first_run_check
        print_help
        exit 0
    fi
    
    local command="$1"
    shift
    
    case "$command" in
        # XDC-specific commands
        masternode)   cmd_masternode "$@" ;;
        peers)        cmd_peers "$@" ;;
        snapshot)     cmd_snapshot "$@" ;;
        monitor)      cmd_monitor "$@" ;;
        sync)         cmd_sync "$@" ;;
        rpc-secure)   cmd_rpc_secure "$@" ;;
        network)      cmd_network "$@" ;;
        consensus)    cmd_consensus "$@" ;;
        network-stats) cmd_network_stats "$@" ;;
        governance)   cmd_governance "$@" ;;
        marketplace)  cmd_marketplace "$@" ;;
        
        # Advanced masternode commands
        rewards)      cmd_rewards "$@" ;;
        cluster)      cmd_cluster "$@" ;;
        stake)        cmd_stake "$@" ;;
        addpeers|addpeer)     cmd_peers "add" "$@" ;;
        attach)     cmd_attach "$@" ;;
        
        # Monitoring & SSL commands (Issues #50, #51)
        heartbeat)  cmd_heartbeat "$@" ;;
        ssl)        cmd_ssl "$@" ;;
        
        # Interactive tutorials (Issue #43)
        demo)       source "${CLI_DIR}/commands/demo.sh"; main "$@" ;;
        
        # General commands
        init)       cmd_init "$@" ;;
        status)     cmd_status "$@" ;;
        info)       cmd_status "$@" ;;  # Alias for status
        health)     cmd_health "$@" ;;
        security)   cmd_security "$@" ;;
        update)     cmd_update "$@" ;;
        backup)     cmd_backup "$@" ;;
        restore)    cmd_restore "$@" ;;
        reset)      cmd_reset "$@" ;;
        logs)       cmd_logs "$@" ;;
        restart)    cmd_restart "$@" ;;
        stop)       cmd_stop "$@" ;;
        start)      cmd_start "$@" ;;
        config)     cmd_config "$@" ;;
        notify)     cmd_notify "$@" ;;
        dashboard)  cmd_dashboard "$@" ;;
        version)    cmd_version "$@" ;;
        client)     cmd_client "$@" ;;
        help|--help|-h)
            if [[ $# -gt 0 ]]; then
                # Show help for specific command: xdc help <command>
                case "$1" in
                    init)       cmd_init --help ;;
                    status|info) cmd_status --help ;;
                    health)     cmd_health --help ;;
                    security)   cmd_security --help ;;
                    update)     cmd_update --help ;;
                    backup)     cmd_backup --help ;;
                    restore)    cmd_restore --help ;;
                    logs)       cmd_logs --help ;;
                    restart)    cmd_restart --help ;;
                    stop)       cmd_stop --help ;;
                    start)      cmd_start --help ;;
                    config)     cmd_config --help ;;
                    notify)     cmd_notify --help ;;
                    dashboard)  cmd_dashboard --help ;;
                    version)    cmd_version --help ;;
                    client)     cmd_client --help ;;
                    attach)     cmd_attach --help ;;
                    masternode) cmd_masternode --help ;;
                    peers)      cmd_peers --help ;;
                    snapshot)   cmd_snapshot --help ;;
                    monitor)    cmd_monitor --help ;;
                    sync)       cmd_sync --help ;;
                    rpc-secure) cmd_rpc_secure --help ;;
                    network)    cmd_network --help ;;
                    consensus)  cmd_consensus --help ;;
                    network-stats) cmd_network_stats --help ;;
                    governance) cmd_governance --help ;;
                    rewards)    cmd_rewards --help ;;
                    cluster)    cmd_cluster --help ;;
                    stake)      cmd_stake --help ;;
                    heartbeat)  cmd_heartbeat --help ;;
                    ssl)        cmd_ssl --help ;;
                    demo)       source "${CLI_DIR}/commands/demo.sh"; main --help ;;
                    *)          echo "No detailed help available for: $1"; echo "Run 'xdc --help' for general usage." ;;
                esac
            else
                print_help
            fi
            ;;
        *)
            error "Unknown command: $command"
            echo ""
            print_help
            exit 1
            ;;
    esac
}

# Run main
main "$@"
