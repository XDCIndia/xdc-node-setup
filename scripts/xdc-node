#==============================================================================
# XDPoS v2 Deep Integration Commands
#==============================================================================

cmd_consensus() {
    local action="all"
    local args=""
    local watch_mode=false
    local watch_interval=5
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            epoch|rounds|votes|finality|rotation|penalties|all)
                action="$1"
                shift
                ;;
            --watch)
                watch_mode=true
                if [[ -n "${2:-}" && ! "$2" =~ ^- ]]; then
                    watch_interval="$2"
                    shift
                fi
                shift
                ;;
            --json)
                args="$args --json"
                shift
                ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node consensus$(c NC) — XDPoS Consensus Monitoring

$(c BOLD)USAGE:$(c NC)
    xdc-node consensus [action] [options]

$(c BOLD)ACTIONS:$(c NC)
    epoch        Show current epoch information and progress
    rounds       Show round tracking and timeline
    votes        Monitor recent vote counts per block
    finality     Show block finality status
    rotation     Display masternode rotation schedule
    penalties    Show active penalties and slashing events
    all          Run all consensus checks (default)

$(c BOLD)OPTIONS:$(c NC)
    --watch [N]  Continuous monitoring mode (default: 5s interval)
    --json       Output in JSON format
    --help       Show this help

$(c BOLD)EXAMPLES:$(c NC)
    xdc-node consensus              # Show all consensus info
    xdc-node consensus epoch        # Show epoch info only
    xdc-node consensus --watch 10   # Watch mode with 10s updates
    xdc-node consensus all --json   # JSON output

$(c BOLD)DESCRIPTION:$(c NC)
    Monitor XDPoS v2 consensus in real-time:
    - Track epochs (900 blocks, ~30 minutes)
    - Monitor rounds within epoch
    - View vote counts for recent blocks
    - Check block finality
    - See masternode rotation schedule
    - Track penalties and slashing events

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    if [[ "$watch_mode" == "true" ]]; then
        run_script "consensus-monitor.sh" "--watch $watch_interval"
    else
        run_script "consensus-monitor.sh" "--$action $args"
    fi
}

