    if [[ ! -f "$docker_compose" ]]; then
        warn "No XDC node configuration found at $config_dir"
        info "Running install.sh to set up your node..."
        
        # Find install.sh
        local install_script=""
        for path in "$config_dir/install.sh" "$PROJECT_DIR/install.sh" "$HOME/xdc-node-setup/install.sh" "./install.sh"; do
            if [[ -f "$path" ]]; then
                install_script="$path"
                break
            fi
        done
        
        if [[ -z "$install_script" ]]; then
            # Download install.sh
            info "Downloading install.sh..."
            install_script="/tmp/xdc-install.sh"
            if curl -fsSL "https://raw.githubusercontent.com/AnilChinchawale/xdc-node-setup/main/install.sh" -o "$install_script" 2>/dev/null; then
                chmod +x "$install_script"
            else
                die "Failed to download install.sh. Please run setup manually."
            fi
        fi
        
        # Run install.sh
        log "Running $install_script..."
        if bash "$install_script"; then
            log "Installation complete. Starting node..."
        else
            die "Installation failed. Please check the output above."
        fi
    fi
    
    # Try Docker first
    local container
    if container=$(find_container) && [[ -n "$container" ]]; then
        info "Found Docker container: $container"
        start_spinner "Starting Docker container"
        
        if docker start "$container" >/dev/null 2>&1; then
            stop_spinner true "Container started"
            log "Docker container $container started"
            
            # Wait a moment for RPC to be available
            sleep 3
            
            # Inject peers if needed
            inject_peers || true
            return 0
        else
            stop_spinner false "Start failed"
            die "Failed to start Docker container $container"
        fi
    fi
    
    # Try to start via docker compose
    if [[ -f "$docker_compose" ]]; then
        info "Starting with docker compose..."
        start_spinner "Starting XDC node"
        
        cd "$(dirname "$docker_compose")" || die "Failed to change to docker directory"
        
        if docker compose up -d xdc-node xdc-dashboard 2>/dev/null; then
            stop_spinner true "Node started"
            log "XDC node started via docker compose"
            
            # Wait for RPC
            sleep 5
            
            # Inject peers
            inject_peers || true
            return 0
        else
            stop_spinner false "Start failed"
            die "Failed to start XDC node. Check 'docker compose logs' for details."
        fi
    fi
    
    # Fall back to systemctl
    require_root
    
    local service
    service=$(detect_service)
    
    if [[ -z "$service" ]]; then
        die "No XDC node service or Docker container found"
    fi
    
    start_spinner "Starting node"
    
    if systemctl start "$service"; then
        stop_spinner true "Node started"
        log "Node $service started"
        
        # Wait a moment for RPC to be available
        sleep 3
        
        # Inject peers if needed
        inject_peers || true
    else
        stop_spinner false "Start failed"
        die "Failed to start $service"
    fi
}

#==============================================================================
# Command: config
#==============================================================================
cmd_config() {
    local action=""
    local key=""
    local value=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            list|get|set)
                action="$1"
                shift
                if [[ "$action" == "get" || "$action" == "set" ]]; then
                    key="${1:-}"
                    shift || true
                fi
                if [[ "$action" == "set" ]]; then
                    value="${1:-}"
                    shift || true
                fi
                ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node config$(c NC) — View/edit configuration

$(c BOLD)USAGE:$(c NC)
    xdc-node config list
    xdc-node config get <key>
    xdc-node config set <key> <value>

$(c BOLD)OPTIONS:$(c NC)
    --json    Output in JSON format
    --help    Show this help

$(c BOLD)KEYS:$(c NC)
    rpc_url              RPC endpoint URL
    network              Network (mainnet/testnet)
    client               Client name
    auto_update          Enable auto-updates (true/false)
    telegram_enabled     Enable Telegram notifications
    telegram_bot_token   Telegram bot token
    telegram_chat_id     Telegram chat ID

$(c BOLD)EXAMPLES:$(c NC)
    xdc-node config list
    xdc-node config get network
    xdc-node config set telegram_enabled true

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    case "$action" in
        list)
            if [[ "$OUTPUT_JSON" == "true" ]]; then
                cat "$VERSIONS_FILE" 2>/dev/null || echo '{}'
            else
                if [[ -f "$VERSIONS_FILE" ]]; then
                    echo -e "$(c BOLD)Configuration (versions.json):$(c NC)"
                    echo ""
                    jq '.' "$VERSIONS_FILE" 2>/dev/null || cat "$VERSIONS_FILE"
                else
                    warn "Config file not found: $VERSIONS_FILE"
                fi
            fi
            ;;
        get)
            if [[ -z "$key" ]]; then
                die "Please specify a key. Run 'xdc-node config --help' for available keys."
            fi
            local result
            result=$(get_config ".$key" "")
            if [[ -n "$result" ]]; then
                echo "$result"
            else
                die "Key not found: $key"
            fi
            ;;
        set)
            if [[ -z "$key" || -z "$value" ]]; then
                die "Please specify key and value. Usage: xdc-node config set <key> <value>"
            fi
            require_root
            
            if [[ -f "$VERSIONS_FILE" ]]; then
                local tmp_file
                tmp_file=$(mktemp)
                jq ".$key = \"$value\"" "$VERSIONS_FILE" > "$tmp_file" && mv "$tmp_file" "$VERSIONS_FILE"
                log "Set $key = $value"
            else
                die "Config file not found: $VERSIONS_FILE"
            fi
            ;;
        *)
            die "Unknown action. Use: list, get, or set"
            ;;
    esac
}

#==============================================================================
# Command: notify
#==============================================================================
cmd_notify() {
    local test=false
    local message=""
    local level="info"
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --test) test=true; shift ;;
            --send) message="$2"; shift 2 ;;
            --level) level="$2"; shift 2 ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node notify$(c NC) — Test notifications or send custom alert

$(c BOLD)USAGE:$(c NC)
    xdc-node notify [options]

$(c BOLD)OPTIONS:$(c NC)
    --test             Test all configured notification channels
    --send "message"   Send a custom notification
    --level LEVEL      Notification level (critical, warning, info)
    --help             Show this help

$(c BOLD)EXAMPLES:$(c NC)
    xdc-node notify --test
    xdc-node notify --send "Node maintenance complete" --level info

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    local notify_script="${SCRIPTS_DIR}/lib/notify.sh"
    local test_script="${SCRIPTS_DIR}/notify-test.sh"
    
    if [[ "$test" == "true" ]]; then
        if [[ -f "$test_script" ]]; then
            info "Testing notification channels..."
            bash "$test_script"
        else
            die "Notification test script not found"
        fi
    elif [[ -n "$message" ]]; then
        if [[ -f "$notify_script" ]]; then
            # shellcheck source=/dev/null
            source "$notify_script"
            
            case "$level" in
                critical) notify_alert "critical" "🚨 Alert" "$message" "cli_alert" ;;
                warning)  notify_alert "warning" "⚠️ Warning" "$message" "cli_alert" ;;
                *)        notify_alert "info" "ℹ️ Info" "$message" "cli_alert" ;;
            esac
            
            log "Notification sent: $message"
        else
            die "Notification library not found"
        fi
    else
        die "Please specify --test or --send \"message\""
    fi
}

