#==============================================================================
# Command: restore
#==============================================================================
cmd_restore() {
    local backup_file=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node restore$(c NC) — Restore from backup

$(c BOLD)USAGE:$(c NC)
    xdc-node restore <backup-file>

$(c BOLD)OPTIONS:$(c NC)
    --help    Show this help

$(c BOLD)DESCRIPTION:$(c NC)
    Restores node data from a backup archive.
    Verifies integrity before restoration.

$(c BOLD)EXAMPLE:$(c NC)
    xdc-node restore /backup/xdc-node/daily/xdc-backup-2024-01-15.tar.gz

EOF
                return 0
                ;;
            -*) shift ;;
            *) backup_file="$1"; shift ;;
        esac
    done
    
    require_root
    
    if [[ -z "$backup_file" ]]; then
        die "Please specify a backup file. Run 'xdc-node backup --list' to see available backups."
    fi
    
    if [[ ! -f "$backup_file" ]]; then
        die "Backup file not found: $backup_file"
    fi
    
    if [[ "$QUIET" != "true" ]]; then
        print_banner
        echo -e "$(c BOLD)Restore from Backup$(c NC)"
        echo ""
    fi
    
    info "Backup file: $backup_file"
    
    # Verify integrity
    start_spinner "Verifying backup integrity"
    if tar -tzf "$backup_file" &>/dev/null; then
        stop_spinner true "Backup integrity verified"
    else
        stop_spinner false "Backup integrity check failed"
        die "Backup file is corrupted or invalid"
    fi
    
    # Confirmation
    echo ""
    warn "This will overwrite current node data!"
    read -p "Are you sure you want to continue? [y/N] " -n 1 -r
    echo ""
    
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        info "Restore cancelled"
        return 0
    fi
    
    # Stop node
    info "Stopping node..."
    cmd_stop
    
    # Restore
    start_spinner "Restoring data"
    
    local restore_dir="${XDC_DATA}"
    mkdir -p "$restore_dir"
    tar -xzf "$backup_file" -C "$restore_dir"
    
    stop_spinner true "Data restored"
    
    # Start node
    info "Starting node..."
    cmd_start
    
    log "Restore completed successfully"
}

#==============================================================================
# Command: logs
#==============================================================================
cmd_logs() {
    local lines=50
    local follow=false
    local client=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --lines|-n) lines="$2"; shift 2 ;;
            --follow|-f) follow=true; shift ;;
            --client) client="$2"; shift 2 ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node logs$(c NC) — Tail node logs

$(c BOLD)USAGE:$(c NC)
    xdc-node logs [options]

$(c BOLD)OPTIONS:$(c NC)
    --lines, -n N    Number of lines to show (default: 50)
    --follow, -f     Follow log output (like tail -f)
    --client NAME    Specific client logs (geth, erigon)
    --help           Show this help

$(c BOLD)EXAMPLE:$(c NC)
    xdc-node logs -f -n 100

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    # Find log files
    local log_file=""
    local possible_logs=(
        "/var/log/xdc-node.log"
        "/var/log/xdcchain.log"
        "${XDC_DATA}/xdc.log"
        "${XDC_DATA}/geth.log"
        "${XDC_DATA}/erigon.log"
    )
    
    for log in "${possible_logs[@]}"; do
        if [[ -f "$log" ]]; then
            log_file="$log"
            break
        fi
    done
    
    # Also check journalctl
    local service
    service=$(detect_service)
    
    if [[ -n "$service" ]]; then
        if [[ "$follow" == "true" ]]; then
            journalctl -u "$service" -n "$lines" -f
        else
            journalctl -u "$service" -n "$lines" --no-pager
        fi
    elif [[ -n "$log_file" ]]; then
        if [[ "$follow" == "true" ]]; then
            tail -n "$lines" -f "$log_file"
        else
            tail -n "$lines" "$log_file"
        fi
    else
        die "No log files found. Is the node running?"
    fi
}

#==============================================================================
# Command: restart
#==============================================================================
cmd_restart() {
    local graceful=true
    local force=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --graceful) graceful=true; shift ;;
            --force) graceful=false; force=true; shift ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node restart$(c NC) — Graceful node restart

$(c BOLD)USAGE:$(c NC)
    xdc-node restart [options]

$(c BOLD)OPTIONS:$(c NC)
    --graceful   Wait for current block before restart (default)
    --force      Immediate restart
    --help       Show this help

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    # Try Docker first
    local container
    if container=$(find_container) && [[ -n "$container" ]]; then
        info "Found Docker container: $container"
        
        if [[ "$graceful" == "true" && "$force" != "true" ]]; then
            info "Performing graceful restart..."
            start_spinner "Waiting for block finalization"
            sleep 2
            stop_spinner true "Block finalized"
        fi
        
        start_spinner "Restarting container"
        
        if docker restart "$container" >/dev/null 2>&1; then
            stop_spinner true "Container restarted"
            log "Docker container $container restarted successfully"
            
            # Wait a moment for RPC to be available
            sleep 3
            
            # Inject peers if needed
            inject_peers || true
            return 0
        else
            stop_spinner false "Restart failed"
            die "Failed to restart Docker container $container"
        fi
    fi
    
    # Fall back to systemctl
    require_root
    
    local service
    service=$(detect_service)
    
    if [[ -z "$service" ]]; then
        die "No XDC node service or Docker container found"
    fi
    
    if [[ "$graceful" == "true" && "$force" != "true" ]]; then
        info "Performing graceful restart..."
        start_spinner "Waiting for block finalization"
        sleep 2
        stop_spinner true "Block finalized"
    fi
    
    start_spinner "Restarting node"
    
    if systemctl restart "$service"; then
        stop_spinner true "Node restarted"
        log "Node $service restarted successfully"
        
        # Wait a moment for RPC to be available
        sleep 3
        
        # Inject peers if needed
        inject_peers || true
    else
        stop_spinner false "Restart failed"
        die "Failed to restart $service"
    fi
}

#==============================================================================
# Command: stop
#==============================================================================
cmd_stop() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node stop$(c NC) — Stop all XDC node containers

$(c BOLD)USAGE:$(c NC)
    xdc-node stop

$(c BOLD)DESCRIPTION:$(c NC)
    Stops all XDC-related Docker containers including:
    - xdc-node (main blockchain node)
    - xdc-dashboard (web dashboard)
    - skynet-agent (fleet monitoring)
    - xdc-metrics-collector (metrics collection)

$(c BOLD)OPTIONS:$(c NC)
    --help    Show this help

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    # Find and stop all XDC-related containers
    local containers
    containers=$(docker ps -q --filter "name=xdc" --filter "name=skynet" 2>/dev/null || true)
    
    if [[ -n "$containers" ]]; then
        local count
        count=$(echo "$containers" | wc -l)
        info "Found $count XDC container(s)"
        start_spinner "Stopping all XDC containers"
        
        if docker stop $containers >/dev/null 2>&1; then
            stop_spinner true "All containers stopped"
            log "Stopped $count XDC container(s)"
        else
            stop_spinner false "Some containers failed to stop"
            warn "Some containers may not have stopped cleanly"
        fi
        return 0
    fi
    
    # Try specific container names as fallback
    local specific_containers="xdc-node xdc-dashboard skynet-agent xdc-metrics-collector"
    local found_any=false
    
    for container in $specific_containers; do
        if docker ps -q --filter "name=$container" | grep -q .; then
            found_any=true
            start_spinner "Stopping $container"
            if docker stop "$container" >/dev/null 2>&1; then
                stop_spinner true "$container stopped"
            else
                stop_spinner false "Failed to stop $container"
            fi
        fi
    done
    
    if [[ "$found_any" == "false" ]]; then
        # Fall back to systemctl
        require_root
        local service
        service=$(detect_service)
        
        if [[ -z "$service" ]]; then
            warn "No XDC node service or Docker container found"
            return 0
        fi
        
        start_spinner "Stopping node"
        
        if systemctl stop "$service"; then
            stop_spinner true "Node stopped"
            log "Node $service stopped"
        else
            stop_spinner false "Stop failed"
            die "Failed to stop $service"
        fi
    fi
}

