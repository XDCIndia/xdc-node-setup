cmd_stop() {
    local show_help=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h) show_help=true; shift ;;
            *) shift ;;
        esac
    done
    
    if [[ "$show_help" == true ]]; then
        cat << EOF
${CYAN}${BOLD}xdc stop${NC} — Stop the XDC node

${BOLD}USAGE:${NC}
    xdc stop

EOF
        return 0
    fi
    
    info "Stopping XDC node..."
    _get_container
    if docker stop "${XDC_CONTAINER:-xdc-node}" 2>/dev/null; then
        log "Node stopped successfully"
    else
        warn "Node may already be stopped or container not found"
    fi
}

cmd_start() {
    local show_help=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h) show_help=true; shift ;;
            *) shift ;;
        esac
    done
    
    if [[ "$show_help" == true ]]; then
        cat << EOF
${CYAN}${BOLD}xdc start${NC} — Start the XDC node

${BOLD}USAGE:${NC}
    xdc start

EOF
        return 0
    fi
    
    info "Starting XDC node..."
    
    # Find the XDC node container (try common names)
    local container=""
    for name in xdc-node xdc xdcchain mainnet-node; do
        if docker ps -a --format '{{.Names}}' | grep -q "^${name}$"; then
            container="$name"
            break
        fi
    done
    
    if [[ -z "$container" ]]; then
        # Try docker compose
        if [[ -d "$INSTALL_DIR/docker" ]]; then
            info "Starting via docker compose..."
            local output
            output=$(cd "$INSTALL_DIR/docker" && docker compose up -d 2>&1) || true
            if echo "$output" | grep -qi "port is already allocated\|address already in use\|Bind for"; then
                warn "Port conflict detected. Attempting to resolve..."
                # Find conflicting port and increment
                local conflict_port
                conflict_port=$(echo "$output" | grep -oP '0\.0\.0\.0:\K\d+' | head -1)
                if [[ -n "$conflict_port" ]]; then
                    local new_port=$((conflict_port + 1))
                    warn "Port $conflict_port in use, trying $new_port..."
                    # Update compose file
                    sed -i "s/${conflict_port}:/${new_port}:/" "$INSTALL_DIR/docker/docker-compose.yml"
                    (cd "$INSTALL_DIR/docker" && docker compose up -d 2>&1) && log "Node started on port $new_port" || error "Still failed. Check ports manually."
                fi
            elif echo "$output" | grep -qi "error\|fail"; then
                error "Failed to start: $output"
            else
                log "Node started successfully"
            fi
        else
            error "No XDC node container found. Run setup first: bash install.sh"
        fi
        return
    fi
    
    # Try starting existing container
    local output
    output=$(docker start "$container" 2>&1) || true
    if echo "$output" | grep -qi "^${container}$" && docker ps --format '{{.Names}}' | grep -q "^${container}$"; then
        log "Node started ($container)"
    elif echo "$output" | grep -qi "port is already allocated\|address already in use"; then
        warn "Port conflict detected. Stopping conflicting container..."
        # Get the port and find who's using it
        local conflict_port
        conflict_port=$(echo "$output" | grep -oP ':\K\d+' | head -1)
        if [[ -n "$conflict_port" ]]; then
            local blocker
            blocker=$(docker ps --format '{{.Names}}' --filter "publish=$conflict_port" | head -1)
            if [[ -n "$blocker" && "$blocker" != "$container" ]]; then
                warn "Port $conflict_port used by '$blocker'"
            fi
            # Try with docker compose and port+1
            if [[ -d "$INSTALL_DIR/docker" ]]; then
                local new_port=$((conflict_port + 1))
                warn "Retrying with port $new_port..."
                sed -i "s/${conflict_port}:/${new_port}:/" "$INSTALL_DIR/docker/docker-compose.yml"
                docker rm -f "$container" 2>/dev/null
                (cd "$INSTALL_DIR/docker" && docker compose up -d 2>&1) && log "Node started on port $new_port" || error "Still failed."
            fi
        fi
    else
        error "Failed: $output"
    fi
}

cmd_restart() {
    local show_help=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h) show_help=true; shift ;;
            *) shift ;;
        esac
    done
    
    if [[ "$show_help" == true ]]; then
        cat << EOF
${CYAN}${BOLD}xdc restart${NC} — Restart the XDC node

${BOLD}USAGE:${NC}
    xdc restart

EOF
        return 0
    fi
    
    info "Restarting XDC node..."
    _get_container
    if docker restart "${XDC_CONTAINER:-xdc-node}" 2>/dev/null; then
        log "Node restarted successfully"
    else
        error "Failed to restart node"
        exit 1
    fi
}

#==============================================================================
# Command: update
