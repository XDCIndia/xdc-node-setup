fi
readonly CLI_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
readonly PROJECT_DIR="$(dirname "$CLI_DIR")"
readonly SCRIPTS_DIR="${PROJECT_DIR}/scripts"
readonly CONFIGS_DIR="${PROJECT_DIR}/configs"

# Runtime directories
