cmd_security() {
    local show_help=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h) show_help=true; shift ;;
            *) shift ;;
        esac
    done
    
    if [[ "$show_help" == true ]]; then
        cat << EOF
${CYAN}${BOLD}xdc security${NC} — Server security score

${BOLD}USAGE:${NC}
    xdc security

${BOLD}CHECKS:${NC}
    • SSH port configuration
    • Root login enabled
    • UFW firewall status
    • fail2ban status
    • RPC exposure
    • Auto-updates enabled
    • Password authentication
    • Docker user privileges
    • Weak passwords
    • SSL/TLS issues

${BOLD}OUTPUT:${NC}
    Security score 0-100 with color coding and recommendations

EOF
        return 0
    fi
    
    echo -e "${CYAN}${BOLD}Security Audit${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    
    local score=100
    
    # Check SSH port
    printf "  %-45s " "SSH Port (non-default):"
    local ssh_port
    ssh_port=$(grep -E "^Port\s+" /etc/ssh/sshd_config 2>/dev/null | awk '{print $2}' || echo "22")
    if [[ "$ssh_port" != "22" && -n "$ssh_port" ]]; then
        echo -e "${GREEN}${CHECK} Port $ssh_port${NC}"
    else
        echo -e "${RED}${CROSS} Using default port 22${NC}"
        echo -e "      ${YELLOW}→ Recommendation: Change SSH port in /etc/ssh/sshd_config${NC}"
        score=$((score - 10))
    fi
    
    # Check root login
    printf "  %-45s " "Root login disabled:"
    if grep -qE "^PermitRootLogin\s+no" /etc/ssh/sshd_config 2>/dev/null; then
        echo -e "${GREEN}${CHECK} Disabled${NC}"
    else
        echo -e "${RED}${CROSS} Enabled or not explicitly disabled${NC}"
        echo -e "      ${YELLOW}→ Recommendation: Set 'PermitRootLogin no' in /etc/ssh/sshd_config${NC}"
        score=$((score - 10))
    fi
    
    # Check UFW
    printf "  %-45s " "UFW Firewall enabled:"
    if command -v ufw > /dev/null 2>&1 && ufw status 2>/dev/null | grep -q "Status: active"; then
        echo -e "${GREEN}${CHECK} Active${NC}"
    else
        echo -e "${RED}${CROSS} Not active${NC}"
        echo -e "      ${YELLOW}→ Recommendation: Enable UFW with 'ufw enable'${NC}"
        score=$((score - 15))
    fi
    
    # Check fail2ban
    printf "  %-45s " "fail2ban installed:"
    if command -v fail2ban-client > /dev/null 2>&1 && systemctl is-active fail2ban > /dev/null 2>&1; then
        echo -e "${GREEN}${CHECK} Active${NC}"
    else
        echo -e "${RED}${CROSS} Not active${NC}"
        echo -e "      ${YELLOW}→ Recommendation: Install and enable fail2ban${NC}"
        score=$((score - 10))
    fi
    
    # Check RPC exposure
    printf "  %-45s " "RPC not exposed to 0.0.0.0:"
    local rpc_exposed=false
    if docker inspect xdc 2>/dev/null | grep -qE '"0\.0\.0\.0:(8545|9545)"'; then
        rpc_exposed=true
    fi
    if [[ "$rpc_exposed" == false ]]; then
        echo -e "${GREEN}${CHECK} RPC bound to localhost only${NC}"
    else
        echo -e "${RED}${CROSS} RPC exposed to 0.0.0.0${NC}"
        echo -e "      ${YELLOW}→ Recommendation: Bind RPC to 127.0.0.1 only${NC}"
        score=$((score - 15))
    fi
    
    # Check auto-updates
    printf "  %-45s " "Automatic security updates:"
    if [[ -f /etc/apt/apt.conf.d/50unattended-upgrades ]] || systemctl is-enabled unattended-upgrades > /dev/null 2>&1; then
        echo -e "${GREEN}${CHECK} Enabled${NC}"
    else
        echo -e "${RED}${CROSS} Not enabled${NC}"
        echo -e "      ${YELLOW}→ Recommendation: Enable unattended-upgrades${NC}"
        score=$((score - 5))
    fi
    
    # Check password auth
    printf "  %-45s " "Password authentication disabled:"
    if grep -qE "^PasswordAuthentication\s+no" /etc/ssh/sshd_config 2>/dev/null; then
        echo -e "${GREEN}${CHECK} Disabled${NC}"
    else
        echo -e "${RED}${CROSS} Enabled${NC}"
        echo -e "      ${YELLOW}→ Recommendation: Use SSH keys, disable password auth${NC}"
        score=$((score - 10))
    fi
    
    # Check Docker root
    printf "  %-45s " "Docker not running as root (check):"
    if [[ -S /var/run/docker.sock ]]; then
        local docker_root_check
        docker_root_check=$(docker info --format '{{json .SecurityOptions}}' 2>/dev/null | tr -d '\n' | grep -c "rootless" || true)
        docker_root_check=${docker_root_check:-0}
        if [[ "$docker_root_check" -gt 0 ]]; then
            echo -e "${GREEN}${CHECK} Rootless mode${NC}"
        else
            echo -e "${YELLOW}${CROSS} Running as root (common)${NC}"
            echo -e "      ${YELLOW}→ Recommendation: Consider rootless Docker mode${NC}"
            score=$((score - 5))
        fi
    else
        echo -e "${YELLOW}${CROSS} Cannot determine${NC}"
        score=$((score - 5))
    fi
    
    # Check for weak passwords (basic check)
    printf "  %-45s " "Weak password check:"
    if [[ -f /etc/shadow ]]; then
        # This is a simplified check - real implementation would use cracklib
        echo -e "${GREEN}${CHECK} Manual review required${NC}"
    else
        echo -e "${YELLOW}${CROSS} Cannot check${NC}"
    fi
    
    # SSL/TLS check for any web services
    printf "  %-45s " "SSL/TLS configuration:"
    if command -v openssl > /dev/null 2>&1; then
        # Check if any certs are expired or weak
        local ssl_issues=0
        for cert in /etc/ssl/certs/*.pem; do
            [[ -f "$cert" ]] || continue
            if openssl x509 -in "$cert" -noout -checkend 0 > /dev/null 2>&1; then
                : # Cert is valid
            else
                ssl_issues=$((ssl_issues + 1))
            fi
        done
        if [[ "$ssl_issues" -eq 0 ]]; then
            echo -e "${GREEN}${CHECK} No obvious issues${NC}"
        else
            echo -e "${RED}${CROSS} $ssl_issues certificate issues found${NC}"
            score=$((score - 10))
        fi
    else
        echo -e "${YELLOW}${CROSS} Cannot check (openssl not installed)${NC}"
    fi
    
    # Print score
    echo ""
    echo "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    printf "  ${BOLD}Security Score: "
    if [[ $score -gt 80 ]]; then
        echo -e "${GREEN}${score}/100${NC}${BOLD} (Good)${NC}"
    elif [[ $score -ge 60 ]]; then
        echo -e "${YELLOW}${score}/100${NC}${BOLD} (Needs Improvement)${NC}"
    else
        echo -e "${RED}${score}/100${NC}${BOLD} (Critical - Action Required)${NC}"
    fi
    echo ""
}

