    fi
    
    # Handle rotation marking
    if [[ -n "$rotate_done" ]]; then
        local today
        today=$(date -Iseconds)
        
        case "$rotate_done" in
            ssh)
                jq --arg date "$today" '.lastSSHRotation = $date' "$SECURITY_STATE_FILE" > "${SECURITY_STATE_FILE}.tmp" && mv "${SECURITY_STATE_FILE}.tmp" "$SECURITY_STATE_FILE"
                log "SSH key rotation marked as done"
                ;;
            password)
                jq --arg date "$today" '.lastPasswordRotation = $date' "$SECURITY_STATE_FILE" > "${SECURITY_STATE_FILE}.tmp" && mv "${SECURITY_STATE_FILE}.tmp" "$SECURITY_STATE_FILE"
                log "Password rotation marked as done"
                ;;
            apikey)
                jq --arg date "$today" '.lastAPIKeyRotation = $date' "$SECURITY_STATE_FILE" > "${SECURITY_STATE_FILE}.tmp" && mv "${SECURITY_STATE_FILE}.tmp" "$SECURITY_STATE_FILE"
                log "API key rotation marked as done"
                ;;
            *)
                error "Unknown rotation type: $rotate_done"
                echo "Valid types: ssh, password, apikey"
                exit 1
                ;;
        esac
        return 0
    fi
    
    # Display monitoring info
    echo -e "${CYAN}${BOLD}Security Monitoring${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    
    local now
    now=$(date +%s)
    local ninety_days=$((90 * 24 * 60 * 60))
    
    # SSH rotation check
    local ssh_date
    ssh_date=$(jq -r '.lastSSHRotation // empty' "$SECURITY_STATE_FILE")
    if [[ -n "$ssh_date" ]]; then
        local ssh_ts
        ssh_ts=$(date -d "$ssh_date" +%s 2>/dev/null || echo "0")
        local ssh_age=$((now - ssh_ts))
        local ssh_days=$((ssh_age / 86400))
        
        printf "  ${BOLD}%-20s${NC} " "SSH Keys:"
        if [[ $ssh_age -gt $ninety_days ]]; then
            echo -e "${RED}${CROSS} $ssh_days days old (rotate recommended)${NC}"
            echo -e "      ${YELLOW}→ Run: xdc monitor --rotate-done ssh${NC}"
        else
            echo -e "${GREEN}${CHECK} $ssh_days days old${NC}"
        fi
    fi
    
    # Password rotation check
    local pwd_date
    pwd_date=$(jq -r '.lastPasswordRotation // empty' "$SECURITY_STATE_FILE")
    if [[ -n "$pwd_date" ]]; then
        local pwd_ts
        pwd_ts=$(date -d "$pwd_date" +%s 2>/dev/null || echo "0")
        local pwd_age=$((now - pwd_ts))
        local pwd_days=$((pwd_age / 86400))
        
        printf "  ${BOLD}%-20s${NC} " "Password:"
        if [[ $pwd_age -gt $ninety_days ]]; then
            echo -e "${RED}${CROSS} $pwd_days days old (rotate recommended)${NC}"
            echo -e "      ${YELLOW}→ Run: xdc monitor --rotate-done password${NC}"
        else
            echo -e "${GREEN}${CHECK} $pwd_days days old${NC}"
        fi
    fi
    
    # API key rotation check
    local api_date
    api_date=$(jq -r '.lastAPIKeyRotation // empty' "$SECURITY_STATE_FILE")
    if [[ -n "$api_date" ]]; then
        local api_ts
        api_ts=$(date -d "$api_date" +%s 2>/dev/null || echo "0")
        local api_age=$((now - api_ts))
        local api_days=$((api_age / 86400))
        
        printf "  ${BOLD}%-20s${NC} " "API Keys:"
        if [[ $api_age -gt $ninety_days ]]; then
            echo -e "${RED}${CROSS} $api_days days old (rotate recommended)${NC}"
            echo -e "      ${YELLOW}→ Run: xdc monitor --rotate-done apikey${NC}"
        else
            echo -e "${GREEN}${CHECK} $api_days days old${NC}"
        fi
    fi
    
    echo ""
    info "Recommendation: Rotate credentials every 90 days"
    echo ""
}

#==============================================================================
# Main
#==============================================================================

main() {
    # Check for jq and curl
    if ! command -v jq > /dev/null 2>&1; then
        echo "Warning: jq is not installed. Some features may not work properly." >&2
    fi
    
    if ! command -v curl > /dev/null 2>&1; then
        echo "Error: curl is required but not installed." >&2
        exit 1
    fi
    
    setup_colors
    
    local cmd="${1:-help}"
    shift || true
    
    case "$cmd" in
        status)
            cmd_status "$@"
            ;;
        sync)
            cmd_sync "$@"
            ;;
        health)
            cmd_health "$@"
            ;;
        logs)
            cmd_logs "$@"
            ;;
        stop)
            cmd_stop "$@"
            ;;
        start)
            cmd_start "$@"
            ;;
        restart)
            cmd_restart "$@"
            ;;
        update)
            cmd_update "$@"
            ;;
        security)
            cmd_security "$@"
            ;;
        snapshot)
            cmd_snapshot "$@"
            ;;
        attach)
            cmd_attach "$@"
            ;;
        info)
            cmd_info "$@"
            ;;
        peers)
            cmd_peers "$@"
            ;;
        backup)
            cmd_backup "$@"
            ;;
        monitor)
            cmd_monitor "$@"
            ;;
        help|-h|--help)
            cmd_help
            ;;
        *)
            error "Unknown command: $cmd"
            echo ""
            echo "Run 'xdc help' for usage information."
            exit 1
            ;;
    esac
}

main "$@"
