cmd_snapshot() {
    local snapshot_url="${SNAPSHOT_URL:-https://download.xinfin.network/xdcchain-mainnet.tar.gz}"
    local force=false
    local show_help=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --url) snapshot_url="$2"; shift 2 ;;
            --force) force=true; shift ;;
            --help|-h) show_help=true; shift ;;
            *) shift ;;
        esac
    done
    
    if [[ "$show_help" == true ]]; then
        cat << EOF
${CYAN}${BOLD}xdc snapshot${NC} — Restore from snapshot with resume support

${BOLD}USAGE:${NC}
    xdc snapshot [options]

${BOLD}OPTIONS:${NC}
    --url URL        Snapshot URL (default: https://download.xinfin.network/xdcchain-mainnet.tar.gz)
    --force          Force re-download even if complete
    --help           Show this help

${BOLD}DESCRIPTION:${NC}
    Downloads and restores the XDC chain from an official snapshot.
    Supports resume for interrupted downloads.
    Tracks state in /var/lib/xdc/snapshot-state.json

${BOLD}STATE FILE:${NC}
    Tracks: stage, bytesDownloaded, totalBytes, startedAt

EOF
        return 0
    fi
    
    # Ensure state directory exists
    mkdir -p "$(dirname "$SNAPSHOT_STATE_FILE")"
    
    local download_dir="/var/tmp/xdc-snapshot"
    mkdir -p "$download_dir"
    
    local filename=$(basename "$snapshot_url")
    local download_path="$download_dir/$filename"
    
    # Check for existing state
    local stage=""
    local bytesDownloaded=0
    local totalBytes=0
    
    if [[ -f "$SNAPSHOT_STATE_FILE" ]]; then
        stage=$(jq -r '.stage // "new"' "$SNAPSHOT_STATE_FILE" 2>/dev/null || echo "new")
        bytesDownloaded=$(jq -r '.bytesDownloaded // 0' "$SNAPSHOT_STATE_FILE" 2>/dev/null || echo "0")
        totalBytes=$(jq -r '.totalBytes // 0' "$SNAPSHOT_STATE_FILE" 2>/dev/null || echo "0")
    fi
    
    if [[ "$force" == true ]]; then
        stage="new"
        rm -f "$download_path"
    fi
    
    # Handle resumption
    if [[ "$stage" == "complete" && "$force" != true ]]; then
        info "Snapshot already restored. Use --force to re-download."
        return 0
    fi
    
    if [[ "$stage" == "extracting" ]]; then
        info "Previous extraction was interrupted. Checking..."
        # Could verify partial extraction here
    fi
    
    # Download phase
    if [[ "$stage" != "extracting" && "$stage" != "complete" ]]; then
        info "Downloading snapshot from $snapshot_url"
        
        # Get file size if not known
        if [[ "$totalBytes" -eq 0 ]]; then
            totalBytes=$(curl -sI "$snapshot_url" 2>/dev/null | grep -i content-length | tail -1 | awk '{print $2}' | tr -d '\r')
            totalBytes=${totalBytes:-0}
        fi
        
        # Save state
        jq -n \
            --arg stage "downloading" \
            --argjson bytes "$bytesDownloaded" \
            --argjson total "$totalBytes" \
            --arg started "$(date -Iseconds)" \
            '{stage: $stage, bytesDownloaded: $bytes, totalBytes: $total, startedAt: $started}' \
            > "$SNAPSHOT_STATE_FILE"
        
        # Download with resume and progress
        local curl_opts="-C - -L --fail"
        if [[ -t 1 ]]; then
            curl_opts="$curl_opts --progress-bar"
        fi
        
        echo ""
        info "Starting download... (supports resume)"
        
        if ! eval curl $curl_opts -o "$download_path" "$snapshot_url" 2>&1; then
            error "Download failed"
            exit 1
        fi
        
        # Update state
        bytesDownloaded=$(stat -c%s "$download_path" 2>/dev/null || stat -f%z "$download_path" 2>/dev/null || echo "0")
        jq --argjson bytes "$bytesDownloaded" '.bytesDownloaded = $bytes | .stage = "downloaded"' \
            "$SNAPSHOT_STATE_FILE" > "${SNAPSHOT_STATE_FILE}.tmp" && mv "${SNAPSHOT_STATE_FILE}.tmp" "$SNAPSHOT_STATE_FILE"
        
        log "Download complete: $(du -h "$download_path" | cut -f1)"
        
        # Check for checksum
        local checksum_url="${snapshot_url}.sha256"
        local checksum_file="$download_dir/${filename}.sha256"
        
        if curl -sI "$checksum_url" 2>/dev/null | grep -q "200 OK"; then
            info "Validating checksum..."
            curl -s -L -o "$checksum_file" "$checksum_url" 2>/dev/null || true
            
            if [[ -f "$checksum_file" ]]; then
                cd "$download_dir"
                if sha256sum -c "$checksum_file" > /dev/null 2>&1; then
                    log "Checksum validated"
                else
                    error "Checksum validation failed!"
                    exit 1
                fi
            fi
        fi
    fi
    
    # Stop node before extraction
    info "Stopping XDC node for snapshot restore..."
    _get_container; docker stop "${XDC_CONTAINER:-xdc-node}" 2>/dev/null || true
    
    # Update state
    jq '.stage = "extracting"' "$SNAPSHOT_STATE_FILE" > "${SNAPSHOT_STATE_FILE}.tmp" && mv "${SNAPSHOT_STATE_FILE}.tmp" "$SNAPSHOT_STATE_FILE"
    
    # Extract phase
    info "Extracting snapshot to $XDC_DATA..."
    mkdir -p "$XDC_DATA"
    
    if [[ "$filename" == *.tar.gz ]]; then
        tar -xzf "$download_path" -C "$XDC_DATA" --strip-components=1 2>&1 | while read -r line; do
            echo -ne "\r  Extracting: $line"
        done
    elif [[ "$filename" == *.tar ]]; then
        tar -xf "$download_path" -C "$XDC_DATA" --strip-components=1 2>&1 | while read -r line; do
            echo -ne "\r  Extracting: $line"
        done
    fi
    echo ""
    
    # Get starting block
    local start_block="unknown"
    if [[ -f "$XDC_DATA/XDC/chaindata/CURRENT" ]]; then
        # Try to determine block from leveldb metadata
        start_block="$(ls -la "$XDC_DATA" 2>/dev/null | wc -l)"
    fi
    
    # Update state
    jq '.stage = "complete"' "$SNAPSHOT_STATE_FILE" > "${SNAPSHOT_STATE_FILE}.tmp" && mv "${SNAPSHOT_STATE_FILE}.tmp" "$SNAPSHOT_STATE_FILE"
    
    # Start node
    info "Starting XDC node..."
    docker start xdc 2>/dev/null || true
    
    log "Snapshot restored successfully"
    echo ""
    echo -e "  ${CYAN}Snapshot restored. Node starting from block ${start_block}.${NC}"
    echo -e "  ${CYAN}Estimated time to tip: ~2-4 hours depending on network${NC}"
    echo ""
}

