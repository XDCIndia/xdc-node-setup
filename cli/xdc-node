readonly XDC_DATA="${XDC_DATA:-/root/xdcchain}"
readonly XDC_LOGS="${XDC_LOGS:-/var/log}"
readonly XDC_BACKUP="${XDC_BACKUP:-/backup/xdc-node}"

# Default config files
readonly VERSIONS_FILE="${XDC_HOME}/configs/versions.json"
readonly NOTIFY_CONF="${XDC_HOME}/configs/notify.conf"

# Global flags
OUTPUT_JSON=false
QUIET=false
VERBOSE=false
NO_COLOR=false

# Colors (will be disabled if --no-color or not a TTY)
declare -A COLORS=(
    [RED]='\033[0;31m'
    [GREEN]='\033[0;32m'
