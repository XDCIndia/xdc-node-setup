#==============================================================================
# Command: status
#==============================================================================

cmd_status() {
    local show_help=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h) show_help=true; shift ;;
            *) shift ;;
        esac
    done
    
    if [[ "$show_help" == true ]]; then
        cat << EOF
${CYAN}${BOLD}xdc status${NC} — Show rich node status

${BOLD}USAGE:${NC}
    xdc status

${BOLD}OUTPUT:${NC}
    • Node running/stopped status
    • Current block height
    • Connected peer count
    • Sync percentage
    • Uptime
    • Disk usage
    • RPC latency

EOF
        return 0
    fi
    
    echo -e "${CYAN}${BOLD}XDC Node Status${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    
    # Check if container is running
    local container_status="stopped"
    local uptime="N/A"
    local docker_image="N/A"
    
    if docker ps --format '{{.Names}}' 2>/dev/null | grep -qi "xdc.*node\|xdc.*chain\|xdc.*mainnet"; then
        container_status="running"
        uptime=$(docker inspect --format='{{.State.StartedAt}}' xdc 2>/dev/null | xargs -I {} date -d "{}" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo "Unknown")
        docker_image=$(docker inspect --format='{{.Config.Image}}' xdc 2>/dev/null || echo "Unknown")
    elif docker ps -a --format '{{.Names}}' 2>/dev/null | grep -qi "xdc.*node\|xdc.*chain\|xdc.*mainnet"; then
        container_status="stopped"
    fi
    
    # Get block height
    local block_height="N/A"
    local hex_height
    hex_height=$(rpc_get_result "eth_blockNumber")
    if [[ -n "$hex_height" && "$hex_height" != "null" ]]; then
        block_height=$((16#${hex_height#0x}))
    fi
    
    # Get peer count
    local peers="N/A"
    local hex_peers
    hex_peers=$(rpc_get_result "net_peerCount")
    if [[ -n "$hex_peers" && "$hex_peers" != "null" ]]; then
        peers=$((16#${hex_peers#0x}))
    fi
    
    # Check sync status
    local sync_status="unknown"
    local sync_pct="N/A"
    local syncing_response
    syncing_response=$(rpc_call "eth_syncing")
    local syncing
    syncing=$(echo "$syncing_response" | jq -r '.result // false')
    
    if [[ "$syncing" == "false" ]]; then
        sync_status="synced"
        sync_pct="100%"
    elif [[ "$syncing" != "null" && "$syncing" != "" ]]; then
        sync_status="syncing"
        local currentBlock
        local highestBlock
        currentBlock=$(echo "$syncing" | jq -r '.currentBlock // "0x0"')
        highestBlock=$(echo "$syncing" | jq -r '.highestBlock // "0x0"')
        if [[ -n "$currentBlock" && -n "$highestBlock" && "$highestBlock" != "0x0" ]]; then
            local current=$((16#${currentBlock#0x}))
            local highest=$((16#${highestBlock#0x}))
            if [[ $highest -gt 0 ]]; then
                sync_pct="$((current * 100 / highest))%"
            fi
        fi
    fi
    
    # Get disk usage
    local disk_usage="N/A"
    local disk_size="N/A"
    if [[ -d "$XDC_DATA" ]]; then
        disk_usage=$(du -sh "$XDC_DATA" 2>/dev/null | cut -f1 || echo "N/A")
        disk_size=$(df -h "$XDC_DATA" 2>/dev/null | awk 'NR==2 {print $2}' || echo "N/A")
    fi
    
    # Measure RPC latency
    local rpc_latency="N/A"
    local start_time end_time
    start_time=$(date +%s%N)
    rpc_call "eth_blockNumber" > /dev/null
    end_time=$(date +%s%N)
    if [[ "$start_time" != "" && "$end_time" != "" ]]; then
        rpc_latency="$(((end_time - start_time) / 1000000))ms"
    fi
    
    # Print status table
    printf "  ${BOLD}%-20s${NC} " "Status:"
    if [[ "$container_status" == "running" ]]; then
        echo -e "${GREEN}● Running${NC}"
    else
        echo -e "${RED}● Stopped${NC}"
    fi
    
    printf "  ${BOLD}%-20s${NC} %s\n" "Block Height:" "$block_height"
    printf "  ${BOLD}%-20s${NC} %s\n" "Peers:" "$peers"
    printf "  ${BOLD}%-20s${NC} %s\n" "Sync Status:" "$sync_status ($sync_pct)"
    printf "  ${BOLD}%-20s${NC} %s\n" "Started At:" "$uptime"
    printf "  ${BOLD}%-20s${NC} %s / %s\n" "Data Directory:" "$disk_usage" "$disk_size"
    printf "  ${BOLD}%-20s${NC} %s\n" "RPC Latency:" "$rpc_latency"
    printf "  ${BOLD}%-20s${NC} %s\n" "Docker Image:" "$docker_image"
    
    echo ""
}

#==============================================================================
# Command: sync
#==============================================================================

cmd_sync() {
    local show_help=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h) show_help=true; shift ;;
            *) shift ;;
        esac
    done
    
    if [[ "$show_help" == true ]]; then
        cat << EOF
${CYAN}${BOLD}xdc sync${NC} — Detailed sync info with progress bar

${BOLD}USAGE:${NC}
    xdc sync [--watch]

${BOLD}OUTPUT:${NC}
    • Current block vs highest block
       • Sync percentage with progress bar
    • Blocks remaining
    • Estimated time to completion

EOF
        return 0
    fi
    
    echo -e "${CYAN}${BOLD}Sync Status${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    
    local syncing_response
    syncing_response=$(rpc_call "eth_syncing")
    local syncing
    syncing=$(echo "$syncing_response" | jq -r '.result // false')
    
    if [[ "$syncing" == "false" ]]; then
        echo -e "  ${GREEN}${CHECK} Node is fully synced${NC}"
        
        # Get current block anyway
        local current_block
        current_block=$(rpc_get_result "eth_blockNumber")
        if [[ -n "$current_block" ]]; then
            local block_num=$((16#${current_block#0x}))
            echo "  Current Block: $block_num"
        fi
    elif [[ "$syncing" != "null" && "$syncing" != "" ]]; then
        local currentBlock highestBlock startingBlock
        currentBlock=$(echo "$syncing" | jq -r '.currentBlock // "0x0"')
        highestBlock=$(echo "$syncing" | jq -r '.highestBlock // "0x0"')
        startingBlock=$(echo "$syncing" | jq -r '.startingBlock // "0x0"')
        
        local current=$((16#${currentBlock#0x}))
        local highest=$((16#${highestBlock#0x}))
        local starting=$((16#${startingBlock#0x}))
        local remaining=$((highest - current))
        
        local pct=0
        if [[ $highest -gt $starting ]]; then
            pct=$(((current - starting) * 100 / (highest - starting)))
        fi
        
        # Progress bar
        local width=40
        local filled=$((pct * width / 100))
        local empty=$((width - filled))
        
        echo "  Current Block:  $current"
        echo "  Highest Block:  $highest"
        echo "  Blocks Behind:  $remaining"
        echo ""
        printf "  ["
        printf "%${filled}s" '' | tr ' ' '█'
        printf "%${empty}s" '' | tr ' ' '░'
        printf "] %d%%\n" "$pct"
        echo ""
        
        # Estimate time (rough calculation)
        if [[ -f "$SNAPSHOT_STATE_FILE" ]]; then
            info "Sync progress tracking available. Use 'xdc snapshot' for restore options."
        fi
    else
        warn "Unable to determine sync status. Is the node running?"
    fi
    
    echo ""
}

#==============================================================================
# Command: health
#==============================================================================

cmd_health() {
    local show_help=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h) show_help=true; shift ;;
            *) shift ;;
        esac
    done
    
    if [[ "$show_help" == true ]]; then
        cat << EOF
${CYAN}${BOLD}xdc health${NC} — Comprehensive health check with score

${BOLD}USAGE:${NC}
    xdc health

${BOLD}CHECKS:${NC}
    • Container running
    • RPC responsive
    • Block height progressing
    • Peer connectivity
    • Disk space
    • Memory usage
    • Sync status

${BOLD}OUTPUT:${NC}
    Health score 0-100 with color coding

EOF
        return 0
    fi
    
    echo -e "${CYAN}${BOLD}Health Check${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    
    local score=0
    local total_checks=0
    local passed_checks=0
    
    # Check 1: Container running
    total_checks=$((total_checks + 1))
    printf "  %-40s " "Container Status:"
    if docker ps --format '{{.Names}}' 2>/dev/null | grep -qi "xdc.*node\|xdc.*chain\|xdc.*mainnet"; then
        echo -e "${GREEN}${CHECK} Running${NC}"
        passed_checks=$((passed_checks + 1))
    else
        echo -e "${RED}${CROSS} Not Running${NC}"
    fi
    
    # Check 2: RPC responsive
    total_checks=$((total_checks + 1))
    printf "  %-40s " "RPC Connection:"
    local block_response
    block_response=$(rpc_call "eth_blockNumber")
    if echo "$block_response" | jq -e '.result' > /dev/null 2>&1; then
        echo -e "${GREEN}${CHECK} Responsive${NC}"
        passed_checks=$((passed_checks + 1))
    else
        echo -e "${RED}${CROSS} Unresponsive${NC}"
    fi
    
    # Check 3: Peer connectivity
    total_checks=$((total_checks + 1))
    printf "  %-40s " "Peer Connectivity:"
    local peer_count
    peer_count=$(rpc_get_result "net_peerCount")
    if [[ -n "$peer_count" && "$peer_count" != "0x0" ]]; then
        local peers=$((16#${peer_count#0x}))
        echo -e "${GREEN}${CHECK} $peers peers connected${NC}"
        passed_checks=$((passed_checks + 1))
    else
        echo -e "${YELLOW}${CROSS} No peers connected${NC}"
    fi
    
    # Check 4: Sync status
    total_checks=$((total_checks + 1))
    printf "  %-40s " "Sync Status:"
    local syncing_response
    syncing_response=$(rpc_call "eth_syncing")
    local syncing
    syncing=$(echo "$syncing_response" | jq -r '.result // false')
    if [[ "$syncing" == "false" ]]; then
        echo -e "${GREEN}${CHECK} Fully synced${NC}"
        passed_checks=$((passed_checks + 1))
    elif [[ "$syncing" != "null" ]]; then
        echo -e "${YELLOW}${CROSS} Syncing in progress${NC}"
    else
        echo -e "${RED}${CROSS} Unknown${NC}"
    fi
    
    # Check 5: Disk space
    total_checks=$((total_checks + 1))
    printf "  %-40s " "Disk Space:"
    if [[ -d "$XDC_DATA" ]]; then
        local disk_pct
        disk_pct=$(df "$XDC_DATA" 2>/dev/null | awk 'NR==2 {gsub(/%/,"",$5); print $5}' || echo "100")
        if [[ "$disk_pct" -lt 80 ]]; then
            echo -e "${GREEN}${CHECK} ${disk_pct}% used${NC}"
            passed_checks=$((passed_checks + 1))
        elif [[ "$disk_pct" -lt 90 ]]; then
            echo -e "${YELLOW}${CROSS} ${disk_pct}% used${NC}"
        else
            echo -e "${RED}${CROSS} ${disk_pct}% used (critical)${NC}"
        fi
    else
        echo -e "${RED}${CROSS} Data directory not found${NC}"
    fi
    
    # Check 6: Memory
    total_checks=$((total_checks + 1))
    printf "  %-40s " "System Memory:"
    local mem_pct
    mem_pct=$(free | awk '/^Mem:/{printf "%d", $3/$2 * 100}')
    if [[ "$mem_pct" -lt 80 ]]; then
        echo -e "${GREEN}${CHECK} ${mem_pct}% used${NC}"
        passed_checks=$((passed_checks + 1))
    elif [[ "$mem_pct" -lt 90 ]]; then
        echo -e "${YELLOW}${CROSS} ${mem_pct}% used${NC}"
    else
        echo -e "${RED}${CROSS} ${mem_pct}% used (high)${NC}"
    fi
    
    # Check 7: Block progression
    total_checks=$((total_checks + 1))
    printf "  %-40s " "Block Progression:"
    local block1 block2
    block1=$(rpc_get_result "eth_blockNumber")
    sleep 2
    block2=$(rpc_get_result "eth_blockNumber")
    if [[ -n "$block1" && -n "$block2" && "$block1" != "$block2" ]]; then
        echo -e "${GREEN}${CHECK} Producing blocks${NC}"
        passed_checks=$((passed_checks + 1))
    else
        echo -e "${YELLOW}${CROSS} No new blocks (may be synced)${NC}"
    fi
    
    # Calculate score
    score=$((passed_checks * 100 / total_checks))
    
    echo ""
    echo "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    printf "  ${BOLD}Health Score: "
    if [[ $score -ge 80 ]]; then
        echo -e "${GREEN}${score}/100${NC}${BOLD} (Excellent)${NC}"
    elif [[ $score -ge 60 ]]; then
        echo -e "${YELLOW}${score}/100${NC}${BOLD} (Fair)${NC}"
    else
        echo -e "${RED}${score}/100${NC}${BOLD} (Poor)${NC}"
    fi
    echo ""
}

#==============================================================================
# Command: logs
#==============================================================================

cmd_logs() {
    local lines=50
    local follow=false
    local show_help=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --lines|-n) lines="$2"; shift 2 ;;
            --follow|-f) follow=true; shift ;;
            --help|-h) show_help=true; shift ;;
            *) shift ;;
        esac
    done
    
    if [[ "$show_help" == true ]]; then
        cat << EOF
${CYAN}${BOLD}xdc logs${NC} — View node logs

${BOLD}USAGE:${NC}
    xdc logs [options]

${BOLD}OPTIONS:${NC}
    --lines, -n N    Number of lines to show (default: 50)
    --follow, -f     Follow log output
    --help           Show this help

EOF
        return 0
    fi
    
    if [[ "$follow" == true ]]; then
        _get_container; docker logs -f --tail "$lines" "${XDC_CONTAINER:-xdc-node}" 2>/dev/null || error "Container not found"
    else
        _get_container; docker logs --tail "$lines" "${XDC_CONTAINER:-xdc-node}" 2>/dev/null || error "Container not found"
    fi
}

