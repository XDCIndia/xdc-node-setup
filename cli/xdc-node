#!/usr/bin/env bash
# Source unified logging library
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../scripts/lib/common.sh" 2>/dev/null || source "/root/.openclaw/workspace/XDC-Node-Setup/scripts/lib/common.sh"
set -euo pipefail

#==============================================================================
# xdc — Comprehensive XDC Network Node Management CLI
# Version: 2.0.0
#==============================================================================

readonly CLI_VERSION="2.0.0"
readonly CLI_NAME="xdc"

# Determine installation directory
# Auto-detect install dir
if [[ -d "${INSTALL_DIR:-}" ]]; then
    readonly INSTALL_DIR="$INSTALL_DIR"
elif [[ -d "/opt/xdc-node/docker" ]]; then
    readonly INSTALL_DIR="/opt/xdc-node"
elif [[ -d "/opt/xdc/docker" ]]; then
    readonly INSTALL_DIR="/opt/xdc"
elif [[ -d "$HOME/.xdc-node/docker" ]]; then
    readonly INSTALL_DIR="$HOME/.xdc-node"
elif [[ -d "$HOME/workspace/xdc-node-setup/docker" ]]; then
    readonly INSTALL_DIR="$HOME/workspace/xdc-node-setup"
else
    readonly INSTALL_DIR="/opt/xdc-node"
fi
readonly XDC_HOME="${XDC_HOME:-/opt/xdc}"
readonly XDC_DATA="${XDC_DATA:-/root/xdcchain}"
readonly XDC_STATE_DIR="${XDC_STATE_DIR:-${XDC_DATA}/.state}"
readonly SECURITY_STATE_FILE="${XDC_STATE_DIR}/security-state.json"
readonly SNAPSHOT_STATE_FILE="${XDC_STATE_DIR}/snapshot-state.json"

# Default RPC settings
readonly XDC_RPC_PORT="${XDC_RPC_PORT:-9545}"
readonly XDC_RPC_URL="http://127.0.0.1:${XDC_RPC_PORT}"

# Find XDC node container name
find_container() {
    for name in xdc-node xdc xdcchain mainnet-node xdcnetwork-mainnet-node; do
        if docker ps -a --format '{{.Names}}' 2>/dev/null | grep -q "^${name}$"; then
            echo "$name"
            return 0
        fi
    done
    # Fallback: any container with xdc in the name
    docker ps -a --format '{{.Names}}' 2>/dev/null | grep -i 'xdc.*node\|xdc.*chain\|xdc.*mainnet' | head -1
}

XDC_CONTAINER=""
_get_container() {
    [[ -n "$XDC_CONTAINER" ]] && return
    XDC_CONTAINER=$(find_container)
}

# Colors
setup_colors() {
    if [[ -t 1 ]]; then
        readonly RED='\033[0;31m'
        readonly GREEN='\033[0;32m'
        readonly YELLOW='\033[1;33m'
        readonly BLUE='\033[0;34m'
        readonly CYAN='\033[0;36m'
        readonly MAGENTA='\033[0;35m'
        readonly BOLD='\033[1m'
        readonly NC='\033[0m'
        readonly CHECK='✅'
        readonly CROSS='❌'
    else
        readonly RED=''
        readonly GREEN=''
        readonly YELLOW=''
        readonly BLUE=''
        readonly CYAN=''
        readonly MAGENTA=''
        readonly BOLD=''
        readonly NC=''
        readonly CHECK='[OK]'
        readonly CROSS='[FAIL]'
    fi
}

# Print helpers
print_header() {
    echo -e "${CYAN}${BOLD}XDC Node CLI${NC} v${CLI_VERSION}"
    echo ""
}


rpc_get_result() {
    local method="$1"
    local params="${2:-[]}"
    local response
    response=$(rpc_call "$method" "$params")
    echo "$response" | jq -r '.result // empty' 2>/dev/null || echo ""
}

