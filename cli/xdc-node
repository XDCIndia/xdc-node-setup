#==============================================================================
# Main Entry Point
#==============================================================================
main() {
    # Parse global options first
    local args=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) OUTPUT_JSON=true; shift ;;
            --quiet|-q) QUIET=true; shift ;;
            --verbose|-v) VERBOSE=true; shift ;;
            --no-color) NO_COLOR=true; shift ;;
            *) args+=("$1"); shift ;;
        esac
    done
    set -- "${args[@]}"
    
    setup_colors
    
    # No command given
    if [[ $# -eq 0 ]]; then
        first_run_check
        print_help
        exit 0
    fi
    
    local command="$1"
    shift
    
    case "$command" in
        # XDC-specific commands
        masternode) cmd_masternode "$@" ;;
        peers)      cmd_peers "$@" ;;
        snapshot)   cmd_snapshot "$@" ;;
        monitor)    cmd_monitor "$@" ;;
        sync)       cmd_sync "$@" ;;
        rpc-secure) cmd_rpc_secure "$@" ;;
        network)    cmd_network "$@" ;;
        
        # General commands
        init)       cmd_init "$@" ;;
        status)     cmd_status "$@" ;;
        health)     cmd_health "$@" ;;
        security)   cmd_security "$@" ;;
        update)     cmd_update "$@" ;;
        backup)     cmd_backup "$@" ;;
        restore)    cmd_restore "$@" ;;
        logs)       cmd_logs "$@" ;;
        restart)    cmd_restart "$@" ;;
        stop)       cmd_stop "$@" ;;
        start)      cmd_start "$@" ;;
        config)     cmd_config "$@" ;;
        notify)     cmd_notify "$@" ;;
        dashboard)  cmd_dashboard "$@" ;;
        version)    cmd_version "$@" ;;
        help|--help|-h)
            print_help
            ;;
        *)
            error "Unknown command: $command"
            echo ""
            print_help
            exit 1
            ;;
    esac
}

# Run main
main "$@"
