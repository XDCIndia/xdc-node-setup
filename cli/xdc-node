log() {
    if [[ "$QUIET" != "true" ]]; then
        echo -e "$(c GREEN)✓$(c NC) $1"
    fi
}

info() {
    if [[ "$QUIET" != "true" ]]; then
        echo -e "$(c BLUE)ℹ$(c NC) $1"
    fi
}

warn() {
    echo -e "$(c YELLOW)⚠$(c NC) $1" >&2
}

error() {
    echo -e "$(c RED)✗$(c NC) $1" >&2
}

die() {
    error "$1"
    exit 1
}

verbose() {
    if [[ "$VERBOSE" == "true" ]]; then
        echo -e "$(c DIM)$1$(c NC)"
    fi
}

json_output() {
    if [[ "$OUTPUT_JSON" == "true" ]]; then
        echo "$1"
        return 0
    fi
    return 1
}

# Spinner for long operations
spinner_pid=""
start_spinner() {
    local msg="${1:-Processing}"
    if [[ "$QUIET" == "true" ]] || [[ "$OUTPUT_JSON" == "true" ]]; then
        return
    fi
    (
        local i=0
        while true; do
            printf "\r$(c CYAN)${SPINNER_CHARS:i++%${#SPINNER_CHARS}:1}$(c NC) %s..." "$msg"
            sleep 0.1
        done
    ) &
    spinner_pid=$!
    disown "$spinner_pid" 2>/dev/null || true
}

stop_spinner() {
    local success="${1:-true}"
    local msg="${2:-Done}"
    if [[ -n "$spinner_pid" ]]; then
        kill "$spinner_pid" 2>/dev/null || true
        wait "$spinner_pid" 2>/dev/null || true
        spinner_pid=""
    fi
    if [[ "$QUIET" != "true" ]] && [[ "$OUTPUT_JSON" != "true" ]]; then
        if [[ "$success" == "true" ]]; then
            printf "\r$(c GREEN)✓$(c NC) %s    \n" "$msg"
        else
            printf "\r$(c RED)✗$(c NC) %s    \n" "$msg"
        fi
    fi
}

# Progress bar
progress_bar() {
    local current=$1
    local total=$2
    local width=${3:-40}
    local label=${4:-"Progress"}
    
    if [[ "$QUIET" == "true" ]] || [[ "$OUTPUT_JSON" == "true" ]]; then
        return
    fi
    
    local percent=$((current * 100 / total))
    local filled=$((current * width / total))
    local empty=$((width - filled))
    
    printf "\r$(c CYAN)%s$(c NC) [" "$label"
    printf "%${filled}s" '' | tr ' ' '█'
    printf "%${empty}s" '' | tr ' ' '░'
    printf "] %3d%%" "$percent"
    
    if [[ $current -eq $total ]]; then
        echo ""
    fi
}

# Table drawing
print_table_header() {
    local cols=("$@")
    local line=""
    
    echo -e "$(c BOLD)┌$(printf '─%.0s' {1..78})┐$(c NC)"
    printf "$(c BOLD)│$(c NC)"
    for col in "${cols[@]}"; do
        printf " %-10s$(c BOLD)│$(c NC)" "$col"
    done
    echo ""
    echo -e "$(c BOLD)├$(printf '─%.0s' {1..78})┤$(c NC)"
}

print_table_row() {
    local cols=("$@")
    printf "$(c BOLD)│$(c NC)"
    for col in "${cols[@]}"; do
        printf " %-10s$(c BOLD)│$(c NC)" "$col"
    done
    echo ""
}

print_table_footer() {
    echo -e "$(c BOLD)└$(printf '─%.0s' {1..78})┘$(c NC)"
}

# Check if running as root
require_root() {
    if [[ $EUID -ne 0 ]]; then
        die "This command requires root privileges. Please run with sudo."
    fi
}

# Check if a command exists
command_exists() {
    command -v "$1" &>/dev/null
}

# RPC call helper
rpc_call() {
    local url="${1:-http://localhost:8545}"
    local method="$2"
    local params="${3:-[]}"
    
    curl -s -m 10 -X POST \
        -H "Content-Type: application/json" \
        -d "{\"jsonrpc\":\"2.0\",\"method\":\"$method\",\"params\":$params,\"id\":1}" \
        "$url" 2>/dev/null || echo '{}'
}

# Get config value from versions.json
get_config() {
    local key="$1"
    local default="${2:-}"
    
    if [[ -f "$VERSIONS_FILE" ]]; then
        local value
        value=$(jq -r "$key // empty" "$VERSIONS_FILE" 2>/dev/null)
        if [[ -n "$value" && "$value" != "null" ]]; then
            echo "$value"
            return 0
        fi
    fi
    echo "$default"
}

# Detect node service name
detect_service() {
    for service in xdc-node xdcchain xdc geth erigon; do
        if systemctl list-units --type=service --all | grep -q "$service"; then
            echo "$service"
            return 0
        fi
    done
    echo ""
}

# Detect running client
detect_client() {
    if pgrep -x "XDC" &>/dev/null || pgrep -f "geth.*xdc" &>/dev/null; then
        echo "XDPoSChain"
    elif pgrep -x "erigon" &>/dev/null; then
        echo "erigon-xdc"
    else
        echo "unknown"
    fi
}

#==============================================================================
# Command: init
#==============================================================================
cmd_init() {
    local quick=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --quick) quick=true; shift ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node init$(c NC) — Interactive setup wizard

$(c BOLD)USAGE:$(c NC)
    xdc-node init [options]

$(c BOLD)OPTIONS:$(c NC)
    --quick     Minimal setup with defaults
    --help      Show this help

$(c BOLD)DESCRIPTION:$(c NC)
    Runs the interactive XDC node setup wizard. This will:
    - Check system requirements
    - Install dependencies
    - Configure the node
    - Set up monitoring and alerts

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    require_root
    
    if [[ ! -f "${PROJECT_DIR}/setup.sh" ]]; then
        die "Setup script not found at ${PROJECT_DIR}/setup.sh"
    fi
    
    print_banner
    
    if [[ "$quick" == "true" ]]; then
        info "Running quick setup with defaults..."
        export NON_INTERACTIVE=true
        bash "${PROJECT_DIR}/setup.sh"
    else
        info "Starting interactive setup wizard..."
        bash "${PROJECT_DIR}/setup.sh"
    fi
}

#==============================================================================
# Command: status
#==============================================================================
cmd_status() {
    local watch=false
    local interval=5
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --watch|-w) watch=true; shift ;;
            --interval) interval="$2"; shift 2 ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node status$(c NC) — Quick node status overview

$(c BOLD)USAGE:$(c NC)
    xdc-node status [options]

$(c BOLD)OPTIONS:$(c NC)
    --watch, -w      Auto-refresh every 5 seconds
    --interval N     Refresh interval in seconds (default: 5)
    --json           Output in JSON format
    --help           Show this help

$(c BOLD)OUTPUT:$(c NC)
    Shows a table with: Node | Block | Peers | Sync% | CPU | RAM | Disk | Status

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    show_status() {
        local rpc_url="${XDC_RPC_URL:-http://localhost:8545}"
        local mainnet_rpc="${MAINNET_RPC_URL:-https://erpc.xinfin.network}"
        
        # Get block height
        local response
        response=$(rpc_call "$rpc_url" "eth_blockNumber")
        local hex_height
        hex_height=$(echo "$response" | jq -r '.result // "0x0"')
        local block_height=0
        if [[ "$hex_height" != "0x0" && -n "$hex_height" && "$hex_height" != "null" ]]; then
            block_height=$((16#${hex_height#0x}))
        fi
        
        # Get mainnet height for sync %
        response=$(rpc_call "$mainnet_rpc" "eth_blockNumber")
        hex_height=$(echo "$response" | jq -r '.result // "0x0"')
        local mainnet_height=0
        if [[ "$hex_height" != "0x0" && -n "$hex_height" && "$hex_height" != "null" ]]; then
            mainnet_height=$((16#${hex_height#0x}))
        fi
        
        # Calculate sync percentage
        local sync_pct=0
        if [[ $mainnet_height -gt 0 ]]; then
            sync_pct=$((block_height * 100 / mainnet_height))
            [[ $sync_pct -gt 100 ]] && sync_pct=100
        fi
        
        # Get peer count
        response=$(rpc_call "$rpc_url" "net_peerCount")
        local hex_peers
        hex_peers=$(echo "$response" | jq -r '.result // "0x0"')
        local peers=0
        if [[ "$hex_peers" != "0x0" && -n "$hex_peers" && "$hex_peers" != "null" ]]; then
            peers=$((16#${hex_peers#0x}))
        fi
        
        # Get system stats
        local cpu_usage
        cpu_usage=$(top -bn1 | grep "Cpu(s)" | awk '{print int($2 + $4)}')
        local ram_usage
        ram_usage=$(free | awk '/^Mem:/{printf "%.0f", $3/$2 * 100}')
        local disk_usage
        disk_usage=$(df -h "${XDC_DATA}" 2>/dev/null | awk 'NR==2 {gsub(/%/,"",$5); print $5}' || echo "0")
        
        # Determine status
        local status="$(c GREEN)●$(c NC) Online"
        local status_json="online"
        
        if [[ $block_height -eq 0 ]]; then
            status="$(c RED)●$(c NC) Offline"
            status_json="offline"
        elif [[ $sync_pct -lt 99 ]]; then
            status="$(c YELLOW)●$(c NC) Syncing"
            status_json="syncing"
        elif [[ $peers -lt 3 ]]; then
            status="$(c YELLOW)●$(c NC) Low Peers"
            status_json="low_peers"
        fi
        
        # Detect client
        local client
        client=$(detect_client)
        
        if json_output ""; then
            cat << EOF
{
  "client": "$client",
  "blockHeight": $block_height,
  "mainnetHeight": $mainnet_height,
  "syncPercent": $sync_pct,
  "peers": $peers,
  "cpu": $cpu_usage,
  "ram": $ram_usage,
  "disk": $disk_usage,
  "status": "$status_json",
  "timestamp": "$(date -Iseconds)"
}
EOF
            return 0
        fi
        
        # Print table
        echo ""
        echo -e "$(c BOLD)┌─────────────────────────────────────────────────────────────────────────────┐$(c NC)"
        echo -e "$(c BOLD)│$(c NC)                       $(c CYAN)XDC Node Status$(c NC)                                      $(c BOLD)│$(c NC)"
        echo -e "$(c BOLD)├─────────────┬───────────┬───────┬───────┬───────┬───────┬───────┬──────────┤$(c NC)"
        echo -e "$(c BOLD)│$(c NC) $(c WHITE)Client$(c NC)      $(c BOLD)│$(c NC) $(c WHITE)Block$(c NC)     $(c BOLD)│$(c NC) $(c WHITE)Peers$(c NC) $(c BOLD)│$(c NC) $(c WHITE)Sync%$(c NC) $(c BOLD)│$(c NC) $(c WHITE)CPU$(c NC)   $(c BOLD)│$(c NC) $(c WHITE)RAM$(c NC)   $(c BOLD)│$(c NC) $(c WHITE)Disk$(c NC)  $(c BOLD)│$(c NC) $(c WHITE)Status$(c NC)   $(c BOLD)│$(c NC)"
        echo -e "$(c BOLD)├─────────────┼───────────┼───────┼───────┼───────┼───────┼───────┼──────────┤$(c NC)"
        printf "$(c BOLD)│$(c NC) %-11s $(c BOLD)│$(c NC) %-9s $(c BOLD)│$(c NC) %-5s $(c BOLD)│$(c NC) %-5s $(c BOLD)│$(c NC) %-5s $(c BOLD)│$(c NC) %-5s $(c BOLD)│$(c NC) %-5s $(c BOLD)│$(c NC) %b $(c BOLD)│$(c NC)\n" \
            "${client:0:11}" \
            "$block_height" \
            "$peers" \
            "${sync_pct}%" \
            "${cpu_usage}%" \
            "${ram_usage}%" \
            "${disk_usage}%" \
            "$status"
        echo -e "$(c BOLD)└─────────────┴───────────┴───────┴───────┴───────┴───────┴───────┴──────────┘$(c NC)"
        echo ""
        echo -e "$(c DIM)Updated: $(date '+%Y-%m-%d %H:%M:%S')$(c NC)"
    }
    
    if [[ "$watch" == "true" ]]; then
        while true; do
            clear
            print_banner
            show_status
            echo ""
            echo -e "$(c DIM)Press Ctrl+C to exit. Refreshing every ${interval}s...$(c NC)"
            sleep "$interval"
        done
    else
        show_status
    fi
}

#==============================================================================
# Command: health
#==============================================================================
cmd_health() {
    local full=false
    local notify=false
    local security_only=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --full) full=true; shift ;;
            --notify) notify=true; shift ;;
            --security-only) security_only=true; shift ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node health$(c NC) — Run health check

$(c BOLD)USAGE:$(c NC)
    xdc-node health [options]

$(c BOLD)OPTIONS:$(c NC)
    --full           Run comprehensive health check
    --notify         Send notification with results
    --security-only  Only run security-related checks
    --json           Output in JSON format
    --help           Show this help

$(c BOLD)CHECKS:$(c NC)
    - Block height and sync status
    - Peer connectivity
    - RPC responsiveness
    - Disk/CPU/RAM usage
    - Process health
    - Network connectivity

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    local script="${SCRIPTS_DIR}/node-health-check.sh"
    
    if [[ ! -f "$script" ]]; then
        die "Health check script not found at $script"
    fi
    
    local args=()
    [[ "$full" == "true" ]] && args+=(--full)
    [[ "$notify" == "true" ]] && args+=(--notify)
    [[ "$security_only" == "true" ]] && args+=(--security-only)
    
    if [[ "$QUIET" != "true" ]]; then
        print_banner
        echo -e "$(c BOLD)Running Health Check$(c NC)"
        echo ""
    fi
    
    local pass_count=0
    local fail_count=0
    local warn_count=0
    
    # Run the health check script
    start_spinner "Running health checks"
    
    local output
    if output=$(bash "$script" "${args[@]}" 2>&1); then
        stop_spinner true "Health check completed"
    else
        stop_spinner false "Health check completed with issues"
    fi
    
    if [[ "$OUTPUT_JSON" == "true" ]]; then
        # Extract JSON from script output or generate summary
        echo "$output" | grep -E '^\{' || cat << EOF
{
  "status": "completed",
  "timestamp": "$(date -Iseconds)",
  "checks": {
    "passed": $pass_count,
    "failed": $fail_count,
    "warnings": $warn_count
  }
}
EOF
        return 0
    fi
    
    echo "$output"
    
    # Summary
    echo ""
    echo -e "$(c BOLD)━━━ Summary ━━━$(c NC)"
    echo "$output" | grep -c "✓" | xargs -I {} echo -e "$(c GREEN)✓$(c NC) Passed: {}"
    echo "$output" | grep -c "✗" | xargs -I {} echo -e "$(c RED)✗$(c NC) Failed: {}"
    echo "$output" | grep -c "⚠" | xargs -I {} echo -e "$(c YELLOW)⚠$(c NC) Warnings: {}"
}

#==============================================================================
# Command: security
#==============================================================================
cmd_security() {
    local audit_only=false
    local fix=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --audit-only) audit_only=true; shift ;;
            --fix) fix=true; shift ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node security$(c NC) — Run security audit

$(c BOLD)USAGE:$(c NC)
    xdc-node security [options]

$(c BOLD)OPTIONS:$(c NC)
    --audit-only  Check only, don't apply changes
    --fix         Apply recommended security fixes
    --json        Output in JSON format
    --help        Show this help

$(c BOLD)CHECKS:$(c NC)
    - SSH configuration
    - Firewall rules
    - File permissions
    - User accounts
    - Network exposure
    - Fail2ban status

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    require_root
    
    local script="${SCRIPTS_DIR}/security-harden.sh"
    
    if [[ ! -f "$script" ]]; then
        die "Security script not found at $script"
    fi
    
    if [[ "$QUIET" != "true" ]]; then
        print_banner
        echo -e "$(c BOLD)Security Audit$(c NC)"
        echo ""
    fi
    
    # Security checks
    declare -A checks=(
        ["SSH Key-Only Auth"]="grep -q 'PasswordAuthentication no' /etc/ssh/sshd_config 2>/dev/null"
        ["SSH Non-Standard Port"]="! grep -qE '^Port 22$' /etc/ssh/sshd_config 2>/dev/null"
        ["Firewall Enabled"]="ufw status | grep -q 'Status: active' 2>/dev/null"
        ["Fail2ban Active"]="systemctl is-active fail2ban &>/dev/null"
        ["Root Login Restricted"]="grep -qE 'PermitRootLogin (no|prohibit-password)' /etc/ssh/sshd_config 2>/dev/null"
        ["RPC Not Exposed"]="! netstat -tlnp 2>/dev/null | grep ':8545.*0.0.0.0' | grep -v '127.0.0.1'"
        ["WebSocket Not Exposed"]="! netstat -tlnp 2>/dev/null | grep ':8546.*0.0.0.0' | grep -v '127.0.0.1'"
        ["Automatic Updates"]="systemctl is-enabled unattended-upgrades &>/dev/null"
    )
    
    local total=0
    local passed=0
    local results=()
    
    for check in "${!checks[@]}"; do
        total=$((total + 1))
        local status="fail"
        local icon="$(c RED)✗$(c NC)"
        
        if eval "${checks[$check]}" &>/dev/null; then
            passed=$((passed + 1))
            status="pass"
            icon="$(c GREEN)✓$(c NC)"
        fi
        
        results+=("$icon $check")
        
        if [[ "$OUTPUT_JSON" != "true" ]]; then
            echo -e "$icon $check"
        fi
    done
    
    local score=$((passed * 100 / total))
    local score_color
    if [[ $score -ge 80 ]]; then
        score_color="$(c GREEN)"
    elif [[ $score -ge 60 ]]; then
        score_color="$(c YELLOW)"
    else
        score_color="$(c RED)"
    fi
    
    if [[ "$OUTPUT_JSON" == "true" ]]; then
        cat << EOF
{
  "score": $score,
  "passed": $passed,
  "total": $total,
  "timestamp": "$(date -Iseconds)"
}
EOF
        return 0
    fi
    
    echo ""
    echo -e "$(c BOLD)━━━ Security Score ━━━$(c NC)"
    echo -e "${score_color}${score}/100$(c NC) ($passed/$total checks passed)"
    
    if [[ "$fix" == "true" && "$audit_only" != "true" ]]; then
        echo ""
        info "Applying security fixes..."
        bash "$script"
    elif [[ $score -lt 80 ]]; then
        echo ""
        warn "Run 'xdc-node security --fix' to apply recommended fixes"
    fi
}

#==============================================================================
# Command: update
#==============================================================================
cmd_update() {
    local check_only=false
    local apply=false
    local client=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --check) check_only=true; shift ;;
            --apply) apply=true; shift ;;
            --client) client="$2"; shift 2 ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node update$(c NC) — Check and apply version updates

$(c BOLD)USAGE:$(c NC)
    xdc-node update [options]

$(c BOLD)OPTIONS:$(c NC)
    --check         Check for updates without applying
    --apply         Download and install updates
    --client NAME   Specific client (XDPoSChain, erigon-xdc)
    --json          Output in JSON format
    --help          Show this help

$(c BOLD)DESCRIPTION:$(c NC)
    Checks GitHub releases for new versions of XDC clients
    and optionally applies updates with rolling restart.

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    local script="${SCRIPTS_DIR}/version-check.sh"
    
    if [[ ! -f "$script" ]]; then
        die "Version check script not found at $script"
    fi
    
    if [[ "$QUIET" != "true" ]]; then
        print_banner
        echo -e "$(c BOLD)Version Update Check$(c NC)"
        echo ""
    fi
    
    start_spinner "Checking for updates"
    
    local current_version
    local latest_version
    local detected_client
    
    detected_client=$(detect_client)
    current_version=$(get_config ".clients.${detected_client:-XDPoSChain}.current" "unknown")
    
    # Query GitHub for latest version
    local repo
    repo=$(get_config ".clients.${detected_client:-XDPoSChain}.repo" "XinFinOrg/XDPoSChain")
    local api_response
    api_response=$(curl -s "https://api.github.com/repos/$repo/releases/latest" 2>/dev/null || echo '{}')
    latest_version=$(echo "$api_response" | jq -r '.tag_name // "unknown"')
    
    stop_spinner true "Check completed"
    
    local update_available=false
    if [[ "$current_version" != "$latest_version" && "$latest_version" != "unknown" && "$latest_version" != "null" ]]; then
        update_available=true
    fi
    
    if [[ "$OUTPUT_JSON" == "true" ]]; then
        cat << EOF
{
  "client": "${detected_client:-unknown}",
  "currentVersion": "$current_version",
  "latestVersion": "$latest_version",
  "updateAvailable": $update_available,
  "timestamp": "$(date -Iseconds)"
}
EOF
        return 0
    fi
    
    echo -e "$(c BOLD)Client:$(c NC)           ${detected_client:-unknown}"
    echo -e "$(c BOLD)Current Version:$(c NC)  $current_version"
    echo -e "$(c BOLD)Latest Version:$(c NC)   $latest_version"
    echo ""
    
    if [[ "$update_available" == "true" ]]; then
        echo -e "$(c GREEN)✓$(c NC) Update available: $current_version → $latest_version"
        
        if [[ "$apply" == "true" && "$check_only" != "true" ]]; then
            echo ""
            info "Applying update..."
            require_root
            bash "$script" --apply
        elif [[ "$check_only" != "true" ]]; then
            echo ""
            info "Run 'xdc-node update --apply' to install the update"
        fi
    else
        echo -e "$(c GREEN)✓$(c NC) You are running the latest version"
    fi
}

#==============================================================================
# Command: backup
#==============================================================================
cmd_backup() {
    local full=false
    local incremental=false
    local encrypt=false
    local upload=false
    local list=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --full) full=true; shift ;;
            --incremental) incremental=true; shift ;;
            --encrypt) encrypt=true; shift ;;
            --upload) upload=true; shift ;;
            --list) list=true; shift ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node backup$(c NC) — Trigger backup

$(c BOLD)USAGE:$(c NC)
    xdc-node backup [options]

$(c BOLD)OPTIONS:$(c NC)
    --full          Full backup (default)
    --incremental   Incremental backup
    --encrypt       Encrypt backup with GPG
    --upload        Upload to configured remote storage
    --list          Show available backups
    --json          Output in JSON format
    --help          Show this help

$(c BOLD)DESCRIPTION:$(c NC)
    Creates a backup of node data and configuration.
    Supports encryption and remote upload to S3/FTP.

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    require_root
    
    local script="${SCRIPTS_DIR}/backup.sh"
    
    if [[ ! -f "$script" ]]; then
        die "Backup script not found at $script"
    fi
    
    if [[ "$list" == "true" ]]; then
        info "Available backups:"
        echo ""
        
        local backup_dirs=("$XDC_BACKUP/daily" "$XDC_BACKUP/weekly" "$XDC_BACKUP/monthly")
        
        for dir in "${backup_dirs[@]}"; do
            if [[ -d "$dir" ]]; then
                local basename_dir
                basename_dir=$(basename "$dir")
                echo -e "$(c BOLD)${basename_dir^}:$(c NC)"
                ls -lh "$dir" 2>/dev/null | tail -n +2 | while read -r line; do
                    echo "  $line"
                done
                echo ""
            fi
        done
        return 0
    fi
    
    if [[ "$QUIET" != "true" ]]; then
        print_banner
        echo -e "$(c BOLD)Backup$(c NC)"
        echo ""
    fi
    
    local args=()
    [[ "$full" == "true" ]] && args+=(--full)
    [[ "$incremental" == "true" ]] && args+=(--incremental)
    [[ "$encrypt" == "true" ]] && args+=(--encrypt)
    [[ "$upload" == "true" ]] && args+=(--upload)
    
    local start_time
    start_time=$(date +%s)
    
    # Simulate progress for demo, actual script handles this
    if [[ "$QUIET" != "true" && "$OUTPUT_JSON" != "true" ]]; then
        for i in {1..100}; do
            progress_bar "$i" 100 40 "Backing up"
            sleep 0.02
        done
    fi
    
    bash "$script" "${args[@]}"
    
    local end_time
    end_time=$(date +%s)
    local duration=$((end_time - start_time))
    
    if [[ "$OUTPUT_JSON" == "true" ]]; then
        cat << EOF
{
  "status": "completed",
  "duration": $duration,
  "timestamp": "$(date -Iseconds)"
}
EOF
        return 0
    fi
    
    echo ""
    log "Backup completed in ${duration}s"
}

#==============================================================================
# Command: restore
#==============================================================================
cmd_restore() {
    local backup_file=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node restore$(c NC) — Restore from backup

$(c BOLD)USAGE:$(c NC)
    xdc-node restore <backup-file>

$(c BOLD)OPTIONS:$(c NC)
    --help    Show this help

$(c BOLD)DESCRIPTION:$(c NC)
    Restores node data from a backup archive.
    Verifies integrity before restoration.

$(c BOLD)EXAMPLE:$(c NC)
    xdc-node restore /backup/xdc-node/daily/xdc-backup-2024-01-15.tar.gz

EOF
                return 0
                ;;
            -*) shift ;;
            *) backup_file="$1"; shift ;;
        esac
    done
    
    require_root
    
    if [[ -z "$backup_file" ]]; then
        die "Please specify a backup file. Run 'xdc-node backup --list' to see available backups."
    fi
    
    if [[ ! -f "$backup_file" ]]; then
        die "Backup file not found: $backup_file"
    fi
    
    if [[ "$QUIET" != "true" ]]; then
        print_banner
        echo -e "$(c BOLD)Restore from Backup$(c NC)"
        echo ""
    fi
    
    info "Backup file: $backup_file"
    
    # Verify integrity
    start_spinner "Verifying backup integrity"
    if tar -tzf "$backup_file" &>/dev/null; then
        stop_spinner true "Backup integrity verified"
    else
        stop_spinner false "Backup integrity check failed"
        die "Backup file is corrupted or invalid"
    fi
    
    # Confirmation
    echo ""
    warn "This will overwrite current node data!"
    read -p "Are you sure you want to continue? [y/N] " -n 1 -r
    echo ""
    
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        info "Restore cancelled"
        return 0
    fi
    
    # Stop node
    info "Stopping node..."
    cmd_stop
    
    # Restore
    start_spinner "Restoring data"
    
    local restore_dir="${XDC_DATA}"
    mkdir -p "$restore_dir"
    tar -xzf "$backup_file" -C "$restore_dir"
    
    stop_spinner true "Data restored"
    
    # Start node
    info "Starting node..."
    cmd_start
    
    log "Restore completed successfully"
}

#==============================================================================
# Command: logs
#==============================================================================
cmd_logs() {
    local lines=50
    local follow=false
    local client=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --lines|-n) lines="$2"; shift 2 ;;
            --follow|-f) follow=true; shift ;;
            --client) client="$2"; shift 2 ;;
            --help|-h)
                cat << EOF
$(c BOLD)xdc-node logs$(c NC) — Tail node logs

$(c BOLD)USAGE:$(c NC)
    xdc-node logs [options]

$(c BOLD)OPTIONS:$(c NC)
    --lines, -n N    Number of lines to show (default: 50)
    --follow, -f     Follow log output (like tail -f)
    --client NAME    Specific client logs (geth, erigon)
    --help           Show this help

$(c BOLD)EXAMPLE:$(c NC)
    xdc-node logs -f -n 100

EOF
                return 0
                ;;
            *) shift ;;
        esac
    done
    
    # Find log files
    local log_file=""
    local possible_logs=(
        "/var/log/xdc-node.log"
        "/var/log/xdcchain.log"
        "${XDC_DATA}/xdc.log"
        "${XDC_DATA}/geth.log"
        "${XDC_DATA}/erigon.log"
    )
    
    for log in "${possible_logs[@]}"; do
        if [[ -f "$log" ]]; then
            log_file="$log"
            break
        fi
    done
    
    # Also check journalctl
    local service
    service=$(detect_service)
    
    if [[ -n "$service" ]]; then
        if [[ "$follow" == "true" ]]; then
            journalctl -u "$service" -n "$lines" -f
        else
            journalctl -u "$service" -n "$lines" --no-pager
        fi
    elif [[ -n "$log_file" ]]; then
        if [[ "$follow" == "true" ]]; then
            tail -n "$lines" -f "$log_file"
        else
            tail -n "$lines" "$log_file"
        fi
    else
        die "No log files found. Is the node running?"
    fi
}

