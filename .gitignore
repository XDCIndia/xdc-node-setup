# XDC Node Setup - .gitignore

# Chain data
/root/xdcchain/
xdcchain/
!docker/*/xdcchain/.gitkeep
chaindata/
lightchaindata/
nodes/
geth/
/erigon/

# Node data directories
/data/
# Ignore runtime secrets but keep default configs
*/.xdc-node/*.bak
*/.xdc-node/client.conf
!*/.xdc-node/skynet.conf
!*/.xdc-node/.env
!*/.xdc-node/node.env
!*/.xdc-node/.gitignore
*.db
*.ldb

# Keystore (DO NOT COMMIT!)
keystore/
*.json.key
*.key
*.pem

# Secrets and credentials
.env.local
.env.production
*.secret
*.secrets
*_secret
*_key
*_password
credentials/
secrets/

# Reports and logs (but keep sample data)
reports/*
!reports/node-health-2026-02-11.json
*.log
*.log.*
/var/log/

# Backup files
*.backup
*.bak
*.tar.gz
*.tar.gz.enc
/backup/

# Docker volumes
docker-volumes/

# Temporary files
tmp/
temp/
*.tmp
*.swp
*.swo
*~

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE
.idea/
.vscode/
*.sublime-*
*.code-workspace

# Node.js (if any tooling uses it)
node_modules/

# Python (if any tooling uses it)
__pycache__/
*.py[cod]
venv/
.venv/

# Testing
.coverage
coverage/
*.cover
htmlcov/

# Build artifacts
build/
dist/
*.egg-info/

# Lock files for specific backup
*.lock
!package-lock.json
!yarn.lock

# Grafana provisioning (generated)
/monitoring/grafana/data/

# Prometheus data
/monitoring/prometheus-data/

# Security audit reports (may contain sensitive info)
/opt/xdc-node/reports/
security-audit-*.txt
security-score.json

# SSH keys (never commit)
id_rsa
id_ed25519
*.pub
known_hosts
authorized_keys

# SSL/TLS certificates
*.crt
*.cert
*.p12
*.pfx
ssl/
certs/

# Terraform (if used)
.terraform/
*.tfstate
*.tfstate.*
*.tfvars

# Ansible (if used)
*.retry
inventory/production
inventory/staging

# Local configuration overrides
*.local
*.local.*
docker-compose.override.yml

# User-specific SkyNet configs (contain node IDs, API keys, emails, etc.)
**/skynet.conf
**/skynet-erigon.conf
mainnet/nethermind-db

# Database files - DO NOT commit
apothem/nethermind-db/
apothem/nethermind-old-*/
*.sst
*.bloom
*.log
*.ldb
dashboard/node_modules/
dashboard/.next/
mainnet/
apothem/*.db
apothem/*-db/
apothem/*-old*/
*.pack
*.node
node_modules/
.next/

# Environment files with secrets
.env
**/.env
*.env
!.env.example
