# XDC Node Setup - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: Grafana Security Configuration
# =============================================================================
# Grafana admin password - MUST be set before starting monitoring stack
# Generate a strong password: openssl rand -base64 32
GRAFANA_ADMIN_PASSWORD=

# Grafana secret key for session signing - MUST be set in production
# Generate: openssl rand -base64 32
GRAFANA_SECRET_KEY=

# Optional: Grafana admin username (default: admin)
# GRAFANA_ADMIN_USER=admin

# Optional: Grafana external URL
# GRAFANA_ROOT_URL=http://localhost:3000

# =============================================================================
# REQUIRED: SkyNet Agent Configuration (if using monitoring)
# =============================================================================
SKYNET_NODE_ID=
SKYNET_API_KEY=
SKYNET_ENDPOINT=https://net.xdc.network

# =============================================================================
# Node Configuration
# =============================================================================
INSTANCE_NAME=my-xdc-node
CONTACT_DETAILS=admin@example.com
NETWORK=mainnet
SYNC_MODE=full

# =============================================================================
# RPC Configuration
# =============================================================================
RPC_ADDR=127.0.0.1
RPC_PORT=8545

# =============================================================================
# SECURITY WARNING: Production Deployment Checklist
# =============================================================================
# 1. Change all default passwords above
# 2. Set strong GRAFANA_SECRET_KEY for session security
# 3. Configure firewall rules (only open necessary ports)
# 4. Enable SSL/TLS for external access
# 5. Review CORS settings for RPC endpoints
# =============================================================================
