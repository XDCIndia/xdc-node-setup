# XDC Node Setup - Environment Variables
# Copy this file to .env and fill in your values

# Grafana Configuration
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=${GRAFANA_PASSWORD:-admin_change_me}
GRAFANA_PASSWORD=

# RPC Configuration
RPC_ADDR=127.0.0.1
RPC_PORT=8545

# RPC Rate Limiting (requests per minute per IP)
RPC_RATE_LIMIT=100

# TLS Configuration
TLS_ENABLED=false
TLS_CERT_PATH=/certs/server.crt
TLS_KEY_PATH=/certs/server.key

# Let's Encrypt (for production)
LETSENCRYPT_ENABLED=false
LETSENCRYPT_EMAIL=admin@example.com
LETSENCRYPT_DOMAIN=node.example.com

# Node Configuration
INSTANCE_NAME=my-xdc-node
CONTACT_DETAILS=admin@example.com
NETWORK=mainnet
SYNC_MODE=full

# SkyNet (Optional)
SKYNET_API_KEY=
SKYNET_ENDPOINT=https://skynet.xdcindia.com

# XDPoS 2.0 Consensus Monitoring
XDPOS2_GAP_DETECTION=1              # Enable gap block monitoring
XDPOS2_QC_VALIDATION=1              # Enable QC validation
XDPOS2_EPOCH_MONITOR=1              # Enable epoch transition monitoring
XDPOS2_VOTE_MONITOR=1               # Enable vote participation monitoring

# XDPoS 2.0 Polling Intervals (seconds)
XDPOS2_GAP_POLL_INTERVAL=10         # Gap monitor poll interval
XDPOS2_QC_POLL_INTERVAL=30          # QC validator poll interval
XDPOS2_EPOCH_POLL_INTERVAL=15       # Epoch monitor poll interval
XDPOS2_VOTE_POLL_INTERVAL=20        # Vote monitor poll interval
