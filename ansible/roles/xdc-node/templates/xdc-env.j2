# XDC Node Environment Configuration
# Generated by Ansible on {{ ansible_date_time.iso8601 }}

# Network Configuration
NETWORK={{ xdc_network | default('mainnet') }}
INSTANCE_NAME={{ inventory_hostname }}

# Client Settings
CLIENT={{ client | default('XDPoSChain') }}
DATA_DIR={{ xdc_data_dir | default('/root/XDC-Node') }}

# RPC Configuration
RPC_PORT={{ rpc_port | default(8545) }}
RPC_ADDR={{ rpc_addr | default('127.0.0.1') }}
RPC_API={{ rpc_api | default('eth,net,web3,txpool') }}
{% if enable_public_rpc | default(false) | bool %}
RPC_VHOSTS={{ rpc_vhosts | default('*') }}
RPC_CORS={{ rpc_cors | default('*') }}
{% endif %}

# WebSocket Configuration
WS_PORT={{ ws_port | default(8546) }}
WS_ADDR={{ ws_addr | default('127.0.0.1') }}
WS_API={{ ws_api | default('eth,net,web3') }}

# P2P Configuration
P2P_PORT={{ p2p_port | default(30303) }}
MAX_PEERS={{ max_peers | default(100) }}

# Node Role Configuration
{% if node_role == 'validator' %}
ENABLE_MINING=true
COINBASE={{ coinbase | default('') }}
UNLOCK={{ unlock_account | default('') }}
{% else %}
ENABLE_MINING=false
{% endif %}

# Logging
LOG_LEVEL={{ log_level | default('info') }}
LOG_FILE={{ xdc_data_dir | default('/root/XDC-Node') }}/logs/xdc.log

# Metrics
{% if enable_metrics | default(true) | bool %}
METRICS_ENABLED=true
METRICS_PORT={{ metrics_port | default(6060) }}
{% endif %}
